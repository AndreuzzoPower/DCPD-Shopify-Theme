{%- comment -%}
  Gestione padding mobile per sezioni con section_width.
  Ripristina il padding .page-width su mobile/tablet e gestisce il flag
  mobile_full_width per forzare la piena larghezza su mobile.

  Usa #shopify-section-ID (generato automaticamente da Shopify) per
  garantire la specificità massima anche nelle sezioni che non hanno
  un id="section-..." esplicito nel loro HTML.

  Input: nessuno — legge direttamente da section.settings
  Richiede: section.settings.mobile_full_width (checkbox, default false)
  Richiede: section.settings.section_width (select)
{%- endcomment -%}

{%- liquid
  assign ms_sw = section.settings.section_width | default: 'page_width'
  if ms_sw == 'default' or ms_sw == 'contained'
    assign ms_sw = 'page_width'
  elsif ms_sw == 'full'
    assign ms_sw = 'full_width'
  elsif ms_sw == 'fluid'
    assign ms_sw = 'page_fluid'
  endif
  assign ms_mobile_fw = section.settings.mobile_full_width | default: false
-%}

{%- unless ms_sw == 'full_width' -%}
  {%- if ms_mobile_fw -%}
    <style>
      @media screen and (max-width: 767px) {
        #shopify-section-{{ section.id }} .page-width,
        #section-{{ section.id }} .page-width {
          padding-left: 0 !important;
          padding-right: 0 !important;
        }
      }
      @media screen and (min-width: 768px) and (max-width: 989px) {
        #shopify-section-{{ section.id }} .page-width,
        #section-{{ section.id }} .page-width {
          padding-left: 0 !important;
          padding-right: 0 !important;
        }
      }
    </style>
  {%- else -%}
    <style>
      @media screen and (max-width: 767px) {
        #shopify-section-{{ section.id }} .page-width,
        #section-{{ section.id }} .page-width {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }
      @media screen and (min-width: 768px) and (max-width: 989px) {
        #shopify-section-{{ section.id }} .page-width,
        #section-{{ section.id }} .page-width {
          {%- if ms_sw == 'narrow' -%}
            padding-left: 9rem !important;
            padding-right: 9rem !important;
          {%- else -%}
            padding-left: 5rem !important;
            padding-right: 5rem !important;
          {%- endif -%}
        }
      }
    </style>
  {%- endif -%}
{%- endunless -%}
