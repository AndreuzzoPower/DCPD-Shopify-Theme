{%- comment -%}
  Snippet: icon-accordion.liquid
  Parametri:
    - icon (string): valore dal select Dawn (es. 'apple', 'check_mark', 'none').
    - custom_icon (string, opzionale): nome file SVG o classe libreria icone.
                                       Se compilato, sovrascrive il valore di `icon`.
{%- endcomment -%}
{%- if custom_icon != blank -%}
  {%- render 'ms_icon', icon: custom_icon -%}
{%- elsif icon != blank and icon != 'none' -%}
  {%- assign file = icon | replace: '_', '-' | prepend: 'icon-' | append: '.svg' -%}
  {%- render 'ms_icon', icon: file -%}
{%- endif -%}
