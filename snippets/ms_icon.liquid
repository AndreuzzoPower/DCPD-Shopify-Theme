{%- comment -%}
  Snippet: ms_icon.liquid
  Sistema centralizzato di rendering icone.

  Parametri:
    - icon (string, obbligatorio): nome file SVG in assets (es. 'icon-arrow.svg')
                                    OPPURE classe della libreria icone (es. 'fa-solid fa-house').
                                    Se contiene '.svg' → carica SVG inline da assets (raw, senza wrapper).
                                    Altrimenti → renderizza come <i class="..."> dentro un wrapper.
    - class (string, opzionale): classi CSS aggiuntive (solo per icone libreria).
    - aria_hidden (boolean, opzionale): default true (solo per icone libreria).
    - aria_label (string, opzionale): label accessibilità (solo per icone libreria).
{%- endcomment -%}

{%- if icon == blank -%}
  {%- break -%}
{%- endif -%}

{%- liquid
  assign icon_str = icon | strip
  assign is_svg = false
  if icon_str contains '.svg'
    assign is_svg = true
  endif
-%}

{%- if is_svg -%}
  {{- icon_str | inline_asset_content -}}
{%- else -%}
  {%- liquid
    assign hide_aria = true
    if aria_hidden == false or aria_label != blank
      assign hide_aria = false
    endif
  -%}
  <span class="svg-wrapper icon-lib-wrapper{% if class != blank %} {{ class }}{% endif %}"{% if hide_aria %} aria-hidden="true"{% endif %}{% if aria_label != blank %} role="img" aria-label="{{ aria_label }}"{% endif %}>
    <i class="{{ icon_str }}"></i>
  </span>
{%- endif -%}
