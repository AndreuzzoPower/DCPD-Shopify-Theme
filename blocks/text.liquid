{%- liquid
  assign title_tag = block.settings.title_tag | default: 'h2'
  assign title_classes = block.settings.title_size | default: 'h1'
  if block.settings.title_custom_class != blank
    assign title_classes = title_classes | append: ' ' | append: block.settings.title_custom_class
  endif

-%}

<style>
  #shopify-block-{{ block.id }},
  #ms-block-{{ block.id }} {
    grid-column: span {{ block.settings.mobile_layout }};
    align-self: {{ block.settings.vertical_align }};
  }
  @media (min-width: 750px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.tablet_layout }}; }
  }
  @media (min-width: 990px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.desktop_layout }}; }
  }
  #ms-block-{{ block.id }} {
    text-align: {{ block.settings.alignment }};
  }
</style>

<div id="ms-block-{{ block.id }}" class="ms-block ms-block-text">
  {%- if block.settings.title != blank -%}
    <{{ title_tag }} class="{{ title_classes }}">{{ block.settings.title }}</{{ title_tag }}>
  {%- endif -%}

  {%- if block.settings.text != blank -%}
    <div class="rte">{{ block.settings.text }}</div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Testo",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "id": "desktop_layout",
      "label": "Colonne desktop",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 4,
      "info": "Schermi maggiori di 990px"
    },
    {
      "id": "tablet_layout",
      "label": "Colonne tablet",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 6,
      "info": "Schermi tra 750px e 990px"
    },
    {
      "id": "mobile_layout",
      "label": "Colonne mobile",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi sotto i 750px"
    },
    {
      "id": "vertical_align",
      "label": "Allineamento verticale",
      "type": "select",
      "options": [
        { "label": "In alto", "value": "start" },
        { "label": "Centro", "value": "center" },
        { "label": "In basso", "value": "end" },
        { "label": "Esteso", "value": "stretch" }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "Titolo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titolo"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag HTML titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Dimensione visiva titolo",
      "info": "Classe CSS che determina la dimensione del testo, indipendente dal tag HTML.",
      "options": [
        { "label": "Piccola", "value": "h2" },
        { "label": "Media", "value": "h1" },
        { "label": "Grande", "value": "h0" },
        { "label": "Extra grande", "value": "hxl" },
        { "label": "Extra extra grande", "value": "hxxl" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Testo"
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Allineamento testo",
      "default": "left"
    }
  ],
  "presets": [
    { "name": "Testo" }
  ]
}
{% endschema %}
