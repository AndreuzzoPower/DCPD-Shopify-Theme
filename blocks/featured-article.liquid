    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Mostra immagine",
      "default": true
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Altezza immagine",
      "options": [
        { "value": "adapt", "label": "Adatta (proporzioni originali)" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Info articolo"
    },
    {
      "type": "select",
      "id": "info_layout",
      "label": "Layout info",
      "options": [
        { "value": "horizontal", "label": "Orizzontale" },
        { "value": "vertical", "label": "Verticale" }
      ],
      "default": "horizontal",
      "info": "Mostra data, tempo di lettura e autore in riga o in colonna."
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Mostra data",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Mostra autore",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_reading",
      "label": "Mostra tempo di lettura",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Mostra estratto",
      "default": true
