{%- comment -%}
  Logica selezione articolo (priorità):
  1. Articolo specifico selezionato → mostra quell'articolo
  2. Blog selezionato → mostra l'articolo più recente del blog
  3. Menu blog selezionato → ultimo articolo tra tutti i blog del menu
  Nota: in Shopify Liquid, `blogs` NON è iterabile con for.
  Si usa un link_list (menu) contenente link ai blog desiderati.
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign target_article = nil
  assign target_blog = nil

  if block.settings.article != blank
    assign target_article = block.settings.article
    assign target_blog = target_article.blog
  elsif block.settings.blog != blank
    assign target_blog = block.settings.blog
    assign target_article = target_blog.articles.first
  elsif block.settings.blogs_menu != blank
    assign _menu = linklists[block.settings.blogs_menu]
    if _menu != blank and _menu.links.size > 0
      for link in _menu.links
        if link.type == 'blog_link'
          assign candidate = link.object.articles.first
          if candidate != nil
            if target_article == nil or candidate.published_at > target_article.published_at
              assign target_article = candidate
              assign target_blog = link.object
            endif
          endif
        endif
      endfor
    endif
  endif
-%}

<style>
  #shopify-block-{{ block.id }},
  #ms-block-{{ block.id }} {
    grid-column: span {{ block.settings.mobile_layout }};
    align-self: {{ block.settings.vertical_align }};
  }
  @media (min-width: 750px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.tablet_layout }}; }
  }
  @media (min-width: 990px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.desktop_layout }}; }
  }
</style>

<div id="ms-block-{{ block.id }}" class="ms-block ms-block-featured-article color-{{ block.settings.color_scheme }} gradient">
  {%- if target_article != nil -%}
    {%- render 'article-card',
      blog: target_blog,
      article: target_article,
      media_height: block.settings.image_height,
      media_aspect_ratio: target_article.image.aspect_ratio,
      show_image: block.settings.show_image,
      show_date: block.settings.show_date,
      show_author: block.settings.show_author,
      show_reading: block.settings.show_reading,
      show_icons: block.settings.show_icons,
      custom_icon_date: block.settings.custom_icon_date,
      custom_icon_reading: block.settings.custom_icon_reading,
      custom_icon_author: block.settings.custom_icon_author,
      show_excerpt: block.settings.show_excerpt,
      show_blog_name: block.settings.show_blog_name,
      blog_name: target_blog.title,
      blog_url: target_blog.url,
      show_tags: block.settings.show_tags,
      tags_style: block.settings.tags_style,
      info_layout: block.settings.info_layout,
      show_button: block.settings.show_button,
      button_label: block.settings.button_label,
      button_type: block.settings.button_type,
      button_style_secondary: block.settings.button_style_secondary,
      button_size: block.settings.button_size,
      button_icon: block.settings.button_icon,
      button_icon_position: block.settings.button_icon_position,
      button_align: block.settings.button_align,
      lazy_load: true
    -%}
  {%- else -%}
    <div class="ms-block-featured-article__empty" aria-label="Nessun articolo disponibile">
      <span class="visually-hidden">Nessun articolo disponibile.</span>
      <span aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</span>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Articolo In Evidenza",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "id": "desktop_layout",
      "label": "Colonne desktop",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 4,
      "info": "Schermi maggiori di 990px"
    },
    {
      "id": "tablet_layout",
      "label": "Colonne tablet",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 6,
      "info": "Schermi tra 750px e 990px"
    },
    {
      "id": "mobile_layout",
      "label": "Colonne mobile",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi sotto i 750px"
    },
    {
      "id": "vertical_align",
      "label": "Allineamento verticale",
      "type": "select",
      "options": [
        { "label": "In alto", "value": "start" },
        { "label": "Centro", "value": "center" },
        { "label": "In basso", "value": "end" },
        { "label": "Esteso", "value": "stretch" }
      ],
      "default": "start"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "paragraph",
      "content": "Priorità: 1) Articolo specifico, 2) Ultimo del blog selezionato, 3) Ultimo tra tutti i blog del menu."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog",
      "info": "Mostra l'articolo più recente del blog selezionato. Ignorato se è selezionato un articolo specifico."
    },
    {
      "type": "article",
      "id": "article",
      "label": "Articolo specifico",
      "info": "Se selezionato, ha la priorità sul blog."
    },
    {
      "type": "link_list",
