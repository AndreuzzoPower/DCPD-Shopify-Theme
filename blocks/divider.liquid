<style>
  #shopify-block-{{ block.id }},
  #ms-block-{{ block.id }} {
    grid-column: span {{ block.settings.mobile_layout }};
    align-self: {{ block.settings.vertical_align }};
  }
  @media (min-width: 750px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.tablet_layout }}; }
  }
  @media (min-width: 990px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.desktop_layout }}; }
  }
  #shopify-block-{{ block.id }} {
    padding-top: {{ block.settings.space_top }}px;
    padding-bottom: {{ block.settings.space_bottom }}px;
  }
  {%- if block.settings.show_rule -%}
  #ms-block-{{ block.id }} .ms-block-divider__rule {
    border: none;
    border-top-style: {{ block.settings.rule_style }};
    border-top-width: {{ block.settings.rule_thickness }}px;
    border-top-color: {{ block.settings.rule_color }};
    margin: 0;
  }
  {%- endif -%}
</style>

<div id="ms-block-{{ block.id }}" class="ms-block ms-block-divider">
  {%- if block.settings.show_rule -%}
    <hr class="ms-block-divider__rule" aria-hidden="true">
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Divisore",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "id": "desktop_layout",
      "label": "Colonne desktop",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi maggiori di 990px"
    },
    {
      "id": "tablet_layout",
      "label": "Colonne tablet",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi tra 750px e 990px"
    },
    {
      "id": "mobile_layout",
      "label": "Colonne mobile",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi sotto i 750px"
    },
    {
      "id": "vertical_align",
      "label": "Allineamento verticale",
      "type": "select",
      "options": [
        { "label": "In alto", "value": "start" },
        { "label": "Centro", "value": "center" },
        { "label": "In basso", "value": "end" },
        { "label": "Esteso", "value": "stretch" }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "space_top",
      "label": "Spazio sopra",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "space_bottom",
      "label": "Spazio sotto",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Linea"
    },
    {
      "type": "checkbox",
      "id": "show_rule",
      "label": "Mostra linea orizzontale",
      "default": true
    },
    {
      "type": "select",
      "id": "rule_style",
      "label": "Stile linea",
      "options": [
        { "label": "Solida", "value": "solid" },
        { "label": "Tratteggiata", "value": "dashed" },
        { "label": "Punteggiata", "value": "dotted" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Colore linea",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "rule_thickness",
      "label": "Spessore linea",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 1
    }
  ],
  "presets": [
    { "name": "Divisore" }
  ]
}
{% endschema %}
