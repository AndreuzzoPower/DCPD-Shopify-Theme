{%- liquid
  assign has_link = false
  if block.settings.image_link != blank
    assign has_link = true
  endif

  capture img_alt
    render 'ms_image_alt', image: block.settings.block_image, custom_alt: block.settings.image_alt
  endcapture
  assign img_alt = img_alt | strip
-%}

<style>
  #shopify-block-{{ block.id }},
  #ms-block-{{ block.id }} {
    grid-column: span {{ block.settings.mobile_layout }};
    align-self: {{ block.settings.vertical_align }};
  }
  @media (min-width: 750px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.tablet_layout }}; }
  }
  @media (min-width: 990px) {
    #shopify-block-{{ block.id }},
    #ms-block-{{ block.id }} { grid-column: span {{ block.settings.desktop_layout }}; }
  }
</style>

<div id="ms-block-{{ block.id }}" class="ms-block">
  {%- if has_link -%}
    <a
      href="{{ block.settings.image_link }}"
      target="{{ block.settings.image_link_target }}"
      {%- if block.settings.image_link_target == '_blank' %} rel="noopener noreferrer"{%- endif %}
      aria-label="{{ img_alt | default: 'Apri link' | escape }}"
    >
  {%- endif -%}

  {%- if block.settings.block_image != blank -%}
    {{
      block.settings.block_image
      | image_url: width: block.settings.block_image.width
      | image_tag: loading: 'lazy', widths: '165, 360, 535, 750, 1070, 1500', sizes: '100vw', alt: img_alt
    }}
  {%- else -%}
    <span aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</span>
  {%- endif -%}

  {%- if has_link -%}</a>{%- endif -%}
</div>

{% schema %}
{
  "name": "Immagine",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "id": "desktop_layout",
      "label": "Colonne desktop",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 6,
      "info": "Schermi maggiori di 990px"
    },
    {
      "id": "tablet_layout",
      "label": "Colonne tablet",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 6,
      "info": "Schermi tra 750px e 990px"
    },
    {
      "id": "mobile_layout",
      "label": "Colonne mobile",
      "type": "range",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "col",
      "default": 12,
      "info": "Schermi sotto i 750px"
    },
    {
      "id": "vertical_align",
      "label": "Allineamento verticale",
      "type": "select",
      "options": [
        { "label": "In alto", "value": "start" },
        { "label": "Centro", "value": "center" },
        { "label": "In basso", "value": "end" },
        { "label": "Esteso", "value": "stretch" }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "image_picker",
      "id": "block_image",
      "label": "Immagine"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Testo alternativo (ALT)",
      "info": "Se vuoto, viene usato l'ALT dell'immagine caricata su Shopify. Se anche quello è vuoto, viene generato dal nome del file."
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Link immagine",
      "info": "Lascia vuoto per nessun link."
    },
    {
      "type": "select",
      "id": "image_link_target",
      "label": "Apri link in",
      "options": [
        { "label": "Stessa finestra", "value": "_self" },
        { "label": "Nuova scheda", "value": "_blank" }
      ],
      "default": "_self"
    }
  ],
  "presets": [
    { "name": "Immagine" }
  ]
}
{% endschema %}
