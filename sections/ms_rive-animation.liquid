    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "16-9", "label": "16:9 (Widescreen)" },
        { "value": "4-3", "label": "4:3 (Standard)" },
        { "value": "1-1", "label": "1:1 (Square)" },
        { "value": "21-9", "label": "21:9 (Ultrawide)" },
        { "value": "9-16", "label": "9:16 (Vertical)" },
        { "value": "custom", "label": "Custom height" }
      ],
      "default": "16-9"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "Custom height",
      "min": 100,
      "max": 800,
      "step": 10,
      "default": 400,
      "unit": "px",
      "info": "Only used when 'Custom height' aspect ratio is selected"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "Rive File"
    },
    {
      "type": "url",
      "id": "rive_url",
      "label": "Rive file URL (.riv)",
      "info": "Upload a .riv file to Shopify Files (Content > Files) or use an external URL. Find free animations at [rive.app/marketplace](https://rive.app/marketplace)"
    },
    {
      "type": "text",
      "id": "state_machine",
      "label": "State Machine name",
      "info": "Leave empty to use the default State Machine or animation"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true,
      "info": "Animation will pause automatically if user prefers reduced motion"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop animation",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom JavaScript"
    },
    {
      "type": "liquid",
      "id": "custom_js",
      "label": "Custom JS code",
      "info": "Control the animation with JavaScript. The Rive instance is available as 'riveInstance'. [View documentation](https://rive.app/docs/runtimes/web/web-js)"
    },
    {
      "type": "header",
      "content": "Accessibilita"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Description for screen readers",
      "default": "Animated content",
      "info": "Describe the animation content for visually impaired users"
    }
  ],
  "blocks": [
