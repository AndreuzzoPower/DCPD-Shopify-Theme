{{ 'rive-animation.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.aspect_ratio == 'custom' and section.settings.custom_height > 0 -%}
    #RiveAnimation-{{ section.id }} .rive-animation__container {
      aspect-ratio: unset;
      height: {{ section.settings.custom_height | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      #RiveAnimation-{{ section.id }} .rive-animation__container {
        height: {{ section.settings.custom_height }}px;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign aspect_ratio_class = 'rive-animation__container--' | append: section.settings.aspect_ratio
  if section.settings.aspect_ratio == 'custom'
    assign aspect_ratio_class = ''
  endif

  assign aria_label = section.settings.aria_label | default: 'Animated content'
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="rive-animation-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <div class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</div>
      </div>
    {%- endunless -%}

    {%- if section.settings.rive_url != blank -%}
      <rive-animation
        id="RiveAnimation-{{ section.id }}"
        class="rive-animation{% if section.settings.full_width %} rive-animation--full-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        data-src="{{ section.settings.rive_url }}"
        data-state-machine="{{ section.settings.state_machine }}"
        data-autoplay="{{ section.settings.autoplay }}"
        data-loop="{{ section.settings.loop }}"
      >
        <div class="rive-animation__container {{ aspect_ratio_class }} global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}">
          <canvas
            id="rive-canvas-{{ section.id }}"
            class="rive-animation__canvas"
            role="img"
            aria-label="{{ aria_label | escape }}"
          ></canvas>
        </div>

        {%- if section.settings.custom_js != blank -%}
          <script data-rive-custom-js type="text/javascript">
            {{ section.settings.custom_js }}
          </script>
        {%- endif -%}
      </rive-animation>
    {%- else -%}
      <div class="rive-animation__container {{ aspect_ratio_class }} global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}">
        <div class="rive-animation__placeholder" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; min-height: 200px; background: rgba(var(--color-foreground), 0.04); border-radius: var(--media-radius);">
          <p style="color: rgba(var(--color-foreground), 0.5); text-align: center; padding: 2rem;">
            Insert a Rive file URL (.riv) to display the animation
          </p>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Rive Animation",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "Rive File"
    },
    {
      "type": "url",
      "id": "rive_url",
      "label": "Rive file URL (.riv)",
      "info": "Upload a .riv file to Shopify Files (Content > Files) or use an external URL. Find free animations at [rive.app/marketplace](https://rive.app/marketplace)"
    },
    {
      "type": "text",
      "id": "state_machine",
      "label": "State Machine name",
      "info": "Leave empty to use the default State Machine or animation"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true,
      "info": "Animation will pause automatically if user prefers reduced motion"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop animation",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom JavaScript"
    },
    {
      "type": "liquid",
      "id": "custom_js",
      "label": "Custom JS code",
      "info": "Control the animation with JavaScript. The Rive instance is available as 'riveInstance'. [View documentation](https://rive.app/docs/runtimes/web/web-js)"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Description for screen readers",
      "default": "Animated content",
      "info": "Describe the animation content for visually impaired users"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "16-9",
          "label": "16:9 (Widescreen)"
        },
        {
          "value": "4-3",
          "label": "4:3 (Standard)"
        },
        {
          "value": "1-1",
          "label": "1:1 (Square)"
        },
        {
          "value": "21-9",
          "label": "21:9 (Ultrawide)"
        },
        {
          "value": "9-16",
          "label": "9:16 (Vertical)"
        },
        {
          "value": "custom",
          "label": "Custom height"
        }
      ],
      "default": "16-9"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "Custom height",
      "min": 100,
      "max": 800,
      "step": 10,
      "default": 400,
      "unit": "px",
      "info": "Only used when 'Custom height' aspect ratio is selected"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.video.settings.full_width.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Rive Animation"
    }
  ]
}
{% endschema %}
