{{ 'ms_rive-animation.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default'
    assign sw = 'page_width'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign aspect_ratio_class = 'rive-animation__container--' | append: section.settings.aspect_ratio
  if section.settings.aspect_ratio == 'custom'
    assign aspect_ratio_class = ''
  endif

  assign aria_label = section.settings.aria_label | default: 'Contenuto animato'

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_classes = 'title inline-richtext ' | append: section.settings.heading_size
  if section.settings.heading_custom_class != blank
    assign heading_classes = heading_classes | append: ' ' | append: section.settings.heading_custom_class
  endif
-%}

{%- style -%}
  {%- if section.settings.max_width > 0 -%}
    #section-{{ section.id }} .rive-animation-wrapper {
      max-width: {{ section.settings.max_width }}px;
      margin-left: {% if section.settings.horizontal_align == 'left' %}0{% elsif section.settings.horizontal_align == 'right' %}auto{% else %}auto{% endif %};
      margin-right: {% if section.settings.horizontal_align == 'right' %}0{% elsif section.settings.horizontal_align == 'left' %}auto{% else %}auto{% endif %};
    }
  {%- endif -%}

  {%- if section.settings.aspect_ratio == 'custom' and section.settings.custom_height > 0 -%}
    #RiveAnimation-{{ section.id }} .rive-animation__container {
      aspect-ratio: unset;
      height: {{ section.settings.custom_height | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      #RiveAnimation-{{ section.id }} .rive-animation__container {
        height: {{ section.settings.custom_height }}px;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- render 'ms_mobile-padding' -%}

<div class="color-{{ section.settings.color_scheme }} gradient" id="section-{{ section.id }}">
  <div class="rive-animation-section isolate {{ sw_class }}">
    <div class="rive-animation-wrapper">
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <{{ heading_tag }} class="{{ heading_classes }}">{{ section.settings.heading }}</{{ heading_tag }}>
      </div>
    {%- endunless -%}

    {%- if section.settings.rive_url != blank -%}
      <rive-animation
        id="RiveAnimation-{{ section.id }}"
        class="rive-animation{% if sw == 'full_width' %} rive-animation--full-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        data-src="{{ section.settings.rive_url }}"
        data-state-machine="{{ section.settings.state_machine }}"
        data-autoplay="{{ section.settings.autoplay }}"
        data-loop="{{ section.settings.loop }}"
      >
        <div class="rive-animation__container {{ aspect_ratio_class }} global-media-settings{% if sw == 'full_width' %} global-media-settings--full-width{% endif %}">
          <canvas
            id="rive-canvas-{{ section.id }}"
            class="rive-animation__canvas"
            role="img"
            aria-label="{{ aria_label | escape }}"
          ></canvas>
        </div>

        {%- if section.settings.custom_js != blank -%}
          <script data-rive-custom-js type="text/javascript">
            {{ section.settings.custom_js }}
          </script>
        {%- endif -%}
      </rive-animation>
    {%- else -%}
      <div class="rive-animation__container {{ aspect_ratio_class }} global-media-settings{% if sw == 'full_width' %} global-media-settings--full-width{% endif %}">
        <div class="rive-animation__placeholder" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; min-height: 200px; background: rgba(var(--color-foreground), 0.04); border-radius: var(--media-radius);">
          <p style="color: rgba(var(--color-foreground), 0.5); text-align: center; padding: 2rem;">
            Inserisci un URL di file Rive (.riv) per visualizzare l'animazione
          </p>
        </div>
      </div>
    {%- endif -%}
    </div>
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Rive Animation",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colori",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Larghezza massima",
      "min": 0,
      "max": 1600,
      "step": 20,
      "default": 0,
      "unit": "px",
      "info": "0 = larghezza piena del contenitore. Riduci per 'ritagliare' attorno all'animazione."
    },
    {
      "type": "select",
      "id": "horizontal_align",
      "label": "Allineamento orizzontale",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Proporzioni",
      "options": [
        { "value": "16-9", "label": "16:9 (Widescreen)" },
        { "value": "4-3", "label": "4:3 (Standard)" },
        { "value": "1-1", "label": "1:1 (Quadrato)" },
        { "value": "21-9", "label": "21:9 (Ultrawide)" },
        { "value": "9-16", "label": "9:16 (Verticale)" },
        { "value": "custom", "label": "Altezza personalizzata" }
      ],
      "default": "16-9"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "Altezza personalizzata",
      "min": 100,
      "max": 800,
      "step": 10,
      "default": 400,
      "unit": "px",
      "info": "Utilizzato solo quando e selezionata 'Altezza personalizzata'"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Piccola" },
        { "value": "h1", "label": "Media" },
        { "value": "h0", "label": "Grande" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "Extra extra large" }
      ],
      "default": "h1",
      "label": "Dimensione titolo"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "heading_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "File Rive"
    },
    {
      "type": "url",
      "id": "rive_url",
      "label": "URL file Rive (.riv)",
      "info": "Carica un file .riv su Shopify Files (Contenuti > File) o usa un URL esterno. Trova animazioni gratuite su [rive.app/marketplace](https://rive.app/marketplace)"
    },
    {
      "type": "text",
      "id": "state_machine",
      "label": "Nome State Machine",
      "info": "Lascia vuoto: la prima State Machine disponibile nel file verra usata automaticamente. Compila solo se il file ne contiene piu di una e vuoi sceglierne una specifica."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Riproduzione automatica",
      "default": true,
      "info": "L'animazione si mettera in pausa automaticamente se l'utente preferisce movimento ridotto"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Ripeti animazione",
      "default": true
    },
    {
      "type": "header",
      "content": "JavaScript personalizzato"
    },
    {
      "type": "liquid",
      "id": "custom_js",
      "label": "Codice JS personalizzato",
      "info": "Controlla l'animazione con JavaScript. L'istanza Rive e disponibile come 'riveInstance'. [Vedi documentazione](https://rive.app/docs/runtimes/web/web-js)"
    },
    {
      "type": "header",
      "content": "Accessibilita"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Descrizione per screen reader",
      "default": "Contenuto animato",
      "info": "Descrivi il contenuto dell'animazione per utenti con disabilita visive"
    }
  ],
  "blocks": [
    {
      "type": "section_padding",
      "name": "Padding sezione",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Desktop"
        },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding superiore",
          "unit": "px",
          "default": 35
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding inferiore",
          "unit": "px",
          "default": 35
        },
        {
          "type": "header",
          "content": "Tablet"
        },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding superiore",
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding inferiore",
          "unit": "px",
          "default": 30
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "range",
          "id": "section_padding_top_xs",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding superiore",
          "unit": "px",
          "default": 20
        },
        {
          "type": "range",
          "id": "section_padding_bottom_xs",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding inferiore",
          "unit": "px",
          "default": 20
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Margine sezione",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Desktop"
        },
        {
          "type": "range",
          "id": "section_margin_top",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine superiore",
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine inferiore",
          "unit": "px",
          "default": 0
        },
        {
          "type": "header",
          "content": "Tablet"
        },
        {
          "type": "range",
          "id": "section_margin_top_md",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine superiore",
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_md",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine inferiore",
          "unit": "px",
          "default": 0
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "range",
          "id": "section_margin_top_xs",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine superiore",
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_xs",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Margine inferiore",
          "unit": "px",
          "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Sfondo sezione",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "Immagine di sfondo"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "Colore di sfondo",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Rive Animation",
      "category": "Media",
      "blocks": [
        {
          "type": "section_padding"
        }
      ]
    }
  ]
}
{% endschema %}
