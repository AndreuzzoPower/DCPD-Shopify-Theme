{%- comment -%}
  MS Related Products
  ═══════════════════════════════════════════════════════════════
  Prodotti correlati (Shopify Recommendations API).
  Supporta slider desktop/mobile, quick add, personalizzazione carosello.
  Blocchi ms_section-style per padding, margin e background.
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- if section.settings.image_shape == 'blob' -%}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign is_full_width = false
  if sw == 'full_width'
    assign is_full_width = true
  endif

  assign peek = section.settings.carousel_peek_size | default: 'medium'

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign products_to_show = section.settings.products_to_show

  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and recommendations.products_count > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and recommendations.products_count > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif
-%}

{%- unless is_full_width -%}
  {%- if show_desktop_slider -%}
    {% style %}
      @media screen and (min-width: 990px) {
        #section-{{ section.id }} .slider.slider--desktop {
          margin-left: 0;
          scroll-padding-left: 0;
        }
        {%- if peek == 'none' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: 100%; }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(25% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(20% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(16.66% - var(--grid-desktop-horizontal-spacing) * 5 / 6); }
        {%- elsif peek == 'small' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(75% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(42.857% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(30% - var(--grid-desktop-horizontal-spacing) * 9 / 10); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(23.077% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.75% - var(--grid-desktop-horizontal-spacing) * 15 / 16); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.789% - var(--grid-desktop-horizontal-spacing) * 18 / 19); }
        {%- elsif peek == 'large' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(57.143% - var(--grid-desktop-horizontal-spacing) * 4 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(36.364% - var(--grid-desktop-horizontal-spacing) * 8 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(26.667% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(21.053% - var(--grid-desktop-horizontal-spacing) * 16 / 19); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(17.391% - var(--grid-desktop-horizontal-spacing) * 20 / 23); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(14.815% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        {%- else -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(66.667% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(40% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(28.571% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(22.222% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.182% - var(--grid-desktop-horizontal-spacing) * 10 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.385% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        {%- endif -%}
      }
    {% endstyle %}
  {%- endif -%}
{%- endunless -%}

<div class="color-{{ section.settings.color_scheme }} gradient" id="section-{{ section.id }}">
  <product-recommendations
    class="related-products{% if sw_class != blank %} {{ sw_class }}{% endif %} isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    data-url="{{ routes.product_recommendations_url }}?limit={{ products_to_show }}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
  >
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      {%- if section.settings.heading != blank -%}
        {%- assign t_tag = section.settings.title_tag | default: 'h2' -%}
        <{{ t_tag }} class="related-products__heading {{ section.settings.heading_size }}{% if section.settings.title_custom_class != blank %} {{ section.settings.title_custom_class }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{- section.settings.heading | escape -}}
        </{{ t_tag }}>
      {%- endif -%}

      {%- if sw_class != blank and show_desktop_slider -%}<div class="{{ sw_class }}">{%- endif -%}
      <slider-component
        data-autoplay="{{ section.settings.enable_desktop_slider_autoplay }}"
        data-speed="{{ section.settings.desktop_slider_autoplay_velocita }}000"
        data-scroll-mode="{{ section.settings.carousel_scroll_mode | default: 'page' }}"
        data-loop="{{ section.settings.carousel_loop | default: false }}"
        data-peek="{{ section.settings.carousel_peek_size | default: 'medium' }}"
        class="slider-mobile-gutter{% if is_full_width %} slider-component-full-width{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if section.settings.carousel_arrows_position == 'overlay_sides' %} ms-carousel--arrows-overlay-sides{% elsif section.settings.carousel_arrows_position == 'above_right' %} ms-carousel--arrows-above-right{% endif %}{% if section.settings.carousel_arrows_overlay_dark %} ms-carousel--arrows-overlay-dark{% endif %}{% unless section.settings.carousel_show_arrows == nil %}{% unless section.settings.carousel_show_arrows %} ms-carousel--no-arrows{% endunless %}{% endunless %}{% unless section.settings.carousel_show_pagination == nil %}{% unless section.settings.carousel_show_pagination %} ms-carousel--no-pagination{% endunless %}{% endunless %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% unless is_full_width %}style="--desktop-margin-left-first-item: 0px"{% endunless %}
      >
        <ul
          id="Slider-{{ section.id }}"
          class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
          role="list"
          aria-label="{{ section.settings.heading | default: 'Prodotti correlati' | escape }}"
        >
          {%- assign skip_card_product_styles = false -%}
          {%- for recommendation in recommendations.products -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- render 'card-product',
                card_product: recommendation,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                show_min_order: section.settings.show_min_order,
                skip_styles: skip_card_product_styles,
                section_id: section.id
              -%}
            </li>
            {%- assign skip_card_product_styles = true -%}
          {%- endfor -%}
        </ul>

        {%- if show_mobile_slider or show_desktop_slider -%}
          {%- render 'ms_carousel-controls',
            section_id: section.id,
            total_items: recommendations.products_count,
            pagination_style: section.settings.carousel_pagination_style,
            show_arrows: section.settings.carousel_show_arrows,
            show_pagination: section.settings.carousel_show_pagination,
            enable_autoplay: section.settings.enable_desktop_slider_autoplay
          -%}
        {%- endif -%}
      </slider-component>
      {%- if sw_class != blank and show_desktop_slider -%}</div>{%- endif -%}
    {%- endif -%}
  </product-recommendations>

  {%- if section.settings.image_shape == 'arch' -%}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Related Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.related-products.settings.paragraph__1.content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Prodotti correlati",
      "label": "t:sections.related-products.settings.heading.label"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "t:sections.related-products.settings.products_to_show.label"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.related-products.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.related-products.settings.image_ratio.options__2.label" },
        { "value": "square", "label": "t:sections.related-products.settings.image_ratio.options__3.label" }
      ],
      "default": "adapt",
      "label": "t:sections.related-products.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        { "value": "default", "label": "t:sections.all.image_shape.options__1.label" },
        { "value": "arch", "label": "t:sections.all.image_shape.options__2.label" },
        { "value": "blob", "label": "t:sections.all.image_shape.options__3.label" },
        { "value": "chevronleft", "label": "t:sections.all.image_shape.options__4.label" },
        { "value": "chevronright", "label": "t:sections.all.image_shape.options__5.label" },
        { "value": "diamond", "label": "t:sections.all.image_shape.options__6.label" },
        { "value": "parallelogram", "label": "t:sections.all.image_shape.options__7.label" },
        { "value": "round", "label": "t:sections.all.image_shape.options__8.label" }
      ],
      "default": "default",
      "label": "t:sections.all.image_shape.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.related-products.settings.show_secondary_image.label"
    },
    {
      "type": "header",
      "content": "Carosello"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.related-products.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Abilita carosello desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider_autoplay",
      "label": "Abilita autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_slider_autoplay_velocita",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Tempo transizione (sec.)"
    },
    {
      "type": "select",
      "id": "carousel_arrows_position",
      "label": "Posizionamento frecce",
      "default": "below_center",
      "options": [
        { "value": "below_center", "label": "Sotto (centrato)" },
        { "value": "overlay_sides", "label": "Ai lati (sovrapposto)" },
        { "value": "above_right", "label": "Sopra a destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_arrows_overlay_dark",
      "label": "Frecce overlay in tema scuro",
      "default": false,
      "info": "Attivo solo con posizionamento 'Ai lati (sovrapposto)'"
    },
    {
      "type": "select",
      "id": "carousel_pagination_style",
      "label": "Stile paginazione",
      "default": "counter",
      "options": [
        { "value": "counter", "label": "Contatore (1 / 5)" },
        { "value": "dots", "label": "Pallini" },
        { "value": "numbers", "label": "Numeri" },
        { "value": "none", "label": "Nessuna" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_scroll_mode",
      "label": "Modalita scorrimento",
      "default": "page",
      "options": [
        { "value": "page", "label": "Pagina (set di elementi)" },
        { "value": "single", "label": "Singolo elemento" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_loop",
      "label": "Tipo loop",
      "default": "none",
      "options": [
        { "value": "none",     "label": "Nessuno" },
        { "value": "rewind",   "label": "Rewind (torna all'inizio)" },
        { "value": "circular", "label": "Circolare (infinito)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_show_arrows",
      "label": "Mostra frecce",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel_show_pagination",
      "label": "Mostra paginazione",
      "default": true
    },
    {
      "type": "select",
      "id": "carousel_peek_size",
      "label": "Anteprima prossimo elemento",
      "default": "medium",
      "options": [
        { "value": "none", "label": "Nessuna" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ]
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.related-products.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "t:sections.related-products.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.related-products.settings.columns_mobile.options__2.label" }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Abilita carosello mobile"
    },
    {
      "type": "header",
      "content": "Scheda prodotto"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.related-products.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.related-products.settings.show_rating.label",
      "info": "t:sections.related-products.settings.show_rating.info"
    },
    {
      "type": "checkbox",
      "id": "show_min_order",
      "default": true,
      "label": "Mostra quantita minima",
      "info": "Se attivo, mostra il label della quantita minima d'ordine sulla scheda prodotto (dove impostato)."
    }
  ],
  "blocks": [
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        { "type": "range", "id": "section_padding_top", "min": 0, "max": 150, "step": 5, "label": "Padding Top", "unit": "px", "default": 36 },
        { "type": "range", "id": "section_padding_bottom", "min": 0, "max": 150, "step": 5, "label": "Padding Bottom", "unit": "px", "default": 36 },
        { "type": "header", "content": "Tablet Device" },
        { "type": "range", "id": "section_padding_top_md", "min": 0, "max": 150, "step": 5, "label": "Padding Top", "unit": "px", "default": 36 },
        { "type": "range", "id": "section_padding_bottom_md", "min": 0, "max": 150, "step": 5, "label": "Padding Bottom", "unit": "px", "default": 36 },
        { "type": "header", "content": "Mobile Device" },
        { "type": "range", "id": "section_padding_top_xs", "min": 0, "max": 150, "step": 5, "label": "Padding Top", "unit": "px", "default": 36 },
        { "type": "range", "id": "section_padding_bottom_xs", "min": 0, "max": 150, "step": 5, "label": "Padding Bottom", "unit": "px", "default": 36 }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        { "type": "range", "id": "section_margin_top", "min": 0, "max": 150, "step": 5, "label": "Margin Top", "unit": "px", "default": 0 },
        { "type": "range", "id": "section_margin_bottom", "min": 0, "max": 150, "step": 5, "label": "Margin Bottom", "unit": "px", "default": 0 },
        { "type": "header", "content": "Tablet Device" },
        { "type": "range", "id": "section_margin_top_md", "min": 0, "max": 150, "step": 5, "label": "Margin Top", "unit": "px", "default": 0 },
        { "type": "range", "id": "section_margin_bottom_md", "min": 0, "max": 150, "step": 5, "label": "Margin Bottom", "unit": "px", "default": 0 },
        { "type": "header", "content": "Mobile Device" },
        { "type": "range", "id": "section_margin_top_xs", "min": 0, "max": 150, "step": 5, "label": "Margin Top", "unit": "px", "default": 0 },
        { "type": "range", "id": "section_margin_bottom_xs", "min": 0, "max": 150, "step": 5, "label": "Margin Bottom", "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "section_bg_image", "label": "BG Image" },
        { "type": "color", "id": "section_bg_color", "label": "BG Color", "default": "#ffffff" }
      ]
    }
  ]
}
{% endschema %}
