{%- comment -%}
  Section: MS Wishlist
  Pagina wishlist che mostra i prodotti salvati dall'utente tramite localStorage.
  I prodotti vengono caricati client-side dal custom element <wishlist-page>.
  Le card sono renderizzate server-side via alternate template (product.ms-wishlist-card)
  per garantire parità visiva con le card della collection grid.
{%- endcomment -%}

{{ 'ms_wishlist.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif

  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase
-%}

{%- render 'ms_mobile-padding', section: section -%}

{%- style -%}
  {%- if section.settings.image_ratio == 'square' -%}
    #section-{{ section.id }} .ms-wishlist-grid .card__inner.ratio,
    #section-{{ section.id }} .ms-wishlist-grid .card.card--media {
      --ratio-percent: 100% !important;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card__media .media {
      padding-bottom: 0 !important;
      aspect-ratio: 1 / 1 !important;
      overflow: hidden;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card__media .media img {
      position: absolute;
      top: 0;
      left: 0;
      object-fit: cover;
      width: 100%;
      height: 100%;
    }
  {%- elsif section.settings.image_ratio == 'portrait' -%}
    #section-{{ section.id }} .ms-wishlist-grid .card__inner.ratio,
    #section-{{ section.id }} .ms-wishlist-grid .card.card--media {
      --ratio-percent: 125% !important;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card__media .media {
      padding-bottom: 0 !important;
      aspect-ratio: 4 / 5 !important;
      overflow: hidden;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card__media .media img {
      position: absolute;
      top: 0;
      left: 0;
      object-fit: cover;
      width: 100%;
      height: 100%;
    }
  {%- endif -%}

  {%- if section.settings.equal_height -%}
    #section-{{ section.id }} .ms-wishlist-grid {
      align-items: stretch;
    }
    #section-{{ section.id }} .ms-wishlist-grid .grid__item > div {
      height: 100%;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card-wrapper {
      height: 100%;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card {
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    #section-{{ section.id }} .ms-wishlist-grid .card__content:last-child {
      flex: 1;
    }
  {%- endif -%}
{%- endstyle -%}

<div id="section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="{{ sw_class }}">
    <wishlist-page
      data-label-singular="1 prodotto salvato"
      data-label-plural="{count} prodotti salvati"
      data-remove-label="Rimuovi dalla wishlist"
      data-confirm-clear="Rimuovere tutti i prodotti dalla wishlist?"
      data-columns-desktop="{{ section.settings.columns_desktop }}"
      data-columns-mobile="{{ section.settings.columns_mobile }}"
      data-image-ratio="{{ section.settings.image_ratio }}"
      data-equal-height="{{ section.settings.equal_height }}"
      data-show-secondary-image="{{ section.settings.show_secondary_image }}"
      data-show-vendor="{{ section.settings.show_vendor }}"
      data-show-rating="{{ section.settings.show_rating }}"
      data-show-min-order="{{ section.settings.show_min_order }}"
      data-quick-add="{{ section.settings.quick_add }}"
      data-section-id="{{ section.id }}"
    >
      <div class="ms-wishlist-header" style="display:none;">
        <span class="ms-wishlist-header__count" role="status" aria-live="polite"></span>
        {%- capture clear_btn_classes -%}
          {%- render 'ms_button_classes',
            type: section.settings.clear_button_type,
            secondary: section.settings.clear_button_style_secondary,
            size: section.settings.clear_button_size
          -%}
        {%- endcapture -%}
        <button type="button" class="ms-wishlist-clear-btn {{ clear_btn_classes | strip }}{% if section.settings.clear_button_custom_class != blank %} {{ section.settings.clear_button_custom_class }}{% endif %}">
          {%- render 'ms_button_icon', icon: section.settings.clear_button_icon, position: section.settings.clear_button_icon_position, slot: 'before' -%}
          {{ section.settings.clear_label | default: 'Svuota wishlist' }}
          {%- render 'ms_button_icon', icon: section.settings.clear_button_icon, position: section.settings.clear_button_icon_position, slot: 'after' -%}
        </button>
      </div>

      <ul
        class="ms-wishlist-grid grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
        style="display:none;"
      ></ul>

      <div class="ms-wishlist-empty">
        <div class="ms-wishlist-empty__icon" aria-hidden="true">
          {%- render 'ms_icon', icon: settings.ms_icon_heart -%}
        </div>
        <div class="ms-wishlist-empty__title h2">
          {{ section.settings.empty_title | default: 'La tua wishlist e vuota' }}
        </div>
        <p class="ms-wishlist-empty__text">
          {{ section.settings.empty_text | default: 'Sfoglia i nostri prodotti e salva i tuoi preferiti cliccando sul cuore.' }}
        </p>
        {%- if section.settings.empty_button_label != blank and section.settings.empty_button_link != blank -%}
          <a
            href="{{ section.settings.empty_button_link }}"
            class="{%- render 'ms_button_classes', type: section.settings.empty_button_type, secondary: section.settings.empty_button_style_secondary, size: section.settings.empty_button_size -%}"
          >
            {%- render 'ms_button_icon', icon: section.settings.empty_button_icon, position: section.settings.empty_button_icon_position, slot: 'before' -%}
            {{ section.settings.empty_button_label | escape }}
            {%- render 'ms_button_icon', icon: section.settings.empty_button_icon, position: section.settings.empty_button_icon_position, slot: 'after' -%}
          </a>
        {%- endif -%}
      </div>
    </wishlist-page>
  </div>
</div>

{%- render 'ms_section-style', section: section -%}

{% schema %}
{
  "name": "MS Wishlist",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione di colori",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Griglia"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Colonne desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Colonne mobile",
      "options": [
        { "value": "1", "label": "1 colonna" },
        { "value": "2", "label": "2 colonne" }
      ]
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adatta all'immagine" },
        { "value": "portrait", "label": "Ritratto" },
        { "value": "square", "label": "Quadrato" }
      ],
      "default": "adapt",
      "label": "Proporzione immagine"
    },
    {
      "type": "checkbox",
      "id": "equal_height",
      "default": false,
      "label": "Altezza uguale per riga",
      "info": "Se attivo, tutte le schede sulla stessa riga avranno la stessa altezza."
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Mostra immagine secondaria al hover"
    },
    {
      "type": "header",
      "content": "Scheda prodotto"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Mostra brand/vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Mostra valutazione",
      "info": "Per mostrare una valutazione, aggiungi un'app per le recensioni dei prodotti."
    },
    {
      "type": "checkbox",
      "id": "show_min_order",
      "default": true,
      "label": "Mostra quantita minima",
      "info": "Se attivo, mostra il label della quantita minima d'ordine sulla scheda prodotto (dove impostato)."
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "none",
      "label": "Pulsante acquisto rapido",
      "options": [
        { "value": "none", "label": "Nessuno" },
        { "value": "standard", "label": "Pulsante acquisto rapido" }
      ]
    },
    {
      "type": "header",
      "content": "Pulsante Svuota wishlist"
    },
    {
      "type": "text",
      "id": "clear_label",
      "label": "Testo pulsante",
      "default": "Svuota wishlist"
    },
    {
      "type": "select",
      "id": "clear_button_type",
      "label": "Tipo pulsante",
      "default": "button",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill", "label": "Pill (arrotondato)" },
        { "value": "link", "label": "Solo link" }
      ]
    },
    {
      "type": "checkbox",
      "id": "clear_button_style_secondary",
      "label": "Stile contorno",
