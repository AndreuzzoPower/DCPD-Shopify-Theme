{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0

  assign column_count = 0
  for block in section.blocks
    if block.type == 'column'
      assign column_count = column_count | plus: 1
    endif
  endfor

  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and column_count > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and column_count > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif

  assign show_carousel = false
  if show_mobile_slider or show_desktop_slider
    assign show_carousel = true
  endif

  assign is_full_width = false
  if sw == 'full_width'
    assign is_full_width = true
  endif

  assign peek = section.settings.carousel_peek_size | default: 'medium'
-%}

{%- render 'ms_mobile-padding' -%}

{%- unless is_full_width -%}
  {%- if show_desktop_slider -%}
    {% style %}
      @media screen and (min-width: 990px) {
        #section-{{ section.id }} .slider.slider--desktop {
          margin-left: 0;
          scroll-padding-left: 0;
        }
        {%- if peek == 'none' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: 100%; }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(25% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(20% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(16.66% - var(--grid-desktop-horizontal-spacing) * 5 / 6); }
        {%- elsif peek == 'small' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(75% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(42.857% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(30% - var(--grid-desktop-horizontal-spacing) * 9 / 10); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(23.077% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.75% - var(--grid-desktop-horizontal-spacing) * 15 / 16); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.789% - var(--grid-desktop-horizontal-spacing) * 18 / 19); }
        {%- elsif peek == 'large' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(57.143% - var(--grid-desktop-horizontal-spacing) * 4 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(36.364% - var(--grid-desktop-horizontal-spacing) * 8 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(26.667% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(21.053% - var(--grid-desktop-horizontal-spacing) * 16 / 19); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(17.391% - var(--grid-desktop-horizontal-spacing) * 20 / 23); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(14.815% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        {%- else -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(66.667% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(40% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(28.571% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(22.222% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.182% - var(--grid-desktop-horizontal-spacing) * 10 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.385% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        {%- endif -%}
      }
    {% endstyle %}
  {%- endif -%}
{%- endunless -%}

<div
  class="multicolumn ms_multicolumn color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow != 'none' %} background-{{ section.settings.background_style }}{% endunless %}"
  id="section-{{ section.id }}"
>
  <div
    class="{{ sw_class }} isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <slider-component
      data-scroll-mode="{{ section.settings.carousel_scroll_mode | default: 'page' }}"
      data-loop="{{ section.settings.carousel_loop | default: 'circular' }}"
      data-peek="{{ section.settings.carousel_peek_size | default: 'medium' }}"
      data-autoplay="{{ section.settings.enable_autoplay | default: false }}"
      data-speed="{{ section.settings.autoplay_speed | default: 5 }}000"
      class="slider-mobile-gutter{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if section.settings.carousel_arrows_position == 'overlay_sides' %} ms-carousel--arrows-overlay-sides{% elsif section.settings.carousel_arrows_position == 'above_right' %} ms-carousel--arrows-above-right{% endif %}{% if section.settings.carousel_arrows_overlay_dark %} ms-carousel--arrows-overlay-dark{% endif %}{% unless section.settings.carousel_show_arrows %} ms-carousel--no-arrows{% endunless %}{% unless section.settings.carousel_show_pagination %} ms-carousel--no-pagination{% endunless %}"
      {% unless is_full_width %}style="--desktop-margin-left-first-item: 0px"{% endunless %}
    >
      <ul
        class="multicolumn-list contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            {%- assign empty_column = '' -%}
            {%- if block.settings.image == blank
              and block.settings.title == blank
              and block.settings.text == blank
              and block.settings.link_label == blank
            -%}
              {%- assign empty_column = ' multicolumn-list__item--empty' -%}
            {%- endif -%}

            {%- liquid
              assign title_tag = block.settings.title_tag | default: 'h3'
              assign title_classes = 'inline-richtext'
              if block.settings.title_custom_class != blank
                assign title_classes = title_classes | append: ' ' | append: block.settings.title_custom_class
              endif

              assign col_link_type = block.settings.link_button_type | default: 'link'
              assign col_link_icon = block.settings.link_button_icon
              if col_link_icon == blank and col_link_type == 'link'
                assign col_link_icon = settings.ms_icon_arrow
              endif
            -%}

            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="multicolumn-list__item grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              <div class="multicolumn-card content-container">
                {%- if block.settings.image != blank -%}
                  {%- if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' -%}
                    {%- assign spaced_image = true -%}
                  {%- endif -%}
                  <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} multicolumn-card-spacing{% endif %}">
                    <div
                      class="media media--transparent media--{{ section.settings.image_ratio }}"
                      {% if section.settings.image_ratio == 'adapt' %}
                        style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                      {% endif %}
                    >
                      {%- liquid
                        assign number_of_columns = section.settings.columns_desktop
                        assign number_of_columns_mobile = section.settings.columns_mobile
                        assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                        assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                        assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                        if section.settings.image_width == 'half'
                          assign image_width = 0.5
                        elsif section.settings.image_width == 'third'
                          assign image_width = 0.33
                        else
                          assign image_width = 1
                        endif
                      -%}
                      {%- capture sizes -%}
                        (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                        (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                        (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                        calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                      {%- endcapture -%}
                      {{
                        block.settings.image
                        | image_url: width: 3200
                        | image_tag:
                          widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                          sizes: sizes,
                          class: 'multicolumn-card__image',
                          alt: block.settings.image.alt | escape
                      }}
                    </div>
                  </div>
                {%- endif -%}

                <div class="multicolumn-card__info">
                  {%- if block.settings.title != blank -%}
                    <{{ title_tag }} class="{{ title_classes }}">{{ block.settings.title }}</{{ title_tag }}>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="rte">{{ block.settings.text }}</div>
                  {%- endif -%}
                  {%- if block.settings.link_label != blank -%}
                    <a
                      class="{% if col_link_type == 'link' %}link animate-arrow{% else %}{%- render 'ms_button_classes', type: col_link_type, secondary: block.settings.link_button_style_secondary, size: block.settings.link_button_size -%}{% endif %}"
                      {% if block.settings.link == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ block.settings.link }}"
                      {% endif %}
                    >
                      {%- render 'ms_button_icon', icon: col_link_icon, position: block.settings.link_button_icon_position, slot: 'before' -%}
                      {{- block.settings.link_label | escape -}}
                      {%- render 'ms_button_icon', icon: col_link_icon, position: block.settings.link_button_icon_position, slot: 'after' -%}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if show_carousel -%}
        {%- render 'ms_carousel-controls',
          section_id: section.id,
          total_items: section.blocks.size,
          pagination_style: section.settings.carousel_pagination_style,
          show_arrows: section.settings.carousel_show_arrows,
          show_pagination: section.settings.carousel_show_pagination,
          enable_autoplay: section.settings.enable_autoplay
        -%}
      {%- endif -%}
    </slider-component>

    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="{%- render 'ms_button_classes', type: section.settings.button_type, secondary: section.settings.button_style_secondary, size: section.settings.button_size -%}"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'before' -%}
          {{ section.settings.button_label | escape }}
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'after' -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Multicolonna",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.multicolumn.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.multicolumn.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.multicolumn.settings.column_alignment.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.multicolumn.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.multicolumn.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.multicolumn.settings.background_style.label"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_ratio.options__3.label"
        },
        {
          "value": "circle",
          "label": "t:sections.multicolumn.settings.image_ratio.options__4.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.multicolumn.settings.image_ratio.label"
    },
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.multicolumn.settings.button_label.default",
      "label": "t:sections.multicolumn.settings.button_label.label",
      "info": "t:sections.multicolumn.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.multicolumn.settings.button_link.label"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "default": false,
      "label": "Stile contorno",
      "info": "Se attivo, il pulsante ha bordo visibile e sfondo trasparente."
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Tipo pulsante",
      "default": "button",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill", "label": "Pill (arrotondato)" },
        { "value": "link", "label": "Solo link" }
      ]
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Dimensione pulsante",
      "info": "\"Predefinita\" usa il valore globale da Impostazioni tema → Pulsanti.",
      "default": "default",
      "options": [
        { "value": "default", "label": "Predefinita" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "jumbo", "label": "Jumbo" },
        { "value": "extra_jumbo", "label": "Extra Jumbo" }
      ]
    },
    {
      "type": "text",
      "id": "button_icon",
      "label": "Icona pulsante",
      "info": "Nome file SVG (es. icon-arrow.svg) o classe icone (es. fa-solid fa-arrow-right). Vuoto = nessuna icona."
    },
    {
      "type": "select",
      "id": "button_icon_position",
      "label": "Posizione icona",
      "default": "before",
      "options": [
        { "value": "before", "label": "Prima del testo" },
        { "value": "after", "label": "Dopo il testo" }
      ]
    },
    {
      "type": "header",
      "content": "Carosello"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.multicolumn.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Abilita carosello desktop",
      "default": false,
      "info": "Attiva lo slider orizzontale anche su desktop."
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Rotazione automatica",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Velocità rotazione (secondi)",
      "default": 5
    },
    {
      "type": "select",
      "id": "carousel_loop",
      "label": "Tipo loop",
      "default": "circular",
      "options": [
        { "value": "none",     "label": "Nessuno (si ferma alla fine)" },
        { "value": "rewind",   "label": "Rewind (torna all'inizio)" },
        { "value": "circular", "label": "Circolare (infinito)" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_peek_size",
      "label": "Anteprima prossimo elemento",
      "default": "medium",
      "options": [
        { "value": "none", "label": "Nessuna" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_arrows_position",
      "label": "Posizionamento frecce",
      "default": "below_center",
      "options": [
        { "value": "below_center", "label": "Sotto (centrato)" },
        { "value": "overlay_sides", "label": "Ai lati (sovrapposto)" },
        { "value": "above_right", "label": "Sopra a destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_arrows_overlay_dark",
      "label": "Frecce overlay in tema scuro",
      "default": false,
      "info": "Attivo solo con posizionamento 'Ai lati (sovrapposto)'"
    },
    {
      "type": "select",
      "id": "carousel_pagination_style",
      "label": "Stile paginazione",
      "default": "counter",
      "options": [
        { "value": "counter", "label": "Contatore (1 / 5)" },
        { "value": "dots", "label": "Pallini" },
        { "value": "numbers", "label": "Numeri" },
        { "value": "none", "label": "Nessuna" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_scroll_mode",
      "label": "Modalita scorrimento",
      "default": "page",
      "options": [
        { "value": "page", "label": "Pagina (set di elementi)" },
        { "value": "single", "label": "Singolo elemento" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_show_arrows",
      "label": "Mostra frecce",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel_show_pagination",
      "label": "Mostra paginazione",
      "default": true
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.multicolumn.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
