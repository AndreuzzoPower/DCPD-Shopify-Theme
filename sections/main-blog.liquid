{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Blog header */
  .main-blog__header {
    margin-bottom: 3rem;
    {% if section.settings.title_alignment == 'center' %}
      text-align: center;
    {% elsif section.settings.title_alignment == 'right' %}
      text-align: right;
    {% endif %}
  }
  .main-blog__description {
    margin-top: 1rem;
    max-width: 72rem;
    color: rgba(var(--color-foreground), 0.7);
    line-height: 1.6;
    {% if section.settings.title_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif section.settings.title_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  /* Tag cloud */
  .main-blog__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
    {% if section.settings.title_alignment == 'center' %}
      justify-content: center;
    {% elsif section.settings.title_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }
  .main-blog__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 2rem;
    font-size: 1.3rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }
  .main-blog__tag:hover,
  .main-blog__tag--active {
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border-color: rgb(var(--color-foreground));
  }

  /* Colonne griglia: grid + editorial */
  {% if section.settings.layout == 'grid' or section.settings.layout == 'editorial' %}
    .section-{{ section.id }}-padding .blog-articles--grid,
    .section-{{ section.id }}-padding .blog-articles--editorial {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding .blog-articles--grid,
      .section-{{ section.id }}-padding .blog-articles--editorial {
        grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      }
    }
  {% endif %}

  /* Colonne griglia: collage */
  {% if section.settings.layout == 'collage' %}
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding .blog-articles--collage {
        grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      }
    }
  {% endif %}

  /* Colonne mobile: mosaico */
  {% if section.settings.layout == 'mosaic' %}
    .section-{{ section.id }}-padding .blog-articles--mosaic {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
  {% endif %}

  /* Lista: rapporto immagine */
  {% if section.settings.layout == 'list' %}
    .section-{{ section.id }}-padding .blog-articles--list {
      {% case section.settings.list_image_ratio %}
        {% when '30_70' %}
          --blog-list-image-ratio: 30%;
        {% when '40_60' %}
          --blog-list-image-ratio: 40%;
        {% when '60_40' %}
          --blog-list-image-ratio: 60%;
        {% else %}
          --blog-list-image-ratio: 50%;
      {% endcase %}
    }
  {% endif %}

  /* Overlay */
  {% if section.settings.enable_overlay %}
    {%- assign overlay_color = section.settings.overlay_bg_color | default: '#000000' -%}
    {%- assign overlay_r = overlay_color | color_extract: 'red' -%}
    {%- assign overlay_g = overlay_color | color_extract: 'green' -%}
    {%- assign overlay_b = overlay_color | color_extract: 'blue' -%}
    .section-{{ section.id }}-padding .article-card--overlay {
      --overlay-bg-rgb: {{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }};
      --overlay-bg-opacity: {{ section.settings.overlay_bg_opacity | divided_by: 100.0 }};
      --overlay-text-color: {{ section.settings.overlay_text_color }};
      {% case section.settings.overlay_position %}
        {% when 'top' %}
          --overlay-justify: flex-start;
        {% when 'center' %}
          --overlay-justify: center;
        {% else %}
          --overlay-justify: flex-end;
      {% endcase %}
    }
  {% endif %}

  /* Stile card: bordi e ombra */
  .section-{{ section.id }}-padding .article-card-wrapper {
    {% if settings.blog_card_border_thickness > 0 %}
      border: {{ settings.blog_card_border_thickness }}px solid {{ settings.blog_card_border_color }};
    {% endif %}
    {% if settings.blog_card_corner_radius > 0 %}
      border-radius: {{ settings.blog_card_corner_radius }}px;
    {% endif %}
    {% if settings.blog_card_shadow == 'light' %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% elsif settings.blog_card_shadow == 'medium' %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    {% elsif settings.blog_card_shadow == 'strong' %}
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
    {% endif %}
    overflow: hidden;
  }

  /* Stile card: padding info */
  .section-{{ section.id }}-padding .card__information {
    padding-top: {{ section.settings.card_info_padding_top }}px !important;
    padding-right: {{ section.settings.card_info_padding_right }}px !important;
    padding-bottom: {{ section.settings.card_info_padding_bottom }}px !important;
    padding-left: {{ section.settings.card_info_padding_left }}px !important;
  }

  /* Overlay: override padding info */
  .section-{{ section.id }}-padding .article-card--overlay .card__information {
    padding: 0 !important;
  }

  /* Estratto: rimuovi margin-bottom */
  .section-{{ section.id }}-padding .article-card__excerpt {
    margin-bottom: 0;
  }

  /* Info verticale */
  {% if section.settings.info_layout == 'vertical' %}
    .section-{{ section.id }}-padding .article-card__info {
      display: flex !important;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
    .section-{{ section.id }}-padding .article-card__info .circle-divider::after {
      display: none;
    }
  {% endif %}
{%- endstyle -%}

{%- paginate blog.articles by section.settings.articles_per_page -%}
  {%- if section.settings.enable_infinite_scroll -%}
    <script src="{{ 'ms_infinite-scroll.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  <div
    class="main-blog page-width section-{{ section.id }}-padding"
    {% if section.settings.enable_infinite_scroll %}
      data-infinite-scroll
      data-infinite-grid=".blog-articles"
      data-infinite-item=".blog-articles__article"
    {% endif %}
  >

    {%- comment -%} Header: titolo + descrizione {%- endcomment -%}
    {%- if section.settings.show_title or section.settings.description != blank or section.settings.show_tag_cloud -%}
      <div class="main-blog__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- if section.settings.show_title -%}
          <h1 class="title--primary">
            {{ blog.title | escape }}
          </h1>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="main-blog__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}

        {%- comment -%} Tag cloud {%- endcomment -%}
        {%- if section.settings.show_tag_cloud and blog.all_tags.size > 0 -%}
          <nav class="main-blog__tags" aria-label="Tag del blog">
            {%- if current_tags -%}
              <a
                href="{{ blog.url }}"
                class="main-blog__tag"
              >
                Tutti
              </a>
            {%- endif -%}
            {%- for tag in blog.all_tags -%}
              {%- if current_tags contains tag -%}
                <a
                  href="{{ blog.url }}"
                  class="main-blog__tag main-blog__tag--active"
                  aria-current="true"
                >
                  {{ tag }}
                </a>
              {%- else -%}
                <a
                  href="{{ blog.url }}/tagged/{{ tag | handleize }}"
                  class="main-blog__tag"
                >
                  {{ tag }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Articoli {%- endcomment -%}
    {%- liquid
      assign blog_layout = section.settings.layout
      assign enable_overlay = section.settings.enable_overlay
      assign collage_cols = section.settings.columns_desktop | plus: 0
      assign collage_cycle = collage_cols | plus: 1

      case blog_layout
        when 'grid'
          assign layout_class = 'blog-articles--grid'
        when 'collage'
          assign layout_class = 'blog-articles--collage'
        when 'list'
          assign layout_class = 'blog-articles--list'
        when 'editorial'
          assign layout_class = 'blog-articles--editorial'
        when 'mosaic'
          assign layout_class = 'blog-articles--mosaic'
        else
          assign layout_class = 'blog-articles--grid'
      endcase
    -%}

    <div class="blog-articles {{ layout_class }}">
      {%- for article in blog.articles -%}
        {%- liquid
          assign use_overlay = false
          assign card_layout = 'vertical'
          assign article_extra_class = ''
          assign can_overlay = false
          if enable_overlay and article.image and section.settings.show_image
            assign can_overlay = true
          endif

          if blog_layout == 'editorial' and forloop.first
            assign article_extra_class = ' blog-articles__article--hero'
            if can_overlay
              assign use_overlay = true
            endif
          endif

          if blog_layout == 'list'
            if can_overlay
              assign use_overlay = true
            else
              assign card_layout = 'horizontal'
              assign list_pos = section.settings.list_image_position
              if list_pos == 'right'
                assign article_extra_class = ' blog-articles__article--image-right'
              elsif list_pos == 'alternate'
                assign alt_mod = forloop.index0 | modulo: 2
                if alt_mod == 1
                  assign article_extra_class = ' blog-articles__article--image-right'
                endif
              endif
            endif
          endif

          if blog_layout == 'collage'
            assign collage_pos = forloop.index0 | modulo: collage_cycle
            if collage_pos == 0
              assign article_extra_class = ' blog-articles__article--full'
              if can_overlay
                assign use_overlay = true
              endif
            elsif forloop.last and collage_pos == 1
              assign article_extra_class = ' blog-articles__article--full'
              if can_overlay
                assign use_overlay = true
              endif
            endif
          endif
        -%}
        <div
          class="blog-articles__article article{{ article_extra_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          {%- render 'article-card',
            article: article,
            media_height: section.settings.image_height,
            media_aspect_ratio: article.image.aspect_ratio,
            show_image: section.settings.show_image,
            show_date: section.settings.show_date,
            show_author: section.settings.show_author,
            show_reading: section.settings.show_reading,
            show_icons: section.settings.show_icons,
            custom_icon_date: section.settings.custom_icon_date,
            custom_icon_reading: section.settings.custom_icon_reading,
            custom_icon_author: section.settings.custom_icon_author,
            show_excerpt: section.settings.show_excerpt,
            show_blog_name: section.settings.show_blog_name,
            blog_name: blog.title,
            blog_url: blog.url,
            show_tags: section.settings.show_tags,
            tags_style: section.settings.tags_style,
            info_layout: section.settings.info_layout,
            show_button: section.settings.show_button,
            button_label: section.settings.button_label,
            button_type: section.settings.button_type,
            button_style_secondary: section.settings.button_style_secondary,
            button_size: section.settings.button_size,
            button_icon: section.settings.button_icon,
            button_icon_position: section.settings.button_icon_position,
            button_align: section.settings.button_align,
            overlay: use_overlay,
            card_layout: card_layout
          -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Paginazione {%- endcomment -%}
    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}
  </div>
{%- endpaginate -%}

{%- if blog.articles.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": {{ blog.title | json }},
    "url": "{{ request.origin }}{{ blog.url }}",
    {%- if blog.articles.size > 0 -%}
    "blogPost": [
      {%- for article in blog.articles limit: 20 -%}
      {
        "@type": "BlogPosting",
        "headline": {{ article.title | json }},
        "url": "{{ request.origin }}{{ article.url }}",
        "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
        "author": {
          "@type": "Person",
          "name": {{ article.author | json }}
        },
        "publisher": {
          "@type": "Organization",
          "name": {{ shop.name | json }},
          "url": "{{ shop.url }}"
        },
        "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
        {%- if article.image -%}
        ,"image": "{{ article.image | image_url: width: 1200 }}"
        {%- endif -%}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
    {%- endif -%}
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Intestazione"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "default": true,
      "label": "Mostra titolo"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Allineamento titolo",
      "default": "left",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descrizione",
      "info": "Una breve descrizione che appare sotto al titolo del blog."
    },
    {
      "type": "header",
      "content": "Tag cloud"
    },
    {
      "type": "checkbox",
      "id": "show_tag_cloud",
      "default": true,
      "label": "Mostra nuvola di tag"
    },
    {
      "type": "header",
      "content": "Vista"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Tipo di layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Griglia" },
        { "value": "collage", "label": "Collage" },
        { "value": "list", "label": "Lista" },
        { "value": "editorial", "label": "Editoriale" },
        { "value": "mosaic", "label": "Mosaico" }
      ]
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonne desktop",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "info": "Utilizzato con i layout Griglia, Editoriale e Collage."
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonne mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "info": "Utilizzato con i layout Griglia, Editoriale e Mosaico."
    },
    {
      "type": "header",
      "content": "Vista Lista"
    },
    {
      "type": "select",
      "id": "list_image_position",
      "label": "Posizione immagine",
      "default": "left",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "right", "label": "Destra" },
        { "value": "alternate", "label": "Alternata" }
      ],
      "info": "Utilizzato solo con il layout Lista (senza overlay)."
    },
    {
      "type": "select",
      "id": "list_image_ratio",
      "label": "Proporzione immagine/info",
      "default": "50_50",
      "options": [
        { "value": "30_70", "label": "30 / 70" },
        { "value": "40_60", "label": "40 / 60" },
        { "value": "50_50", "label": "50 / 50" },
        { "value": "60_40", "label": "60 / 40" }
      ],
      "info": "Utilizzato solo con il layout Lista (senza overlay)."
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "default": false,
      "label": "Abilita overlay",
      "info": "Mostra le informazioni in sovrapposizione sull'immagine. Attivo solo su articoli a riga intera (Lista, hero Editoriale, card grandi Collage)."
    },
    {
      "type": "color",
      "id": "overlay_bg_color",
      "label": "Colore sfondo overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_bg_opacity",
      "label": "Opacita sfondo overlay",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Colore testo overlay",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "overlay_position",
      "label": "Posizione contenuto overlay",
      "default": "bottom",
      "options": [
        { "value": "top", "label": "Alto" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Basso" }
      ]
    },
    {
      "type": "header",
      "content": "Articoli"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 6,
      "label": "Articoli per pagina"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "default": false,
      "label": "Abilita infinite scroll",
      "info": "Carica automaticamente gli articoli successivi durante lo scroll. La paginazione classica resta disponibile come fallback."
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "adapt", "label": "t:sections.main-blog.settings.image_height.options__1.label" },
        { "value": "small", "label": "t:sections.main-blog.settings.image_height.options__2.label" },
        { "value": "medium", "label": "t:sections.main-blog.settings.image_height.options__3.label" },
        { "value": "large", "label": "t:sections.main-blog.settings.image_height.options__4.label" }
      ],
      "default": "medium",
      "label": "t:sections.main-blog.settings.image_height.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.main-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_reading",
      "default": false,
      "label": "Tempo di lettura"
    },
    {
      "type": "checkbox",
      "id": "show_icons",
      "default": false,
      "label": "Mostra icone"
    },
    {
      "type": "text",
      "id": "custom_icon_date",
      "label": "Icona data personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "text",
      "id": "custom_icon_reading",
      "label": "Icona lettura personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "text",
      "id": "custom_icon_author",
      "label": "Icona autore personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "Mostra estratto"
    },
    {
      "type": "checkbox",
      "id": "show_blog_name",
      "default": false,
      "label": "Mostra nome blog",
      "info": "Visualizza il nome del blog come etichetta (pill) sull'immagine, in alto a sinistra, con link al blog."
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "default": false,
      "label": "Mostra tag articolo"
    },
    {
      "type": "select",
      "id": "tags_style",
      "label": "Stile tag",
      "default": "pill",
      "options": [
        { "value": "pill", "label": "Pill" },
        { "value": "link", "label": "Link" }
      ],
      "info": "Scegli come visualizzare i tag: come etichette arrotondate (pill) o link semplici."
    },
    {
      "type": "header",
      "content": "Pulsante articolo"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Mostra pulsante",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Leggi articolo"
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Tipo pulsante",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill", "label": "Pill" },
        { "value": "link", "label": "Link" }
      ],
      "default": "link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "label": "Stile secondario (outline)",
      "default": false,
      "info": "Solo per tipo 'Pulsante'."
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Dimensione pulsante",
      "options": [
        { "value": "default", "label": "Predefinita" },
        { "value": "small", "label": "Piccolo" },
        { "value": "medium", "label": "Medio" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "default",
      "info": "Solo per tipo 'Pulsante'."
