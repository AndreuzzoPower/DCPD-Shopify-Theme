{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
{{ 'ms_contact-form.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default'
    assign sw = 'page_width'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
    else
      assign sw_class = 'page-width'
  endcase

  assign contact_form_class = 'isolate'
  if settings.animations_reveal_on_scroll
    assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
  endif
-%}

{%- comment -%}
  Macro per rendere un campo input con supporto label/placeholder e colonne.
  Chiamata inline tramite assegnazione di variabili prima di includere
  il blocco HTML — Liquid non supporta macro, quindi usiamo variabili.
{%- endcomment -%}

<div id="section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact{% unless sw_class == blank %} {{ sw_class }}{% endunless %}">

    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}

      {%- if form.posted_successfully? -%}
        <div class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {%- render 'ms_icon', icon: settings.ms_icon_success -%}
          {{ 'templates.contact.form.post_success' | t }}
        </div>
      {%- elsif form.errors -%}
        <div class="form__message">
          <div class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {%- render 'ms_icon', icon: settings.ms_icon_error -%}
            {{ 'templates.contact.form.error_heading' | t }}
          </div>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}

      <div class="ms-contact-form__grid">

        {%- comment -%} ── Nome ── {%- endcomment -%}
        {%- if section.settings.show_name -%}
          {%- liquid
            assign f_cols  = section.settings.cols_name | default: '6'
            assign f_mode  = section.settings.label_mode_name | default: 'label'
            assign f_label = section.settings.label_name | default: 'Nome'
            assign f_ph    = f_label
            if section.settings.required_name
              assign f_ph = f_label | append: ' *'
            endif
          -%}
          <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}">
            <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
              <input
                class="field__input"
                autocomplete="name"
                type="text"
                id="ContactForm-name"
                name="contact[Nome]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="{{ f_ph }}"
                {% if section.settings.required_name %}required aria-required="true"{% endif %}
                {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
              >
              {%- if f_mode == 'label' -%}
                <label class="field__label" for="ContactForm-name">
                  {{- f_label -}}{%- if section.settings.required_name %}<span aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ── Email (sempre visibile, sempre obbligatoria) ── {%- endcomment -%}
        {%- liquid
          assign f_cols_em  = section.settings.cols_email | default: '6'
          assign f_mode_em  = section.settings.label_mode_email | default: 'label'
          assign f_label_em = section.settings.label_email | default: 'Email'
          assign f_ph_em    = f_label_em | append: ' *'
        -%}
        <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols_em }}">
          <div class="field field--with-error{% if f_mode_em == 'placeholder' %} ms-field--placeholder-only{% endif %}">
            <input
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              class="field__input"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{ f_ph_em }}"
              {% if f_mode_em == 'placeholder' %}aria-label="{{ f_label_em }}"{% endif %}
            >
            {%- if f_mode_em == 'label' -%}
              <label class="field__label" for="ContactForm-email">
                {{- f_label_em -}}<span aria-hidden="true"> *</span>
              </label>
            {%- endif -%}
            {%- if form.errors contains 'email' -%}
              <small class="contact__field-error" id="ContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message">
                  {%- render 'ms_icon', icon: settings.ms_icon_error -%}
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ── Telefono ── {%- endcomment -%}
        {%- if section.settings.show_phone -%}
          {%- liquid
            assign f_cols  = section.settings.cols_phone | default: '6'
            assign f_mode  = section.settings.label_mode_phone | default: 'label'
            assign f_label = section.settings.label_phone | default: 'Telefono'
            assign f_ph    = f_label
            if section.settings.required_phone
              assign f_ph = f_label | append: ' *'
            endif
          -%}
          <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}">
            <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
              <input
                type="tel"
                id="ContactForm-phone"
                class="field__input"
                autocomplete="tel"
                name="contact[Telefono]"
                pattern="[0-9\-\+\s]*"
                value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                placeholder="{{ f_ph }}"
                {% if section.settings.required_phone %}required aria-required="true"{% endif %}
                {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
              >
              {%- if f_mode == 'label' -%}
                <label class="field__label" for="ContactForm-phone">
                  {{- f_label -}}{%- if section.settings.required_phone %}<span aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ── Azienda ── {%- endcomment -%}
        {%- if section.settings.show_company -%}
          {%- liquid
            assign f_cols  = section.settings.cols_company | default: '6'
            assign f_mode  = section.settings.label_mode_company | default: 'label'
            assign f_label = section.settings.label_company | default: 'Azienda'
            assign f_ph    = f_label
            if section.settings.required_company
              assign f_ph = f_label | append: ' *'
            endif
          -%}
          <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}">
            <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
              <input
                type="text"
                id="ContactForm-company"
                class="field__input"
                autocomplete="organization"
                name="contact[Azienda]"
                value="{{ form['Azienda'] }}"
                placeholder="{{ f_ph }}"
                {% if section.settings.required_company %}required aria-required="true"{% endif %}
                {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
              >
              {%- if f_mode == 'label' -%}
                <label class="field__label" for="ContactForm-company">
                  {{- f_label -}}{%- if section.settings.required_company %}<span aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ── Oggetto ── {%- endcomment -%}
        {%- if section.settings.show_subject -%}
          {%- liquid
            assign f_cols  = section.settings.cols_subject | default: '12'
            assign f_mode  = section.settings.label_mode_subject | default: 'label'
            assign f_label = section.settings.label_subject | default: 'Oggetto'
            assign f_ph    = f_label
            if section.settings.required_subject
              assign f_ph = f_label | append: ' *'
            endif
          -%}
          <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}">
            <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
              <input
                type="text"
                id="ContactForm-subject"
                class="field__input"
                name="contact[Oggetto]"
                value="{{ form['Oggetto'] }}"
                placeholder="{{ f_ph }}"
                {% if section.settings.required_subject %}required aria-required="true"{% endif %}
                {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
              >
              {%- if f_mode == 'label' -%}
                <label class="field__label" for="ContactForm-subject">
                  {{- f_label -}}{%- if section.settings.required_subject %}<span aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ── Messaggio ── {%- endcomment -%}
        {%- if section.settings.show_message -%}
          {%- liquid
            assign f_cols  = section.settings.cols_message | default: '12'
            assign f_mode  = section.settings.label_mode_message | default: 'label'
            assign f_label = section.settings.label_message | default: 'Messaggio'
            assign f_ph    = f_label
            if section.settings.required_message
              assign f_ph = f_label | append: ' *'
            endif
          -%}
          <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}">
            <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
              <textarea
                rows="{{ section.settings.rows_message | default: 8 }}"
                id="ContactForm-body"
                class="text-area field__input"
                name="contact[Messaggio]"
                placeholder="{{ f_ph }}"
                {% if section.settings.required_message %}required aria-required="true"{% endif %}
                {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
              >
                {{- form.body -}}
              </textarea>
              {%- if f_mode == 'label' -%}
                <label class="form__label field__label" for="ContactForm-body">
                  {{- f_label -}}{%- if section.settings.required_message %}<span aria-hidden="true"> *</span>{%- endif -%}
                </label>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} ── Consensi ── {%- endcomment -%}
      {%- if section.settings.show_privacy or section.settings.show_newsletter or section.settings.show_profiling -%}
        <div class="ms-contact-form__consents">

          {%- if section.settings.show_privacy and section.settings.privacy_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-privacy-{{ section.id }}"
                name="contact[Privacy Policy]"
                value="Accettata"
                {% if section.settings.required_privacy %}required aria-required="true"{% endif %}
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-privacy-{{ section.id }}">
                {{ section.settings.privacy_text }}
                {%- if section.settings.required_privacy -%}
                  <span class="ms-contact-form__consent-required" aria-hidden="true"> *</span>
                {%- endif -%}
              </label>
            </div>
          {%- endif -%}

          {%- if section.settings.show_newsletter and section.settings.newsletter_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-newsletter-{{ section.id }}"
                name="contact[Newsletter]"
                value="Accettata"
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-newsletter-{{ section.id }}">
                {{ section.settings.newsletter_text }}
              </label>
            </div>
          {%- endif -%}

          {%- if section.settings.show_profiling and section.settings.profiling_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-profiling-{{ section.id }}"
                name="contact[Profilazione]"
                value="Accettata"
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-profiling-{{ section.id }}">
                {{ section.settings.profiling_text }}
              </label>
            </div>
          {%- endif -%}

        </div>
      {%- endif -%}

      {%- comment -%} ── Pulsante invio ── {%- endcomment -%}
      {%- assign btn_align = section.settings.button_align | default: 'left' -%}
      <div class="contact__button ms-contact-form__button--{{ btn_align }}">
        <button
          type="submit"
          class="{%- render 'ms_button_classes', type: section.settings.button_type, secondary: section.settings.button_style_secondary, size: section.settings.button_size -%}"
        >
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'before' -%}
          {{ section.settings.button_label | default: 'Invia messaggio' | escape }}
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'after' -%}
        </button>
      </div>

    {%- endform -%}
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Form Contatti",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "narrow"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Campo Nome"
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "label": "Mostra campo",
      "default": true
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Etichetta",
      "default": "Nome"
    },
    {
      "type": "select",
      "id": "label_mode_name",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "checkbox",
      "id": "required_name",
      "label": "Obbligatorio",
      "default": false
    },
    {
      "type": "select",
      "id": "cols_name",
      "label": "Larghezza colonne",
      "default": "6",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Campo Email"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Etichetta",
      "default": "Email",
      "info": "Sempre visibile e obbligatorio."
    },
    {
      "type": "select",
      "id": "label_mode_email",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "select",
      "id": "cols_email",
      "label": "Larghezza colonne",
      "default": "6",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Campo Telefono"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Mostra campo",
      "default": true
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "Etichetta",
      "default": "Telefono"
    },
    {
      "type": "select",
      "id": "label_mode_phone",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "checkbox",
      "id": "required_phone",
      "label": "Obbligatorio",
      "default": false
    },
    {
      "type": "select",
      "id": "cols_phone",
      "label": "Larghezza colonne",
      "default": "6",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Campo Azienda"
    },
    {
      "type": "checkbox",
      "id": "show_company",
      "label": "Mostra campo",
      "default": false
    },
    {
      "type": "text",
      "id": "label_company",
      "label": "Etichetta",
      "default": "Azienda"
    },
    {
      "type": "select",
      "id": "label_mode_company",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "checkbox",
      "id": "required_company",
      "label": "Obbligatorio",
      "default": false
    },
    {
      "type": "select",
      "id": "cols_company",
      "label": "Larghezza colonne",
      "default": "6",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Campo Oggetto"
    },
    {
      "type": "checkbox",
      "id": "show_subject",
      "label": "Mostra campo",
      "default": false
    },
    {
      "type": "text",
      "id": "label_subject",
      "label": "Etichetta",
      "default": "Oggetto"
    },
    {
      "type": "select",
      "id": "label_mode_subject",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "checkbox",
      "id": "required_subject",
      "label": "Obbligatorio",
      "default": false
    },
    {
      "type": "select",
      "id": "cols_subject",
      "label": "Larghezza colonne",
      "default": "12",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Campo Messaggio"
    },
    {
      "type": "checkbox",
      "id": "show_message",
      "label": "Mostra campo",
      "default": true
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "Etichetta",
      "default": "Messaggio"
    },
    {
      "type": "select",
      "id": "label_mode_message",
      "label": "Stile etichetta",
      "default": "label",
      "options": [
        { "value": "label", "label": "Label fluttuante" },
        { "value": "placeholder", "label": "Solo placeholder" }
      ]
    },
    {
      "type": "checkbox",
      "id": "required_message",
      "label": "Obbligatorio",
      "default": false
    },
    {
      "type": "range",
      "id": "rows_message",
      "label": "Righe textarea",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "cols_message",
      "label": "Larghezza colonne",
      "default": "12",
      "options": [
        { "value": "4", "label": "4/12 (un terzo)" },
        { "value": "6", "label": "6/12 (metà)" },
        { "value": "12", "label": "12/12 (intera riga)" }
      ]
    },
    {
      "type": "header",
      "content": "Consenso Privacy Policy"
    },
    {
      "type": "checkbox",
      "id": "show_privacy",
      "label": "Mostra consenso privacy",
      "default": true
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Testo consenso privacy",
      "default": "<p>Ho letto e accetto la <a href='/policies/privacy-policy'>Privacy Policy</a></p>",
      "info": "Puoi inserire link alla tua pagina privacy policy."
    },
    {
      "type": "checkbox",
      "id": "required_privacy",
      "label": "Obbligatorio",
      "default": true
    },
    {
      "type": "header",
      "content": "Consenso Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Mostra consenso newsletter",
      "default": false
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Testo consenso newsletter",
      "default": "<p>Acconsento all'invio di comunicazioni commerciali e newsletter</p>"
    },
    {
      "type": "header",
      "content": "Consenso Profilazione"
    },
    {
      "type": "checkbox",
      "id": "show_profiling",
      "label": "Mostra consenso profilazione",
      "default": false
    },
    {
      "type": "richtext",
      "id": "profiling_text",
      "label": "Testo consenso profilazione",
      "default": "<p>Acconsento al trattamento dei miei dati personali per finalità di profilazione</p>"
    },
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Invia messaggio"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Dimensione pulsante",
      "info": "\"Predefinita\" usa il valore globale da Impostazioni tema → Pulsanti.",
      "default": "default",
