{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
{{ 'ms_contact-form.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default'
    assign sw = 'page_width'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
    else
      assign sw_class = 'page-width'
  endcase

  assign contact_form_class = 'isolate'
  if settings.animations_reveal_on_scroll
    assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
  endif
-%}

<div id="section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact{% unless sw_class == blank %} {{ sw_class }}{% endunless %}">

    {%- if section.settings.use_shopify_form and section.settings.shopify_form_embed != blank -%}
      {%- comment -%} ── Form nativo Shopify Forms app ── {%- endcomment -%}
      <div class="ms-contact-form__shopify-embed">
        {{ section.settings.shopify_form_embed }}
      </div>

    {%- else -%}

    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}

      {%- if form.posted_successfully? -%}
        <div class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {%- render 'ms_icon', icon: settings.ms_icon_success -%}
          {{ 'templates.contact.form.post_success' | t }}
        </div>
      {%- elsif form.errors -%}
        <div class="form__message">
          <div class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {%- render 'ms_icon', icon: settings.ms_icon_error -%}
            {{ 'templates.contact.form.error_heading' | t }}
          </div>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}

      {%- comment -%} ── Campi dinamici ── {%- endcomment -%}
      <div class="ms-contact-form__grid">

        {%- for block in section.blocks -%}
          {%- liquid
            assign bt = block.type
            assign is_field = false
            if bt == 'field_text' or bt == 'field_email' or bt == 'field_tel' or bt == 'field_textarea' or bt == 'field_select' or bt == 'text_block' or bt == 'spacer'
              assign is_field = true
            endif
          -%}

          {%- if is_field -%}
            {%- liquid
              assign f_cols     = block.settings.cols | default: '6'
              assign f_mode     = block.settings.label_mode | default: 'label'
              assign f_label    = block.settings.label | default: 'Campo'
              assign f_required = block.settings.required
              assign f_name     = block.settings.field_name | default: 'campo'
              assign f_id       = 'ContactForm-' | append: block.id
              if bt == 'field_email'
                assign f_id = 'ContactForm-email'
              endif
              assign f_ph = f_label
              if f_required
                assign f_ph = f_label | append: ' *'
              endif
              if bt == 'spacer'
                assign f_cols = '12'
              endif
            -%}

            <div class="ms-contact-form__field-wrap ms-contact-form__field-wrap--cols-{{ f_cols }}" {{ block.shopify_attributes }}>

              {%- case bt -%}

                {%- when 'field_text' -%}
                  <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
                    <input
                      type="text"
                      id="{{ f_id }}"
                      class="field__input"
                      name="contact[{{ f_name }}]"
                      value="{{ form[f_name] }}"
                      placeholder="{{ f_ph }}"
                      {% unless block.settings.autocomplete == blank or block.settings.autocomplete == 'none' %}autocomplete="{{ block.settings.autocomplete }}"{% endunless %}
                      {% if f_required %}required aria-required="true"{% endif %}
                      {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
                    >
                    {%- if f_mode == 'label' -%}
                      <label class="field__label" for="{{ f_id }}">
                        {{- f_label -}}{%- if f_required %}<span aria-hidden="true"> *</span>{%- endif -%}
                      </label>
                    {%- endif -%}
                  </div>

                {%- when 'field_email' -%}
                  <div class="field field--with-error{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
                    <input
                      type="email"
                      id="{{ f_id }}"
                      class="field__input"
                      name="contact[{{ f_name }}]"
                      autocomplete="email"
                      spellcheck="false"
                      autocapitalize="off"
                      value="{{ form.email }}"
                      placeholder="{{ f_ph }}"
                      {% if f_required %}required aria-required="true"{% endif %}
                      {% if form.errors contains 'email' %}
                        aria-invalid="true"
                        aria-describedby="{{ f_id }}-error"
                      {% endif %}
                      {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
                    >
                    {%- if f_mode == 'label' -%}
                      <label class="field__label" for="{{ f_id }}">
                        {{- f_label -}}{%- if f_required %}<span aria-hidden="true"> *</span>{%- endif -%}
                      </label>
                    {%- endif -%}
                    {%- if form.errors contains 'email' -%}
                      <small class="contact__field-error" id="{{ f_id }}-error">
                        <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                        <span class="form__message">
                          {%- render 'ms_icon', icon: settings.ms_icon_error -%}
                          {{- form.errors.translated_fields.email | capitalize }}
                          {{ form.errors.messages.email -}}
                        </span>
                      </small>
                    {%- endif -%}
                  </div>

                {%- when 'field_tel' -%}
                  <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
                    <input
                      type="tel"
                      id="{{ f_id }}"
                      class="field__input"
                      name="contact[{{ f_name }}]"
                      autocomplete="tel"
                      pattern="[0-9\-\+\s]*"
                      value="{{ form[f_name] }}"
                      placeholder="{{ f_ph }}"
                      {% if f_required %}required aria-required="true"{% endif %}
                      {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
                    >
                    {%- if f_mode == 'label' -%}
                      <label class="field__label" for="{{ f_id }}">
                        {{- f_label -}}{%- if f_required %}<span aria-hidden="true"> *</span>{%- endif -%}
                      </label>
                    {%- endif -%}
                  </div>

                {%- when 'field_textarea' -%}
                  <div class="field{% if f_mode == 'placeholder' %} ms-field--placeholder-only{% endif %}">
                    <textarea
                      rows="{{ block.settings.rows | default: 8 }}"
                      id="{{ f_id }}"
                      class="text-area field__input"
                      name="contact[{{ f_name }}]"
                      placeholder="{{ f_ph }}"
                      {% if f_required %}required aria-required="true"{% endif %}
                      {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
                    >{{- form[f_name] -}}</textarea>
                    {%- if f_mode == 'label' -%}
                      <label class="form__label field__label" for="{{ f_id }}">
                        {{- f_label -}}{%- if f_required %}<span aria-hidden="true"> *</span>{%- endif -%}
                      </label>
                    {%- endif -%}
                  </div>

                {%- when 'field_select' -%}
                  <div class="ms-contact-form__select-wrap">
                    {%- if f_mode == 'label' -%}
                      <label class="form__label ms-contact-form__select-label" for="{{ f_id }}">
                        {{- f_label -}}{%- if f_required %}<span aria-hidden="true"> *</span>{%- endif -%}
                      </label>
                    {%- endif -%}
                    <div class="select">
                      <select
                        id="{{ f_id }}"
                        class="select__select"
                        name="contact[{{ f_name }}]"
                        {% if f_required %}required aria-required="true"{% endif %}
                        {% if f_mode == 'placeholder' %}aria-label="{{ f_label }}"{% endif %}
                      >
                        {%- if block.settings.placeholder_option != blank -%}
                          <option value="" disabled selected>{{ block.settings.placeholder_option }}</option>
                        {%- endif -%}
                        {%- assign select_opts = block.settings.options_list | split: "\n" -%}
                        {%- for opt in select_opts -%}
                          {%- assign opt_val = opt | strip -%}
                          {%- if opt_val != blank -%}
                            <option value="{{ opt_val }}"{% if form[f_name] == opt_val %} selected{% endif %}>{{ opt_val }}</option>
                          {%- endif -%}
                        {%- endfor -%}
                      </select>
                      {%- render 'icon-caret' -%}
                    </div>
                  </div>

                {%- when 'text_block' -%}
                  {%- liquid
                    assign tb_tag   = block.settings.heading_tag | default: 'h3'
                    assign tb_align = block.settings.text_align | default: 'left'
                  -%}
                  <div class="ms-contact-form__text-block" style="text-align: {{ tb_align }};">
                    {%- if block.settings.heading != blank -%}
                      <{{ tb_tag }} class="ms-contact-form__text-block-heading {{ block.settings.heading_size | default: 'h3' }}">
                        {{ block.settings.heading | escape }}
                      </{{ tb_tag }}>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="ms-contact-form__text-block-body rte">
                        {{ block.settings.text }}
                      </div>
                    {%- endif -%}
                  </div>

                {%- when 'spacer' -%}
                  <div
                    class="ms-contact-form__spacer"
                    style="--spacer-h: {{ block.settings.height | default: 30 }}px; --spacer-h-mobile: {{ block.settings.height_mobile | default: 15 }}px;"
                    aria-hidden="true"
                  ></div>

              {%- endcase -%}

            </div>
          {%- endif -%}

        {%- endfor -%}

      </div>

      {%- comment -%} ── Consensi ── {%- endcomment -%}
      {%- if section.settings.show_privacy or section.settings.show_newsletter or section.settings.show_profiling -%}
        <div class="ms-contact-form__consents">

          {%- if section.settings.show_privacy and section.settings.privacy_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-privacy-{{ section.id }}"
                name="contact[Privacy Policy]"
                value="Accettata"
                {% if section.settings.required_privacy %}required aria-required="true"{% endif %}
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-privacy-{{ section.id }}">
                {{ section.settings.privacy_text }}
                {%- if section.settings.required_privacy -%}
                  <span class="ms-contact-form__consent-required" aria-hidden="true"> *</span>
                {%- endif -%}
              </label>
            </div>
          {%- endif -%}

          {%- if section.settings.show_newsletter and section.settings.newsletter_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-newsletter-{{ section.id }}"
                name="contact[Newsletter]"
                value="Accettata"
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-newsletter-{{ section.id }}">
                {{ section.settings.newsletter_text }}
              </label>
            </div>
          {%- endif -%}

          {%- if section.settings.show_profiling and section.settings.profiling_text != blank -%}
            <div class="ms-contact-form__consent">
              <input
                type="checkbox"
                id="ContactForm-profiling-{{ section.id }}"
                name="contact[Profilazione]"
                value="Accettata"
              >
              <label class="ms-contact-form__consent-label rte" for="ContactForm-profiling-{{ section.id }}">
                {{ section.settings.profiling_text }}
              </label>
            </div>
          {%- endif -%}

        </div>
      {%- endif -%}

      {%- comment -%} ── Pulsante invio ── {%- endcomment -%}
      {%- assign btn_align = section.settings.button_align | default: 'left' -%}
      <div class="contact__button ms-contact-form__button--{{ btn_align }}">
        <button
          type="submit"
          class="{%- render 'ms_button_classes', type: section.settings.button_type, secondary: section.settings.button_style_secondary, size: section.settings.button_size -%}"
        >
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'before' -%}
          {{ section.settings.button_label | default: 'Invia messaggio' | escape }}
          {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'after' -%}
        </button>
      </div>

    {%- endform -%}

    {%- endif -%}
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Form Contatti",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "narrow"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Shopify Forms (app)"
    },
    {
      "type": "checkbox",
      "id": "use_shopify_form",
      "label": "Usa form dall'app Shopify Forms",
      "default": false,
      "info": "Se attivo, i blocchi campo e i consensi vengono ignorati: viene renderizzato il codice embed qui sotto."
    },
    {
      "type": "liquid",
      "id": "shopify_form_embed",
      "label": "Codice embed form",
      "info": "Incolla il codice Liquid o HTML fornito dall'app Shopify Forms. Visibile solo se l'opzione sopra è attiva."
    },
    {
      "type": "header",
      "content": "Consenso Privacy Policy"
    },
    {
      "type": "checkbox",
      "id": "show_privacy",
      "label": "Mostra consenso privacy",
      "default": true
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Testo consenso privacy",
      "default": "<p>Ho letto e accetto la <a href='/policies/privacy-policy'>Privacy Policy</a></p>",
      "info": "Puoi inserire link alla tua pagina privacy policy."
    },
    {
      "type": "checkbox",
      "id": "required_privacy",
      "label": "Obbligatorio",
      "default": true
    },
    {
      "type": "header",
      "content": "Consenso Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Mostra consenso newsletter",
      "default": false
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Testo consenso newsletter",
      "default": "<p>Acconsento all'invio di comunicazioni commerciali e newsletter</p>"
    },
    {
      "type": "header",
      "content": "Consenso Profilazione"
    },
    {
      "type": "checkbox",
      "id": "show_profiling",
      "label": "Mostra consenso profilazione",
      "default": false
    },
    {
      "type": "richtext",
      "id": "profiling_text",
      "label": "Testo consenso profilazione",
      "default": "<p>Acconsento al trattamento dei miei dati personali per finalità di profilazione</p>"
    },
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Invia messaggio"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Dimensione pulsante",
      "info": "\"Predefinita\" usa il valore globale da Impostazioni tema → Pulsanti.",
      "default": "default",
      "options": [
        { "value": "default", "label": "Predefinita" },
        { "value": "small",   "label": "Small" },
        { "value": "medium",  "label": "Medium" },
        { "value": "large",   "label": "Large" },
        { "value": "jumbo",   "label": "Jumbo" },
        { "value": "extra_jumbo", "label": "Extra Jumbo" }
      ]
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "label": "Stile contorno",
      "default": false,
      "info": "Se attivo, il pulsante ha bordo visibile e sfondo trasparente."
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Tipo pulsante",
      "default": "button",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill",   "label": "Pill (arrotondato)" },
        { "value": "link",   "label": "Solo link" }
      ]
    },
    {
      "type": "text",
      "id": "button_icon",
      "label": "Icona pulsante",
      "info": "Nome file SVG (es. icon-arrow.svg) o classe icone (es. fa-solid fa-arrow-right). Vuoto = nessuna icona."
    },
    {
      "type": "select",
      "id": "button_icon_position",
      "label": "Posizione icona",
      "default": "after",
      "options": [
        { "value": "before", "label": "Prima del testo" },
        { "value": "after",  "label": "Dopo il testo" }
      ]
    },
    {
      "type": "select",
      "id": "button_align",
      "label": "Allineamento pulsante",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Destra" },
        { "value": "full",   "label": "Larghezza piena" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "field_text",
      "name": "Campo Testo",
      "settings": [
        {
          "type": "text",
          "id": "field_name",
          "label": "Nome campo",
          "default": "Nome",
          "info": "Usato come chiave nel messaggio ricevuto (es. 'Nome: Mario Rossi'). Solo lettere e trattini."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta",
          "default": "Nome"
        },
        {
          "type": "select",
          "id": "label_mode",
          "label": "Stile etichetta",
          "default": "label",
          "options": [
            { "value": "label",       "label": "Label fluttuante" },
            { "value": "placeholder", "label": "Solo placeholder" }
          ]
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Obbligatorio",
          "default": false
        },
        {
          "type": "select",
          "id": "cols",
          "label": "Larghezza colonne",
          "default": "6",
          "options": [
            { "value": "4",  "label": "4/12 — un terzo" },
            { "value": "6",  "label": "6/12 — metà" },
            { "value": "12", "label": "12/12 — intera riga" }
          ]
        },
        {
          "type": "select",
          "id": "autocomplete",
          "label": "Autocomplete browser",
          "default": "none",
          "options": [
            { "value": "none",           "label": "Nessuno" },
            { "value": "name",           "label": "Nome completo" },
            { "value": "given-name",     "label": "Nome" },
            { "value": "family-name",    "label": "Cognome" },
            { "value": "organization",   "label": "Azienda" },
            { "value": "street-address", "label": "Indirizzo" },
            { "value": "postal-code",    "label": "CAP" },
            { "value": "country-name",   "label": "Paese" }
          ]
        }
      ]
    },
    {
      "type": "field_email",
      "name": "Campo Email",
      "settings": [
        {
          "type": "text",
          "id": "field_name",
          "label": "Nome campo",
          "default": "email",
          "info": "Lascia 'email' per il campo principale — usato da Shopify per le notifiche."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta",
          "default": "Email"
        },
        {
          "type": "select",
          "id": "label_mode",
          "label": "Stile etichetta",
          "default": "label",
          "options": [
            { "value": "label",       "label": "Label fluttuante" },
            { "value": "placeholder", "label": "Solo placeholder" }
          ]
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Obbligatorio",
          "default": true
        },
        {
          "type": "select",
          "id": "cols",
          "label": "Larghezza colonne",
          "default": "6",
          "options": [
            { "value": "4",  "label": "4/12 — un terzo" },
            { "value": "6",  "label": "6/12 — metà" },
            { "value": "12", "label": "12/12 — intera riga" }
          ]
        }
      ]
    },
    {
      "type": "field_tel",
      "name": "Campo Telefono",
      "settings": [
        {
          "type": "text",
          "id": "field_name",
          "label": "Nome campo",
          "default": "Telefono"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta",
          "default": "Telefono"
        },
        {
          "type": "select",
          "id": "label_mode",
          "label": "Stile etichetta",
          "default": "label",
          "options": [
            { "value": "label",       "label": "Label fluttuante" },
            { "value": "placeholder", "label": "Solo placeholder" }
          ]
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Obbligatorio",
          "default": false
        },
        {
          "type": "select",
          "id": "cols",
          "label": "Larghezza colonne",
          "default": "6",
          "options": [
            { "value": "4",  "label": "4/12 — un terzo" },
            { "value": "6",  "label": "6/12 — metà" },
            { "value": "12", "label": "12/12 — intera riga" }
          ]
        }
      ]
    },
    {
      "type": "field_textarea",
      "name": "Campo Area di Testo",
      "settings": [
        {
          "type": "text",
          "id": "field_name",
          "label": "Nome campo",
          "default": "Messaggio"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta",
          "default": "Messaggio"
        },
        {
          "type": "select",
          "id": "label_mode",
          "label": "Stile etichetta",
          "default": "label",
          "options": [
            { "value": "label",       "label": "Label fluttuante" },
            { "value": "placeholder", "label": "Solo placeholder" }
          ]
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Obbligatorio",
          "default": false
        },
        {
          "type": "range",
          "id": "rows",
          "label": "Righe visibili",
          "min": 3,
          "max": 20,
          "step": 1,
          "default": 8
        },
        {
          "type": "select",
          "id": "cols",
          "label": "Larghezza colonne",
          "default": "12",
          "options": [
            { "value": "4",  "label": "4/12 — un terzo" },
            { "value": "6",  "label": "6/12 — metà" },
            { "value": "12", "label": "12/12 — intera riga" }
          ]
        }
      ]
    },
