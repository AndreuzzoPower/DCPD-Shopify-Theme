{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign products_to_display = section.settings.collection.all_products_count

  if section.settings.collection.all_products_count > section.settings.products_to_show
    assign products_to_display = section.settings.products_to_show
    assign more_in_collection = true
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and products_to_display > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif

  assign is_full_width = false
  if section.settings.section_width == 'full_width'
    assign is_full_width = true
  endif

  assign peek = section.settings.carousel_peek_size | default: 'medium'

  assign fc_sw = section.settings.section_width | default: 'page_width'
  if fc_sw == 'default' or fc_sw == 'contained'
    assign fc_sw = 'page_width'
  elsif fc_sw == 'full'
    assign fc_sw = 'full_width'
  elsif fc_sw == 'fluid'
    assign fc_sw = 'page_fluid'
  endif
  case fc_sw
    when 'narrow'
      assign fc_sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign fc_sw_class = 'page-width'
    when 'page_fluid'
      assign fc_sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign fc_sw_class = ''
  endcase
-%}

{%- unless is_full_width -%}
  {%- if show_desktop_slider -%}
    {% style %}
      @media screen and (min-width: 990px) {
        #section-{{ section.id }} .slider.slider--desktop {
          margin-left: 0;
          scroll-padding-left: 0;
        }
        {%- if peek == 'none' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: 100%; }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(25% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(20% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(16.66% - var(--grid-desktop-horizontal-spacing) * 5 / 6); }
        {%- elsif peek == 'small' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(75% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(42.857% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(30% - var(--grid-desktop-horizontal-spacing) * 9 / 10); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(23.077% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.75% - var(--grid-desktop-horizontal-spacing) * 15 / 16); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.789% - var(--grid-desktop-horizontal-spacing) * 18 / 19); }
        {%- elsif peek == 'large' -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(57.143% - var(--grid-desktop-horizontal-spacing) * 4 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(36.364% - var(--grid-desktop-horizontal-spacing) * 8 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(26.667% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(21.053% - var(--grid-desktop-horizontal-spacing) * 16 / 19); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(17.391% - var(--grid-desktop-horizontal-spacing) * 20 / 23); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(14.815% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        {%- else -%}
        #section-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(66.667% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
        #section-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(40% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
        #section-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(28.571% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
        #section-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(22.222% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
        #section-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.182% - var(--grid-desktop-horizontal-spacing) * 10 / 11); }
        #section-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.385% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
        {%- endif -%}
      }
    {% endstyle %}
  {%- endif -%}
{%- endunless -%}

<div
  class="color-{{ section.settings.color_scheme }} isolate gradient"
  id="section-{{ section.id }}"
>
  <div
    class="collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if is_full_width %} collection--full-width{% endif %}"
    id="collection-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.title != blank -%}
        <div class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </div>
      {%- endif -%}
      {%- if section.settings.description != blank
        or section.settings.show_description
        and section.settings.collection.description != empty
      -%}
        <div class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {%- if section.settings.show_description -%}
            {{ section.settings.collection.description }}
          {%- else -%}
            {{ section.settings.description -}}
          {%- endif %}
        </div>
      {%- endif -%}
    </div>

    {%- if fc_sw_class != blank -%}<div class="{{ fc_sw_class }}">{%- endif -%}
    <slider-component
      data-autoplay="{{ section.settings.enable_desktop_slider_autoplay }}"
      data-speed="{{ section.settings.desktop_slider_autoplay_velocita }}000"
      data-scroll-mode="{{ section.settings.carousel_scroll_mode | default: 'page' }}"
      data-loop="{{ section.settings.carousel_loop | default: false }}"
      data-peek="{{ section.settings.carousel_peek_size | default: 'medium' }}"
      class="slider-mobile-gutter{% if is_full_width %} slider-component-full-width{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if section.settings.carousel_arrows_position == 'overlay_sides' %} ms-carousel--arrows-overlay-sides{% elsif section.settings.carousel_arrows_position == 'above_right' %} ms-carousel--arrows-above-right{% endif %}{% if section.settings.carousel_arrows_overlay_dark %} ms-carousel--arrows-overlay-dark{% endif %}{% unless section.settings.carousel_show_arrows == nil %}{% unless section.settings.carousel_show_arrows %} ms-carousel--no-arrows{% endunless %}{% endunless %}{% unless section.settings.carousel_show_pagination == nil %}{% unless section.settings.carousel_show_pagination %} ms-carousel--no-pagination{% endunless %}{% endunless %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% unless is_full_width %}style="--desktop-margin-left-first-item: 0px"{% endunless %}
    >
      <ul
        id="Slider-{{ section.id }}"
        data-id="{{ section.id }}"
        class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
        role="list"
        aria-label="{{ 'general.slider.name' | t }}"
      >
        {% assign skip_card_product_styles = false %}

        {%- if section.settings.collection.products.size > 0 -%}
          {% paginate section.settings.collection.products by section.settings.products_to_show %}
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_min_order: section.settings.show_min_order,
                  skip_styles: skip_card_product_styles,
                  section_id: section.id,
                  quick_add: section.settings.quick_add
                %}
              </li>
              {%- assign skip_card_product_styles = true -%}
            {%- endfor -%}
          {% endpaginate %}
        {%- else -%}
          {%- for i in (1..section.settings.columns_desktop) -%}
            <li
              class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {% liquid
                assign ridx = forloop.rindex
                case ridx
                  when 5
                    assign ridx = 1
                  when 6
                    assign ridx = 2
                endcase
              %}
              {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
              {% render 'card-product',
                show_vendor: section.settings.show_vendor,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                placeholder_image: placeholder_image
              %}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        {%- render 'ms_carousel-controls',
          section_id: section.id,
          total_items: products_to_display,
          pagination_style: section.settings.carousel_pagination_style,
          show_arrows: section.settings.carousel_show_arrows,
          show_pagination: section.settings.carousel_show_pagination,
          enable_autoplay: section.settings.enable_desktop_slider_autoplay
        -%}
      {%- endif -%}
    </slider-component>
    {%- if fc_sw_class != blank -%}</div>{%- endif -%}

    {%- if section.settings.show_view_all and more_in_collection -%}
      <div class="center collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a
          href="{{ section.settings.collection.url }}"
          class="{%- render 'ms_button_classes', type: section.settings.view_all_type, secondary: section.settings.view_all_style_secondary, size: section.settings.view_all_size -%}"
          aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.collection.title | escape }}"
        >
          {%- render 'ms_button_icon', icon: section.settings.view_all_icon, position: section.settings.view_all_icon_position, slot: 'before' -%}
          {{ 'sections.featured_collection.view_all' | t }}
          {%- render 'ms_button_icon', icon: section.settings.view_all_icon, position: section.settings.view_all_icon_position, slot: 'after' -%}
        </a>
      </div>
    {%- endif -%}
    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>
{%- render 'ms_section-style' -%}
{% schema %}
{
  "name": "MS Featured collection",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_to_show.label"
    },
    {
      "type": "liquid",
      "id": "title",
      "default": "t:sections.featured-collection.settings.title.default",
      "label": "t:sections.featured-collection.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "liquid",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.featured-collection.settings.show_description.label",
      "default": false
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.featured-collection.settings.description_style.label",
      "options": [
        {
          "value": "body",
          "label": "t:sections.featured-collection.settings.description_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.featured-collection.settings.description_style.options__2.label"
        },
        {
          "value": "uppercase",
          "label": "t:sections.featured-collection.settings.description_style.options__3.label"
        }
      ],
      "default": "body"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured-collection.settings.show_view_all.label",
      "info": "t:sections.featured-collection.settings.show_view_all.info"
    },
    {
      "type": "checkbox",
      "id": "view_all_style_secondary",
      "default": false,
      "label": "Stile contorno (View all)",
      "info": "Se attivo, il pulsante ha bordo visibile e sfondo trasparente."
    },
    {
      "type": "select",
      "id": "view_all_type",
      "label": "Tipo pulsante (View all)",
      "default": "button",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill", "label": "Pill (arrotondato)" },
        { "value": "link", "label": "Solo link" }
      ]
    },
    {
      "type": "select",
      "id": "view_all_size",
      "label": "Dimensione pulsante (View all)",
      "info": "\"Predefinita\" usa il valore globale da Impostazioni tema → Pulsanti.",
      "default": "default",
      "options": [
        { "value": "default", "label": "Predefinita" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "jumbo", "label": "Jumbo" },
        { "value": "extra_jumbo", "label": "Extra Jumbo" }
      ]
    },
    {
      "type": "text",
      "id": "view_all_icon",
      "label": "Icona pulsante (View all)",
      "info": "Nome file SVG (es. icon-arrow.svg) o classe icone (es. fa-solid fa-arrow-right). Vuoto = nessuna icona."
    },
    {
      "type": "select",
      "id": "view_all_icon_position",
      "label": "Posizione icona (View all)",
      "default": "before",
      "options": [
        { "value": "before", "label": "Prima del testo" },
        { "value": "after", "label": "Dopo il testo" }
      ]
    },
    {
      "type": "header",
      "content": "Carosello"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider_autoplay",
      "label": "Abilita autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_slider_autoplay_velocita",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Tempo transizione (sec.)"
    },
    {
      "type": "select",
      "id": "carousel_arrows_position",
      "label": "Posizionamento frecce",
      "default": "below_center",
      "options": [
        { "value": "below_center", "label": "Sotto (centrato)" },
        { "value": "overlay_sides", "label": "Ai lati (sovrapposto)" },
        { "value": "above_right", "label": "Sopra a destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_arrows_overlay_dark",
      "label": "Frecce overlay in tema scuro",
      "default": false,
      "info": "Attivo solo con posizionamento 'Ai lati (sovrapposto)'"
    },
    {
      "type": "select",
      "id": "carousel_pagination_style",
      "label": "Stile paginazione",
      "default": "counter",
      "options": [
        { "value": "counter", "label": "Contatore (1 / 5)" },
        { "value": "dots", "label": "Pallini" },
        { "value": "numbers", "label": "Numeri" },
        { "value": "none", "label": "Nessuna" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_scroll_mode",
      "label": "Modalità scorrimento",
      "default": "page",
      "options": [
        { "value": "page", "label": "Pagina (set di elementi)" },
        { "value": "single", "label": "Singolo elemento" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_loop",
      "label": "Tipo loop",
      "default": "none",
      "options": [
        { "value": "none",     "label": "Nessuno" },
        { "value": "rewind",   "label": "Rewind (torna all'inizio)" },
        { "value": "circular", "label": "Circolare (infinito)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_show_arrows",
      "label": "Mostra frecce",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel_show_pagination",
      "label": "Mostra paginazione",
      "default": true
    },
    {
      "type": "select",
      "id": "carousel_peek_size",
      "label": "Anteprima prossimo elemento",
      "default": "medium",
      "options": [
        { "value": "none", "label": "Nessuna" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ]
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.featured-collection.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
