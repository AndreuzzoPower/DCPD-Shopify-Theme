{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif

  assign is_full = false
  if sw == 'full_width'
    assign is_full = true
  endif

  if section.settings.full_width == true and section.settings.section_width == blank
    assign is_full = true
    assign sw = 'full_width'
  endif

  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase
-%}

{%- render 'ms_mobile-padding' -%}

<div class="isolate{% unless is_full %} {{ sw_class }}{% endunless %}">
  <div class="rich-text content-container color-{{ section.settings.color_scheme }} gradient{% if is_full %} rich-text--full-width content-container--full-width{% endif %}">
    <div class="rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}{% if is_full %} page-width{% endif %}">
      <div class="rich-text__blocks {{ section.settings.content_alignment }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- liquid
                assign title_tag = block.settings.title_tag | default: 'div'
                assign title_classes = 'rich-text__heading rte inline-richtext ' | append: block.settings.heading_size
                if block.settings.title_custom_class != blank
                  assign title_classes = title_classes | append: ' ' | append: block.settings.title_custom_class
                endif
                if settings.animations_reveal_on_scroll
                  assign title_classes = title_classes | append: ' scroll-trigger animate--slide-in'
                endif
              -%}
              <{{ title_tag }}
                class="{{ title_classes }}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.heading }}
              </{{ title_tag }}>
            {%- when 'caption' -%}
              <p
                class="rich-text__caption {{ block.settings.text_style }} {{ block.settings.text_style }}--{{ block.settings.text_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.caption | escape }}
              </p>
            {%- when 'text' -%}
              <div
                class="rich-text__text rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ block.settings.text }}
              </div>
            {%- when 'button' -%}
              <div
                class="rich-text__buttons{% if block.settings.button_label != blank and block.settings.button_label_2 != blank %} rich-text__buttons--multiple{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.button_label != blank -%}
                  <a
                    {% if block.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link }}"
                    {% endif %}
                    class="{%- render 'ms_button_classes', type: block.settings.button_type, secondary: block.settings.button_style_secondary, size: block.settings.button_size -%}"
                  >
                    {%- render 'ms_button_icon', icon: block.settings.button_icon, position: block.settings.button_icon_position, slot: 'before' -%}
                    {{- block.settings.button_label | escape -}}
                    {%- render 'ms_button_icon', icon: block.settings.button_icon, position: block.settings.button_icon_position, slot: 'after' -%}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a
                    {% if block.settings.button_link_2 == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link_2 }}"
                    {% endif %}
                    class="{%- render 'ms_button_classes', type: block.settings.button_type_2, secondary: block.settings.button_style_secondary_2, size: block.settings.button_size_2 -%}"
                  >
                    {%- render 'ms_button_icon', icon: block.settings.button_icon_2, position: block.settings.button_icon_position_2, slot: 'before' -%}
                    {{- block.settings.button_label_2 | escape -}}
                    {%- render 'ms_button_icon', icon: block.settings.button_icon_2, position: block.settings.button_icon_position_2, slot: 'after' -%}
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% for block in section.blocks %}
  {% if block.type == 'section_padding' %}
    <style>
      #shopify-section-{{ section.id }} {
        padding-top: {{ block.settings.section_padding_top }}px;
        padding-bottom: {{ block.settings.section_padding_bottom }}px;
      }
      @media all and (min-width: 768px) and (max-width: 991px) {
        #shopify-section-{{ section.id }} {
          padding-top: {{ block.settings.section_padding_top_md }}px;
          padding-bottom: {{ block.settings.section_padding_bottom_md }}px;
        }
      }
      @media all and (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          padding-top: {{ block.settings.section_padding_top_xs }}px;
          padding-bottom: {{ block.settings.section_padding_bottom_xs }}px;
        }
      }
    </style>
  {% endif %}
  {% if block.type == 'section_margin' %}
    <style>
      #shopify-section-{{ section.id }} {
        margin-top: {{ block.settings.section_margin_top }}px;
        margin-bottom: {{ block.settings.section_margin_bottom }}px;
      }
      @media all and (min-width: 768px) and (max-width: 991px) {
        #shopify-section-{{ section.id }} {
          margin-top: {{ block.settings.section_margin_top_md }}px;
          margin-bottom: {{ block.settings.section_margin_bottom_md }}px;
        }
      }
      @media all and (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          margin-top: {{ block.settings.section_margin_top_xs }}px;
          margin-bottom: {{ block.settings.section_margin_bottom_xs }}px;
        }
      }
    </style>
  {% endif %}
  {% if block.type == 'section_background' %}
    <style>
      #shopify-section-{{ section.id }} {
        background-color: {{ block.settings.section_bg_color }};
        {% if block.settings.section_bg_image != blank %}
          background-image: url({{ block.settings.section_bg_image | image_url }});
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;
        {% endif %}
      }
    </style>
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "MS Rich Text",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "full_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.rich-text.settings.desktop_content_position.label"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich-text.settings.content_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.rich-text.settings.content_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.rich-text.settings.content_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.rich-text.settings.content_alignment.label"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 3,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.rich-text.blocks.heading.settings.heading.default",
          "label": "t:sections.rich-text.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            },
            {
              "value": "hxl",
              "label": "t:sections.all.heading_size.options__4.label"
            },
            {
              "value": "hxxl",
              "label": "t:sections.all.heading_size.options__5.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "select",
          "id": "title_tag",
          "label": "Tag titolo",
          "options": [
            { "label": "H1", "value": "h1" },
            { "label": "H2", "value": "h2" },
            { "label": "H3", "value": "h3" },
            { "label": "H4", "value": "h4" },
            { "label": "H5", "value": "h5" },
            { "label": "H6", "value": "h6" },
            { "label": "Paragrafo", "value": "p" },
            { "label": "Div", "value": "div" }
          ],
          "default": "div"
        },
        {
          "type": "text",
          "id": "title_custom_class",
          "label": "Classe CSS personalizzata titolo",
          "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
        }
      ]
    },
    {
      "type": "caption",
      "name": "t:sections.rich-text.blocks.caption.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "default": "t:sections.rich-text.blocks.caption.settings.text.default",
          "label": "t:sections.rich-text.blocks.caption.settings.text.label"
