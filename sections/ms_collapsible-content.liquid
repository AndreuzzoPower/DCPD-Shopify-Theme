{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign acc_style = section.settings.accordion_style | default: 'standard'
  assign show_image = section.settings.show_image
  assign has_image = false
  if section.settings.image != blank and show_image
    assign has_image = true
  endif
-%}

{%- style -%}
  {%- if section.settings.image_border_radius > 0 and has_image -%}
    #section-{{ section.id }} .collapsible-content__media {
      border-radius: {{ section.settings.image_border_radius }}px;
      overflow: hidden;
    }
  {%- endif -%}

  /* Align summary items vertically */
  #section-{{ section.id }} .accordion summary {
    align-items: center;
  }

  {%- if acc_style == 'bordered' -%}
    #section-{{ section.id }} .accordion {
      border: 1px solid rgba(var(--color-foreground), 0.12);
      border-radius: 8px;
      margin-top: 0;
      margin-bottom: 0.8rem;
      overflow: hidden;
    }
    #section-{{ section.id }} .accordion:last-child {
      margin-bottom: 0;
    }
    #section-{{ section.id }} .accordion summary {
      border-top: none;
      padding: 1.5rem;
    }
    #section-{{ section.id }} .accordion .accordion__content {
      padding: 0 1.5rem 1.5rem;
    }

  {%- elsif acc_style == 'boxed' -%}
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper {
      border: 1px solid rgba(var(--color-foreground), 0.12);
      border-radius: 8px;
      overflow: hidden;
    }
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper .accordion {
      margin-top: 0;
      border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    }
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper .accordion:first-child {
      border-top: none;
    }
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper .accordion:last-child {
      border-bottom: none;
    }
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper .accordion summary {
      border-top: none;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    #section-{{ section.id }} .ms-collapsible__accordion-wrapper .accordion .accordion__content {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

  {%- elsif acc_style == 'filled' -%}
    #section-{{ section.id }} .accordion {
      background-color: rgba(var(--color-foreground), 0.04);
      border: none;
      border-radius: 8px;
      margin-top: 0;
      margin-bottom: 0.8rem;
      overflow: hidden;
    }
    #section-{{ section.id }} .accordion:last-child {
      margin-bottom: 0;
    }
    #section-{{ section.id }} .accordion summary {
      border-top: none;
      padding: 1.5rem;
    }
    #section-{{ section.id }} .accordion .accordion__content {
      padding: 0 1.5rem 1.5rem;
    }

  {%- elsif acc_style == 'minimal' -%}
    #section-{{ section.id }} .accordion {
      border: none;
      margin-top: 0;
    }
    #section-{{ section.id }} .accordion summary {
      border-top: none;
    }
  {%- endif -%}
{%- endstyle -%}

{%- render 'ms_mobile-padding' -%}

<div class="color-{{ section.settings.color_scheme }} gradient" id="section-{{ section.id }}">
  <div class="{{ sw_class }} isolate">
    <div class="{% if has_image %}page-width{% else %}collapsible-content-wrapper-narrow{% endif %}">
      <div class="grid grid--1-col{% if has_image %} grid--2-col-tablet{% endif %} collapsible-content__grid{% if section.settings.desktop_layout == 'image_second' %} collapsible-content__grid--reverse{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if has_image -%}
          <div class="grid__item collapsible-content__grid-item">
            <div
              class="collapsible-content__media collapsible-content__media--{{ section.settings.image_ratio }} media global-media-settings gradient"
              {% if section.settings.image_ratio == 'adapt' %}
                style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
              {% endif %}
            >
              {%- capture sizes -%}
                (min-width: {{ settings.page_width }}px) calc({{ settings.page_width }}px / 2 - 50px),
                (min-width: 750px) calc(50vw - 65px),
                calc(100vw - 30px)
              {%- endcapture -%}
              {{
                section.settings.image
                | image_url: width: 3200
                | image_tag:
                  sizes: sizes,
                  widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200'
              }}
            </div>
          </div>
        {%- endif -%}
        <div class="grid__item">
          <div class="ms-collapsible__accordion-wrapper">
            {%- for block in section.blocks -%}
              {%- if block.type == 'collapsible_row' -%}
                <div
                  class="accordion"
                  {{ block.shopify_attributes }}
                  role="list"
                >
                  <details
                    id="Details-{{ block.id }}-{{ section.id }}"
                    {% if section.settings.open_first_collapsible_row and forloop.first %}
                      open
                    {% endif %}
                    role="listitem"
                  >
                    <summary id="Summary-{{ block.id }}-{{ section.id }}">
                      <span class="summary__title">
                        <span class="accordion__title inline-richtext {{ section.settings.heading_size }}">
                          {{ block.settings.heading | default: block.settings.page.title | escape }}
                        </span>
                      </span>
                      {%- if block.settings.custom_icon != blank -%}
                        {%- render 'ms_icon', icon: block.settings.custom_icon, class: 'icon-caret' -%}
                      {%- elsif section.settings.accordion_icon != blank -%}
                        {%- render 'ms_icon', icon: section.settings.accordion_icon, class: 'icon-caret' -%}
                      {%- else -%}
                        {%- render 'ms_icon', icon: settings.ms_icon_caret, class: 'icon-caret' -%}
                      {%- endif -%}
                    </summary>
                    <div
                      class="accordion__content rte"
                      id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}"
                      role="region"
                      aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"
                    >
                      {{ block.settings.row_content }}
                      {{ block.settings.page.content }}
                    </div>
                  </details>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Collapsible Content",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione colori sezione",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Accordion"
    },
    {
      "type": "select",
      "id": "accordion_style",
      "label": "Stile accordion",
      "options": [
        { "value": "standard", "label": "Standard (linee separatorie)" },
        { "value": "bordered", "label": "Bordi attorno a ogni riga" },
        { "value": "boxed", "label": "Contenitore unico" },
        { "value": "filled", "label": "Sfondo per ogni riga" },
        { "value": "minimal", "label": "Minimale (nessun separatore)" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Dimensione intestazione",
      "options": [
        { "value": "h6", "label": "Extra piccola" },
        { "value": "h5", "label": "Piccola" },
        { "value": "h4", "label": "Media" },
        { "value": "h3", "label": "Grande" },
        { "value": "h2", "label": "Extra grande" }
      ],
      "default": "h4"
    },
    {
      "type": "text",
      "id": "accordion_icon",
      "label": "Icona apri/chiudi (predefinita)",
      "info": "Sostituisce il caret predefinito a destra di ogni riga. File .svg = asset del tema (es. icon-arrow.svg), altrimenti classe libreria icone (es. fa-solid fa-chevron-down). Vuoto = usa il caret del tema. Ruota di 180° quando la riga è aperta."
    },
    {
      "type": "checkbox",
      "id": "open_first_collapsible_row",
      "default": false,
      "label": "Apri il primo elemento"
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Visualizza immagine",
      "info": "Disattiva per nascondere l'immagine senza rimuoverla."
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adatta all'immagine" },
        { "value": "small", "label": "Piccola" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "adapt",
      "label": "Proporzioni immagine"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Raggio bordi immagine"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "options": [
        { "value": "image_first", "label": "Immagine prima" },
        { "value": "image_second", "label": "Immagine dopo" }
      ],
      "default": "image_second",
      "label": "Posizione immagine desktop"
    }
  ],
  "blocks": [
    {
      "type": "collapsible_row",
      "name": "Riga espandibile",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Riga espandibile",
          "label": "Intestazione"
        },
        {
          "type": "text",
          "id": "custom_icon",
          "label": "Icona apri/chiudi personalizzata",
          "info": "Se compilato, sovrascrive l'icona predefinita della sezione solo per questa riga. File .svg o classe libreria icone."
        },
        {
          "type": "richtext",
          "id": "row_content",
          "label": "Contenuto riga"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Contenuto da pagina"
        }
      ]
    },
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 100
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 100
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 80
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 80
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_padding_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 60
        },
        {
          "type": "range",
          "id": "section_padding_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 60
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_margin_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_margin_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_margin_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "BG Image"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "BG Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Collapsible Content",
      "category": "Contenuti",
      "blocks": [
        { "type": "collapsible_row" },
        { "type": "collapsible_row" },
        { "type": "collapsible_row" },
        { "type": "collapsible_row" }
      ]
    }
  ]
}
{% endschema %}
