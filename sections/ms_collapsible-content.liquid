            { "value": "shirt", "label": "Camicia" },
            { "value": "shoe", "label": "Scarpa" },
            { "value": "silhouette", "label": "Silhouette" },
            { "value": "snowflake", "label": "Fiocco di neve" },
            { "value": "star", "label": "Stella" },
