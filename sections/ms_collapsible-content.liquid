{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase
-%}

{%- render 'ms_mobile-padding' -%}

<div class="color-{{ section.settings.color_scheme }} gradient" id="section-{{ section.id }}">
  <div class="collapsible-content collapsible-{{ section.settings.layout }}-layout isolate{% if section.settings.layout == 'section' %} {{ sw_class }}{% elsif section.settings.layout == 'none' %} content-container content-container--full-width{% endif %}">
    <div class="collapsible-content__wrapper{% if section.settings.layout == 'section' %} content-container color-{{ section.settings.container_color_scheme }} gradient{% endif %}">
      <div class="{% if section.settings.image == blank %}collapsible-content-wrapper-narrow{% else %}{{ sw_class }}{% endif %}">
        <div class="grid grid--1-col grid--2-col-tablet collapsible-content__grid{% if section.settings.desktop_layout == 'image_second' %} collapsible-content__grid--reverse{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {%- if section.settings.image != blank -%}
            <div class="grid__item collapsible-content__grid-item">
              <div
                class="collapsible-content__media collapsible-content__media--{{ section.settings.image_ratio }} media global-media-settings gradient"
                {% if section.settings.image_ratio == 'adapt' %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- liquid
                  assign padding_multiplier = 1
                  if section.settings.layout == 'section'
                    assign padding_multiplier = 2
                  endif
                  assign desktop_tablet_padding = 100 | times: padding_multiplier | append: 'px'
                  assign mobile_padding = 30 | times: padding_multiplier | append: 'px'
                -%}
                {%- capture sizes -%}
                  (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ desktop_tablet_padding }}) / 2),
                  (min-width: 750px) calc((100vw - {{ desktop_tablet_padding }}) / 2),
                  calc(100vw - {{ mobile_padding }})
                {%- endcapture -%}
                {{
                  section.settings.image
                  | image_url: width: 3200
                  | image_tag:
                    sizes: sizes,
                    widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200'
                }}
              </div>
            </div>
          {% endif %}
          <div class="grid__item">
            {%- for block in section.blocks -%}
              {% if block.type == 'collapsible_row' %}
                <div
                  class="accordion{% if section.settings.layout == 'row' %} content-container color-{{ section.settings.container_color_scheme }} gradient{% endif %}"
                  {{ block.shopify_attributes }}
                  role="list"
                >
                  <details
                    id="Details-{{ block.id }}-{{ section.id }}"
                    {% if section.settings.open_first_collapsible_row and forloop.first %}
                      open
                    {% endif %}
                    role="listitem"
                  >
                    <summary id="Summary-{{ block.id }}-{{ section.id }}">
                      {% render 'icon-accordion', icon: block.settings.icon, custom_icon: block.settings.custom_icon %}
                      <div class="accordion__title inline-richtext h4">
                        {{ block.settings.heading | default: block.settings.page.title | escape }}
                      </div>
                      {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
                    </summary>
                    <div
                      class="accordion__content rte"
                      id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}"
                      role="region"
                      aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"
                    >
                      {{ block.settings.row_content }}
                      {{ block.settings.page.content }}
                    </div>
                  </details>
                </div>
              {% endif %}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Collapsible Content",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposizione contenuto",
      "options": [
        { "value": "none", "label": "Nessun contenitore" },
        { "value": "row", "label": "Spazio tra le righe" },
        { "value": "section", "label": "Contenitore sezione" }
      ],
      "default": "none"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione colori sezione",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "container_color_scheme",
      "label": "Combinazione colori contenitore",
      "default": "scheme-2"
    },
    {
      "type": "checkbox",
      "id": "open_first_collapsible_row",
      "default": false,
      "label": "Apri il primo elemento"
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adatta all'immagine" },
        { "value": "small", "label": "Piccola" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "adapt",
      "label": "Proporzioni immagine"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "options": [
        { "value": "image_first", "label": "Immagine prima" },
        { "value": "image_second", "label": "Immagine dopo" }
      ],
      "default": "image_second",
      "label": "Posizione immagine desktop"
    }
  ],
  "blocks": [
    {
      "type": "collapsible_row",
      "name": "Riga espandibile",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Riga espandibile",
          "label": "Intestazione"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "Nessuna" },
            { "value": "apple", "label": "Mela" },
            { "value": "banana", "label": "Banana" },
            { "value": "bottle", "label": "Bottiglia" },
            { "value": "box", "label": "Scatola" },
            { "value": "carrot", "label": "Carota" },
            { "value": "chat_bubble", "label": "Fumetto" },
            { "value": "check_mark", "label": "Segno di spunta" },
            { "value": "clipboard", "label": "Appunti" },
            { "value": "dairy", "label": "Latticini" },
            { "value": "dairy_free", "label": "Senza lattosio" },
            { "value": "dryer", "label": "Asciugatrice" },
            { "value": "eye", "label": "Occhio" },
            { "value": "fire", "label": "Fuoco" },
            { "value": "gluten_free", "label": "Senza glutine" },
            { "value": "heart", "label": "Cuore" },
            { "value": "iron", "label": "Ferro da stiro" },
            { "value": "leaf", "label": "Foglia" },
            { "value": "leather", "label": "Pelle" },
            { "value": "lightning_bolt", "label": "Fulmine" },
            { "value": "lipstick", "label": "Rossetto" },
            { "value": "lock", "label": "Lucchetto" },
            { "value": "map_pin", "label": "Segnaposto" },
            { "value": "nut_free", "label": "Senza frutta a guscio" },
            { "value": "pants", "label": "Pantaloni" },
            { "value": "paw_print", "label": "Zampa" },
            { "value": "pepper", "label": "Peperoncino" },
            { "value": "perfume", "label": "Profumo" },
            { "value": "plane", "label": "Aereo" },
            { "value": "plant", "label": "Pianta" },
            { "value": "price_tag", "label": "Cartellino prezzo" },
            { "value": "question_mark", "label": "Punto interrogativo" },
            { "value": "recycle", "label": "Riciclo" },
            { "value": "return", "label": "Reso" },
