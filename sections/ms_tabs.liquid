{{ 'ms_tabs.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign tab_style = section.settings.tab_style | default: 'underline'
  assign tab_align = section.settings.tab_alignment | default: 'start'
  assign mobile_behavior = section.settings.mobile_behavior | default: 'tabs'

  assign tab_blocks = section.blocks | where: 'type', 'tab'
-%}

{%- render 'ms_mobile-padding' -%}

<ms-tabs
  class="ms-tabs ms-tabs--{{ tab_style }}{% if mobile_behavior == 'accordion' %} ms-tabs--mobile-accordion{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="{{ sw_class }} isolate">

      {%- if section.settings.heading != blank -%}
        {%- assign title_tag = section.settings.title_tag | default: 'h2' -%}
        {%- assign title_classes = section.settings.heading_size | default: 'h1' -%}
        {%- if section.settings.title_custom_class != blank -%}
          {%- assign title_classes = title_classes | append: ' ' | append: section.settings.title_custom_class -%}
        {%- endif -%}
        <{{ title_tag }} class="ms-tabs__heading {{ title_classes }}">
          {{- section.settings.heading | escape -}}
        </{{ title_tag }}>
      {%- endif -%}

      {%- comment -%} Desktop / default tabs {%- endcomment -%}
      <div class="ms-tabs__desktop">
        {%- if tab_blocks.size > 0 -%}
          <div
            class="ms-tabs__tablist{% if tab_align == 'center' %} ms-tabs__tablist--center{% elsif tab_align == 'end' %} ms-tabs__tablist--end{% elsif tab_align == 'stretch' %} ms-tabs__tablist--stretch{% endif %}"
            role="tablist"
            aria-label="{{ section.settings.heading | default: 'Tabs' | escape }}"
            aria-orientation="horizontal"
          >
            {%- for block in tab_blocks -%}
              <button
                class="ms-tabs__tab"
                role="tab"
                id="Tab-{{ block.id }}-{{ section.id }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="Panel-{{ block.id }}-{{ section.id }}"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                data-tab-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.tab_icon != blank -%}
                  <span class="ms-tabs__tab-icon" aria-hidden="true">
                    {%- render 'ms_icon', icon: block.settings.tab_icon -%}
                  </span>
                {%- endif -%}
                {{ block.settings.heading | default: 'Tab' | escape }}
              </button>
            {%- endfor -%}
          </div>

          <div class="ms-tabs__panels">
            {%- for block in tab_blocks -%}
              <div
                class="ms-tabs__panel"
                role="tabpanel"
                id="Panel-{{ block.id }}-{{ section.id }}"
                aria-labelledby="Tab-{{ block.id }}-{{ section.id }}"
                data-panel-index="{{ forloop.index0 }}"
                {% unless forloop.first %}hidden{% endunless %}
                tabindex="0"
              >
                <div class="ms-tabs__panel-content rte">
                  {{ block.settings.content }}
                  {{ block.settings.page.content }}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Mobile accordion fallback {%- endcomment -%}
      {%- if mobile_behavior == 'accordion' and tab_blocks.size > 0 -%}
        <div class="ms-tabs__accordion">
          {%- for block in tab_blocks -%}
            <div class="accordion" {{ block.shopify_attributes }}>
              <details
                id="TabAccordion-{{ block.id }}-{{ section.id }}"
                {% if section.settings.open_first_tab and forloop.first %}open{% endif %}
              >
                <summary id="TabSummary-{{ block.id }}-{{ section.id }}">
                  <span class="summary__title">
                    {%- if block.settings.tab_icon != blank -%}
                      <span class="ms-tabs__tab-icon" aria-hidden="true" style="margin-right:0.8rem">
                        {%- render 'ms_icon', icon: block.settings.tab_icon -%}
                      </span>
                    {%- endif -%}
                    <span class="accordion__title inline-richtext {{ section.settings.accordion_heading_size }}">
                      {{ block.settings.heading | default: 'Tab' | escape }}
                    </span>
                  </span>
                  {%- render 'ms_icon', icon: settings.ms_icon_caret, class: 'icon-caret' -%}
                </summary>
                <div
                  class="accordion__content rte"
                  id="TabContent-{{ block.id }}-{{ section.id }}"
                  role="region"
                  aria-labelledby="TabSummary-{{ block.id }}-{{ section.id }}"
                >
                  {{ block.settings.content }}
                  {{ block.settings.page.content }}
                </div>
              </details>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</ms-tabs>

{%- render 'ms_section-style' -%}

<script src="{{ 'ms_tabs.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign sd_faq_items = ''
  for block in tab_blocks
    assign sd_q = block.settings.heading | escape
    assign sd_a = block.settings.content | default: block.settings.page.content | strip_html | strip | truncate: 5000
    if sd_q != blank and sd_a != blank
      unless sd_faq_items == ''
        assign sd_faq_items = sd_faq_items | append: '|||'
      endunless
      assign sd_faq_items = sd_faq_items | append: sd_q | append: '^^^' | append: sd_a
    endif
  endfor
  assign sd_faq_arr = sd_faq_items | split: '|||'
-%}
{%- if sd_faq_arr.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for sd_faq in sd_faq_arr -%}
        {%- assign sd_parts = sd_faq | split: '^^^' -%}
        {
          "@type": "Question",
          "name": {{ sd_parts[0] | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ sd_parts[1] | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "MS Tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione colori sezione",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Dimensione titolo",
      "options": [
        { "label": "Piccola", "value": "h2" },
        { "label": "Media", "value": "h1" },
        { "label": "Grande", "value": "h0" },
        { "label": "Extra grande", "value": "hxl" },
        { "label": "Extra extra grande", "value": "hxxl" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "select",
      "id": "tab_style",
      "label": "Stile tabs",
      "options": [
        { "value": "underline", "label": "Sottolineato" },
        { "value": "bordered", "label": "Bordato" },
        { "value": "pill", "label": "Pill (arrotondato)" },
        { "value": "filled", "label": "Sfondo" },
        { "value": "boxed", "label": "Riquadrato" }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "tab_alignment",
      "label": "Allineamento tabs",
      "options": [
        { "value": "start", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "end", "label": "Destra" },
        { "value": "stretch", "label": "Esteso (uguale larghezza)" }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "mobile_behavior",
      "label": "Comportamento su mobile",
      "options": [
        { "value": "tabs", "label": "Tabs (invariato)" },
        { "value": "accordion", "label": "Accordion" }
      ],
      "default": "tabs",
      "info": "Su schermi sotto i 750px, i tabs possono trasformarsi in accordion per una migliore usabilita."
    },
    {
      "type": "checkbox",
      "id": "open_first_tab",
      "label": "Apri il primo accordion su mobile",
      "default": true,
      "info": "Solo se il comportamento mobile e impostato su Accordion."
    },
    {
      "type": "select",
      "id": "accordion_heading_size",
      "label": "Dimensione titolo accordion mobile",
      "options": [
        { "value": "h6", "label": "Extra piccola" },
        { "value": "h5", "label": "Piccola" },
        { "value": "h4", "label": "Media" },
        { "value": "h3", "label": "Grande" },
        { "value": "h2", "label": "Extra grande" }
      ],
      "default": "h4",
      "info": "Dimensione visiva dei titoli nella vista accordion su mobile."
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titolo tab",
          "default": "Tab"
        },
        {
          "type": "text",
          "id": "tab_icon",
          "label": "Icona tab",
          "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Vuoto = nessuna icona."
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenuto",
          "default": "<p>Contenuto del tab.</p>"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Contenuto da pagina",
          "info": "Se selezionata, il contenuto della pagina viene aggiunto dopo il richtext."
        }
      ]
    },
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 100
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 100
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 80
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 80
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_padding_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 60
        },
        {
          "type": "range",
          "id": "section_padding_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 60
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_margin_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_margin_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_margin_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "BG Image"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "BG Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Tabs",
      "category": "Contenuti",
      "blocks": [
        { "type": "tab", "settings": { "heading": "Tab 1", "content": "<p>Contenuto del primo tab.</p>" } },
        { "type": "tab", "settings": { "heading": "Tab 2", "content": "<p>Contenuto del secondo tab.</p>" } },
        { "type": "tab", "settings": { "heading": "Tab 3", "content": "<p>Contenuto del terzo tab.</p>" } }
      ]
    }
  ]
}
{% endschema %}
