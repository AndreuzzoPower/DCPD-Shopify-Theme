{%- comment -%}
  Section: ms_collection-list.liquid
  Descrizione: Elenco collezioni — griglia o carosello su desktop e mobile.
  Adeguata alle direttive MS (v7).
{%- endcomment -%}

{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'ms_collection-list.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
    ── Section Width ──
  endcomment
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif

  assign is_full_width = false
  if sw == 'full_width'
    assign is_full_width = true
  endif

  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  comment
    ── Conta solo i blocchi collezione (esclude padding/margin/bg) ──
  endcomment
  assign collection_blocks_count = 0
  for block in section.blocks
    if block.type == 'featured_collection'
      assign collection_blocks_count = collection_blocks_count | plus: 1
    endif
  endfor

  comment
    ── Slider / Grid ──
  endcomment
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0

  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and collection_blocks_count > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and collection_blocks_count > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif

  comment
    ── Title tag e classe ──
  endcomment
  assign title_tag = section.settings.title_tag | default: 'h2'
  assign title_base_class = 'collection-list-title inline-richtext'
  assign title_classes = title_base_class | append: ' ' | append: section.settings.heading_size
  if section.settings.title_custom_class != blank
    assign title_classes = title_classes | append: ' ' | append: section.settings.title_custom_class
  endif

  assign columns = collection_blocks_count
  if columns > 3
    assign columns = 3
  endif

  comment
    ── Card layout helpers ──
  endcomment
  assign link_pos = section.settings.card_link_position | default: 'below'
  assign link_style = section.settings.card_link_style | default: 'link'
  assign link_align = section.settings.card_link_alignment | default: 'left'
  assign is_overlay = false
  if link_pos contains 'overlay'
    assign is_overlay = true
  endif
-%}

{%- comment -%} ── Stili dinamici (dipendono dai settings) ── {%- endcomment -%}
{%- style -%}
  /* Title & description alignment */
  {%- if section.settings.title_alignment != 'left' -%}
    #section-{{ section.id }} .ms-cl-header {
      text-align: {{ section.settings.title_alignment }};
    }
  {%- endif -%}

  /* Grid alignment */
  {%- if section.settings.grid_alignment != 'left' -%}
    #section-{{ section.id }} .collection-list:not(.slider) {
      {%- if section.settings.grid_alignment == 'center' -%}
        justify-content: center;
      {%- elsif section.settings.grid_alignment == 'right' -%}
        justify-content: flex-end;
      {%- endif -%}
    }
    #section-{{ section.id }} .collection-list:not(.slider) > .grid__item {
      flex-grow: 0;
    }
  {%- endif -%}

  /* Card border-radius */
  {%- if section.settings.card_border_radius > 0 -%}
    #section-{{ section.id }} .card-wrapper {
      border-radius: {{ section.settings.card_border_radius }}px;
      overflow: hidden;
    }
    #section-{{ section.id }} .card,
    #section-{{ section.id }} .card__inner {
      border-radius: {{ section.settings.card_border_radius }}px;
    }
  {%- endif -%}

  /* Card shadow */
  {%- if section.settings.card_shadow == 'light' -%}
    #section-{{ section.id }} .card-wrapper { box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08); }
  {%- elsif section.settings.card_shadow == 'medium' -%}
    #section-{{ section.id }} .card-wrapper { box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12); }
  {%- elsif section.settings.card_shadow == 'strong' -%}
    #section-{{ section.id }} .card-wrapper { box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18); }
  {%- endif -%}

  /* Card background */
  {%- if section.settings.card_bg_color != blank -%}
    #section-{{ section.id }} .card {
      background-color: {{ section.settings.card_bg_color }};
    }
  {%- endif -%}

  /* Link area padding */
  {%- if section.settings.card_link_padding_top != 0
      or section.settings.card_link_padding_right != 0
      or section.settings.card_link_padding_bottom != 0
      or section.settings.card_link_padding_left != 0 -%}
    #section-{{ section.id }} .card__content .card__information {
      padding: {{ section.settings.card_link_padding_top }}px {{ section.settings.card_link_padding_right }}px {{ section.settings.card_link_padding_bottom }}px {{ section.settings.card_link_padding_left }}px;
    }
  {%- endif -%}

  /* Overlay styles */
  {%- if is_overlay -%}
    {%- if section.settings.card_overlay_text_color != blank -%}
      #section-{{ section.id }}.ms-cl--overlay .card--media > .card__content,
      #section-{{ section.id }}.ms-cl--overlay .card--media > .card__content a {
        color: {{ section.settings.card_overlay_text_color }};
      }
    {%- endif -%}
    {%- if section.settings.card_overlay_bg_color != blank -%}
      {%- assign overlay_alpha = section.settings.card_overlay_bg_opacity | times: 0.01 -%}
      #section-{{ section.id }}.ms-cl--overlay .card--media > .card__content {
        background-color: {{ section.settings.card_overlay_bg_color | color_modify: 'alpha', overlay_alpha }};
        padding: 1rem;
      }
    {%- endif -%}
  {%- endif -%}
{%- endstyle -%}

<div
  class="color-{{ section.settings.color_scheme }} gradient{% if section.settings.card_image_round %} ms-cl--round-images{% endif %}{% if link_style == 'pill' %} ms-cl--link-pill{% elsif link_style == 'button' %} ms-cl--link-button{% endif %}{% if is_overlay %} ms-cl--overlay ms-cl--{{ link_pos }}{% endif %}{% if link_align != 'left' %} ms-cl--align-link-{{ link_align }}{% endif %}"
  id="section-{{ section.id }}"
>
  {%- if sw_class != blank -%}<div class="{{ sw_class }}">{%- endif -%}
  <div class="collection-list-wrapper isolate{% if show_mobile_slider == false and show_desktop_slider == false %} page-width-tablet{% endif %}{% if section.settings.title == blank and section.settings.description == blank %} no-heading{% endif %}">
    {%- unless section.settings.title == blank and section.settings.description == blank -%}
      <div class="ms-cl-header title-wrapper-with-link{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %} title-wrapper--no-top-margin">
        {%- unless section.settings.title == blank -%}
          <{{ title_tag }}
            id="SectionHeading-{{ section.id }}"
            class="{{ title_classes }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          >
            {{ section.settings.title }}
          </{{ title_tag }}>
        {%- endunless -%}

        {%- unless section.settings.description == blank -%}
          <div class="ms-cl-description rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.description }}
          </div>
        {%- endunless -%}
      </div>
    {%- endunless -%}

    <slider-component
      data-autoplay="{{ section.settings.enable_autoplay }}"
      data-speed="{{ section.settings.autoplay_speed }}000"
      class="slider-mobile-gutter{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if is_full_width %} slider-component-full-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    >
      <ul
        class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %} collection-list--{{ collection_blocks_count }}-items"
        id="Slider-{{ section.id }}"
        role="list"
        aria-label="{{ section.settings.title | default: 'Elenco collezioni' | strip_html | escape }}"
      >
        {%- assign slide_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'featured_collection' -%}
            {%- assign slide_index = slide_index | plus: 1 -%}
            <li
              id="Slide-{{ section.id }}-{{ slide_index }}"
              class="collection-list__item grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if block.settings.custom_image == blank and block.settings.collection.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ slide_index }};"
              {% endif %}
            >
              {%- assign placeholder_image_index = slide_index | minus: 1 | modulo: 4 | plus: 1 -%}
              {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
              {% render 'card-collection',
                card_collection: block.settings.collection,
                media_aspect_ratio: section.settings.image_ratio,
                columns: columns,
                placeholder_image: placeholder_image,
                custom_image: block.settings.custom_image,
                custom_label: block.settings.custom_label,
                show_icon: section.settings.card_show_icon,
                custom_icon: section.settings.card_custom_icon
              %}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons{% if show_desktop_slider == false %} large-up-hide{% endif %}{% if show_mobile_slider == false %} medium-hide small-hide{% endif %}">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ collection_blocks_count }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
          </button>
        </div>
      {%- endif -%}
    </slider-component>

  </div>
  {%- if sw_class != blank -%}</div>{%- endif -%}
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Elenco collezioni",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 18,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout sezione"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "header",
      "content": "Titolo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.collection-list.settings.title.default",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Testo sotto il titolo"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Allineamento titolo e testo",
      "default": "left",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ]
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "grid_alignment",
      "label": "Allineamento griglia",
      "info": "Allineamento degli elementi quando non riempiono tutte le colonne. Applicato solo in modalita griglia.",
      "default": "left",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Abilita carosello",
      "default": false,
      "info": "Se disattivato, le collezioni verranno visualizzate in una griglia su desktop."
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Abilita autoplay",
      "default": false,
      "info": "Attiva la rotazione automatica delle slide. Funziona quando il carosello e attivo."
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3,
      "unit": "s",
      "label": "Velocita autoplay (secondi)",
      "info": "Tempo tra una slide e la successiva."
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "t:sections.collection-list.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.collection-list.settings.columns_mobile.options__2.label" }
      ],
      "default": "1",
      "label": "t:sections.collection-list.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.collection-list.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "Stile card"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.collection-list.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.collection-list.settings.image_ratio.options__2.label" },
        { "value": "square", "label": "t:sections.collection-list.settings.image_ratio.options__3.label" }
      ],
      "default": "square",
      "label": "t:sections.collection-list.settings.image_ratio.label"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Raggio bordi (border-radius)"
    },
    {
      "type": "select",
      "id": "card_shadow",
      "label": "Ombra card",
      "default": "none",
      "options": [
        { "value": "none", "label": "Nessuna" },
        { "value": "light", "label": "Leggera" },
        { "value": "medium", "label": "Media" },
        { "value": "strong", "label": "Forte" }
      ]
    },
    {
      "type": "checkbox",
      "id": "card_image_round",
      "default": false,
      "label": "Immagini rotonde",
      "info": "Ritaglia le immagini in forma circolare (1:1)."
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Sfondo card"
    },
    {
      "type": "header",
      "content": "Link card"
    },
    {
      "type": "select",
      "id": "card_link_style",
      "label": "Stile link",
      "default": "link",
      "options": [
        { "value": "link", "label": "Link (default)" },
        { "value": "button", "label": "Bottone" },
        { "value": "pill", "label": "Pill" }
      ]
    },
    {
      "type": "select",
      "id": "card_link_alignment",
      "label": "Allineamento link",
      "default": "left",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "card_show_icon",
      "default": true,
      "label": "Mostra icona nel link"
    },
    {
      "type": "text",
      "id": "card_custom_icon",
      "label": "Icona personalizzata",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-arrow-right). Se compilato, sovrascrive la freccia di default."
    },
    {
      "type": "select",
      "id": "card_link_position",
      "label": "Posizione link",
      "default": "below",
      "options": [
        { "value": "below", "label": "Sotto l'immagine" },
        { "value": "overlay-top", "label": "Overlay — in alto" },
        { "value": "overlay-center", "label": "Overlay — al centro" },
        { "value": "overlay-bottom", "label": "Overlay — in basso" }
      ],
      "info": "La modalita overlay posiziona il testo sopra l'immagine."
    },
    {
      "type": "header",
      "content": "Padding area link"
    },
    {
      "type": "range",
      "id": "card_link_padding_top",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "card_link_padding_right",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Padding right"
    },
    {
      "type": "range",
      "id": "card_link_padding_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "range",
      "id": "card_link_padding_left",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Padding left"
    },
    {
      "type": "header",
      "content": "Overlay (colori)"
    },
    {
      "type": "color",
      "id": "card_overlay_text_color",
      "label": "Colore testo overlay",
      "default": "#ffffff",
      "info": "Applicato solo quando la posizione del link e in overlay."
    },
    {
      "type": "color",
      "id": "card_overlay_bg_color",
      "label": "Sfondo overlay",
      "default": "#000000",
      "info": "Colore di sfondo dietro il testo in overlay."
    },
    {
      "type": "range",
      "id": "card_overlay_bg_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%",
      "label": "Opacita sfondo overlay"
    },
    {
      "type": "header",
      "content": "Colori"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "t:sections.collection-list.blocks.featured_collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Immagine personalizzata",
          "info": "Se presente, sovrascrive l'immagine di default della collezione."
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Label personalizzata",
          "info": "Se compilata, sovrascrive il nome della collezione nel link/bottone."
        }
      ]
    },
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Large / Desktop"
        },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding Top",
          "unit": "px",
          "default": 100
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding Bottom",
          "unit": "px",
          "default": 100
        },
        {
          "type": "header",
          "content": "Tablet"
        },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0,
          "max": 150,
          "step": 5,
          "label": "Padding Top",
          "unit": "px",
          "default": 80
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0,
          "max": 150,
