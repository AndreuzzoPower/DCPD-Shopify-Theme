{%- comment -%}
  Section: ms_featured-blog.liquid
  Descrizione: Blog in evidenza — mostra articoli dal blog selezionato in un carosello.
               Se nessun blog è selezionato ma è impostato un "Menu blog",
               mostra gli ultimi articoli da tutti i blog presenti nel menu,
               ordinati per data di pubblicazione (più recenti prima).
  Adeguata alle direttive MS (v7).
{%- endcomment -%}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}
{{ 'ms_featured-blog.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
    ── Section Width ──
  endcomment
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif

  assign is_full_width = false
  if sw == 'full_width'
    assign is_full_width = true
  endif

  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  comment
    ── Raccolta articoli ──
    1. Blog selezionato → usa quello.
    2. Nessun blog ma menu blog impostato → raccoglie gli articoli
       da tutti i blog presenti nel menu, ordinati per data DESC.
    3. Nessuno dei due → messaggio "Nessun articolo".
    Nota: in Shopify Liquid, `blogs` NON è iterabile con for.
    Si usa un link_list (menu) contenente link ai blog desiderati.
  endcomment
  assign has_selected_blog = false
  assign has_multi_blog = false
  assign all_articles = '' | split: ''
  assign total_articles_count = 0

  if section.settings.blog != blank
    assign has_selected_blog = true
    assign total_articles_count = section.settings.blog.articles_count
  elsif section.settings.blogs_menu != blank
    assign _menu = linklists[section.settings.blogs_menu]
    if _menu != blank and _menu.links.size > 0
      for link in _menu.links
        if link.type == 'blog_link'
          assign all_articles = all_articles | concat: link.object.articles
        endif
      endfor
      assign all_articles = all_articles | sort: 'published_at' | reverse
      assign total_articles_count = all_articles.size
      if total_articles_count > 0
        assign has_multi_blog = true
      endif
    endif
  endif

  assign posts_displayed = total_articles_count
  assign posts_exceed_limit = false
  if section.settings.post_limit <= total_articles_count
    assign posts_exceed_limit = true
    assign posts_displayed = section.settings.post_limit
  endif

  comment
    ── Slider / Grid ──
    Calcola se attivare lo slider su desktop e/o mobile.
    Pattern identico a ms_products-from-metafield.liquid.
  endcomment
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0

  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and posts_displayed > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and posts_displayed > columns_desktop_int
    assign show_desktop_slider = true
  endif

  comment
    ── Title tag e classe ──
  endcomment
  assign title_tag = section.settings.title_tag | default: 'h2'
  assign title_base_class = 'ms-fb__title blog__title inline-richtext'
  assign title_classes = title_base_class | append: ' ' | append: section.settings.heading_size
  if section.settings.title_custom_class != blank
    assign title_classes = title_classes | append: ' ' | append: section.settings.title_custom_class
  endif

  comment
    ── Button style + sizing ──
  endcomment
  assign btn_style = section.settings.button_style | default: 'button'
  assign btn_size_class = ''
-%}

{%- capture btn_size_class -%}{%- render 'ms_button_size', size: section.settings.button_size -%}{%- endcapture -%}

{%- comment -%} ── Stili dinamici card (dipendono dai settings) ── {%- endcomment -%}
{%- style -%}
  /* Bordi card */
  #section-{{ section.id }} .article-card-wrapper {
    {%- if section.settings.card_border_position == 'all' -%}
      border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    {%- elsif section.settings.card_border_position == 'bottom' -%}
      border-bottom: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    {%- endif -%}
    {%- if section.settings.card_border_radius > 0 -%}
      border-radius: {{ section.settings.card_border_radius }}px;
    {%- endif -%}
    {%- if section.settings.card_shadow == 'light' -%}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {%- elsif section.settings.card_shadow == 'medium' -%}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    {%- elsif section.settings.card_shadow == 'strong' -%}
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
    {%- endif -%}
    overflow: hidden;
  }

  /* Padding area info */
  #section-{{ section.id }} .card__information {
    padding-top: {{ section.settings.card_info_padding_top }}px !important;
    padding-right: {{ section.settings.card_info_padding_right }}px !important;
    padding-bottom: {{ section.settings.card_info_padding_bottom }}px !important;
    padding-left: {{ section.settings.card_info_padding_left }}px !important;
  }

  /* Info verticale */
  {%- if section.settings.card_info_vertical -%}
    #section-{{ section.id }} .article-card__info {
      display: flex !important;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
    #section-{{ section.id }} .article-card__info .circle-divider::after {
      display: none;
    }
  {%- endif -%}
{%- endstyle -%}

<div
  class="ms-featured-blog color-{{ section.settings.color_scheme }} gradient{% if section.settings.heading == blank %} no-heading{% endif %}{% if is_full_width %} ms-fb--full-width{% endif %}"
  id="section-{{ section.id }}"
>
  {%- if sw_class != blank -%}<div class="{{ sw_class }}">{%- endif -%}
  <div class="isolate{% if show_mobile_slider == false and show_desktop_slider == false %} page-width-tablet{% endif %}">
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper-with-link{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %} title-wrapper--no-top-margin">
        <{{ title_tag }}
          id="SectionHeading-{{ section.id }}"
          class="{{ title_classes }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {{ section.settings.heading }}
        </{{ title_tag }}>

        {%- if section.settings.blog != blank
          and section.settings.show_view_all
          and section.settings.post_limit < section.settings.blog.articles_count
        -%}
          <a
            href="{{ section.settings.blog.url }}"
            class="link underlined-link large-up-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            aria-label="{{ 'sections.featured_blog.view_all' | t }}: {{ section.settings.blog.title | escape }}"
          >
            {{ 'sections.featured_blog.view_all' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <slider-component
      data-autoplay="{{ section.settings.enable_autoplay }}"
      data-speed="{{ section.settings.autoplay_speed }}000"
      class="slider-mobile-gutter{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if is_full_width %} slider-component-full-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    >
      <ul
        id="Slider-{{ section.id }}"
        class="blog__posts articles-wrapper contains-card contains-card--article{% if settings.blog_card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
        role="list"
        aria-label="{{ section.settings.heading | default: 'Blog in evidenza' | strip_html | escape }}"
      >
        {%- if has_selected_blog and section.settings.blog.articles_count > 0 -%}
          {%- comment -%} ── Blog specifico selezionato ── {%- endcomment -%}
          {%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="blog__post grid__item article{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- render 'article-card',
                blog: section.settings.blog,
                article: article,
                media_height: section.settings.image_height,
                media_aspect_ratio: article.image.aspect_ratio,
                show_image: section.settings.show_image,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                show_reading: section.settings.show_reading,
                show_icons: section.settings.show_icons,
                custom_icon_date: section.settings.custom_icon_date,
                custom_icon_reading: section.settings.custom_icon_reading,
                custom_icon_author: section.settings.custom_icon_author,
                show_excerpt: section.settings.show_excerpt,
                show_blog_name: section.settings.show_blog_name,
                blog_name: section.settings.blog.title,
                blog_url: section.settings.blog.url,
                show_tags: section.settings.show_tags,
                tags_style: section.settings.tags_style
              -%}
            </li>
          {%- endfor -%}

        {%- elsif has_multi_blog -%}
          {%- comment -%}
            ── Nessun blog selezionato → ultimi post da tutti i blog nel menu ──
            Gli articoli sono già ordinati per published_at DESC.
            Per ogni articolo, risaliamo al blog di appartenenza tramite l'URL.
          {%- endcomment -%}
          {%- for article in all_articles limit: section.settings.post_limit -%}
            {%- liquid
              assign _article_blog_handle = article.url | split: '/blogs/' | last | split: '/' | first
              assign _article_blog = blogs[_article_blog_handle]
            -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="blog__post grid__item article{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- render 'article-card',
                blog: _article_blog,
                article: article,
                media_height: section.settings.image_height,
                media_aspect_ratio: article.image.aspect_ratio,
                show_image: section.settings.show_image,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                show_reading: section.settings.show_reading,
                show_icons: section.settings.show_icons,
                custom_icon_date: section.settings.custom_icon_date,
                custom_icon_reading: section.settings.custom_icon_reading,
                custom_icon_author: section.settings.custom_icon_author,
                show_excerpt: section.settings.show_excerpt,
                show_blog_name: section.settings.show_blog_name,
                blog_name: _article_blog.title,
                blog_url: _article_blog.url,
                show_tags: section.settings.show_tags,
                tags_style: section.settings.tags_style
              -%}
            </li>
          {%- endfor -%}

        {%- else -%}
          {%- comment -%} ── Nessun articolo disponibile ── {%- endcomment -%}
          <li class="blog__post grid__item article{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}">
            <div class="ms-fb__no-articles">
              <p>{{ 'sections.featured_blog.no_articles' | t }}</p>
            </div>
          </li>
        {%- endif -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons{% if show_desktop_slider == false %} large-up-hide{% endif %}{% if show_mobile_slider == false %} medium-hide small-hide{% endif %}">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ posts_displayed }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
          </button>
        </div>
      {%- endif -%}
    </slider-component>

    {%- if section.settings.show_view_all and section.settings.blog != blank and section.settings.post_limit < section.settings.blog.articles_count -%}
      <div
        class="ms-fb__view-all center small-hide medium-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- liquid
          assign view_all_text = 'sections.featured_blog.view_all' | t
        -%}
        {%- case btn_style -%}
          {%- when 'pill' -%}
            <a
              href="{{ section.settings.blog.url }}"
              id="ViewAll-{{ section.id }}"
              class="ms-fb__view-all-btn ms-fb__view-all-btn--pill{{ btn_size_class }}"
              aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
            >
              {{ view_all_text }}
            </a>
          {%- when 'link' -%}
            <a
              href="{{ section.settings.blog.url }}"
              id="ViewAll-{{ section.id }}"
              class="ms-fb__view-all-btn ms-fb__view-all-btn--link"
              aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
            >
              {{ view_all_text }}
            </a>
          {%- else -%}
            <a
              href="{{ section.settings.blog.url }}"
              id="ViewAll-{{ section.id }}"
              class="ms-fb__view-all-btn button{{ btn_size_class }}"
              aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
            >
              {{ view_all_text }}
            </a>
        {%- endcase -%}
      </div>
    {%- endif -%}
  </div>
  {%- if sw_class != blank -%}</div>{%- endif -%}
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Blog in evidenza",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout sezione"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.featured-blog.settings.blog.label",
      "info": "Seleziona un blog specifico. Se vuoto, verrà usato il 'Menu blog' sottostante."
    },
    {
      "type": "link_list",
      "id": "blogs_menu",
      "label": "Menu blog (per tutti i blog)",
      "info": "Se nessun blog è selezionato sopra, scegli un menu di navigazione contenente link ai blog. Verranno mostrati gli ultimi articoli da tutti i blog presenti nel menu, ordinati per data."
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 3,
      "label": "t:sections.featured-blog.settings.post_limit.label"
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonne desktop",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Abilita carosello",
      "default": true,
      "info": "Se disattivato, gli articoli verranno visualizzati in una griglia su desktop."
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Abilita autoplay",
      "default": false,
      "info": "Attiva la rotazione automatica delle slide. Funziona quando il carosello è attivo."
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3,
      "unit": "s",
      "label": "Velocità autoplay (secondi)",
      "info": "Tempo tra una slide e la successiva."
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonne mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "label": "Abilita swipe / carosello",
      "default": true,
      "info": "Se disattivato, gli articoli verranno visualizzati in una griglia su mobile."
    },
    {
      "type": "header",
      "content": "Titolo"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.featured-blog.settings.heading.default",
      "label": "t:sections.featured-blog.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "Contenuti card"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "adapt", "label": "t:sections.main-blog.settings.image_height.options__1.label" },
        { "value": "small", "label": "t:sections.main-blog.settings.image_height.options__2.label" },
        { "value": "medium", "label": "t:sections.main-blog.settings.image_height.options__3.label" },
        { "value": "large", "label": "t:sections.main-blog.settings.image_height.options__4.label" }
      ],
      "default": "medium",
      "label": "t:sections.main-blog.settings.image_height.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_reading",
      "default": false,
      "label": "Mostra tempo di lettura"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "Mostra estratto"
    },
    {
      "type": "checkbox",
      "id": "show_blog_name",
      "default": false,
      "label": "Mostra nome blog",
      "info": "Visualizza il nome del blog come etichetta (pill) sull'immagine, in alto a sinistra, con link al blog."
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "default": false,
      "label": "Mostra tag"
    },
    {
      "type": "select",
      "id": "tags_style",
      "label": "Stile tag",
      "options": [
        { "value": "pill", "label": "Pill" },
        { "value": "link", "label": "Link" }
      ],
      "default": "pill"
    },
    {
      "type": "header",
      "content": "Icone"
    },
    {
      "type": "checkbox",
      "id": "show_icons",
      "default": false,
      "label": "Mostra icone (data, lettura, autore)"
    },
    {
      "type": "text",
      "id": "custom_icon_date",
      "label": "Icona data personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "text",
      "id": "custom_icon_reading",
      "label": "Icona tempo lettura personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "text",
      "id": "custom_icon_author",
      "label": "Icona autore personalizzata (SVG)",
      "info": "File .svg = asset del tema, altrimenti classe della libreria icone (es. fa-solid fa-star). Se compilato, sovrascrive l'icona predefinita."
    },
    {
      "type": "header",
      "content": "Stile card"
    },
    {
      "type": "select",
      "id": "card_border_position",
      "label": "Bordi",
      "default": "none",
      "options": [
