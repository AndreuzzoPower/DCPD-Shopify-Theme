{{ 'ms_divider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign divider_type = section.settings.divider_type | default: 'tilt'
  assign divider_color = section.settings.divider_color | default: '#ffffff'
  assign fill_mode = section.settings.fill_mode | default: 'solid'
  assign divider_height = section.settings.divider_height | default: 80
  assign divider_height_mobile = section.settings.divider_height_mobile | default: 50
  assign flip_x = section.settings.flip_horizontal
  assign flip_y = section.settings.flip_vertical

  assign sw = section.settings.section_width | default: 'full_width'
  if sw == 'default'
    assign sw = 'page_width'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign css_classes = 'ms-divider'
  if flip_x
    assign css_classes = css_classes | append: ' ms-divider--flip-x'
  endif
  if flip_y
    assign css_classes = css_classes | append: ' ms-divider--flip-y'
  endif

  assign fill_ref = divider_color
  if fill_mode == 'gradient' or fill_mode == 'image'
    assign fill_ref = 'url(#ms-divider-fill-' | append: section.id | append: ')'
  endif

  assign fill_ref_attr = 'fill="' | append: fill_ref | append: '"'

  assign selected_scheme_id = section.settings.color_scheme | append: ''
  assign selected_scheme = settings.color_schemes[selected_scheme_id]
  if selected_scheme == blank
    assign selected_scheme = settings.color_schemes | first
  endif

  if selected_scheme.settings.background_gradient != blank
    assign scheme_background_value = selected_scheme.settings.background_gradient
  else
    assign scheme_background_value = selected_scheme.settings.background
  endif
-%}

{%- style -%}
  #section-{{ section.id }} {
    --ms-divider-height: {{ divider_height }}px;
    --ms-divider-height-mobile: {{ divider_height_mobile }}px;
  }
{%- endstyle -%}

{%- render 'ms_mobile-padding' -%}

{%- capture svg_defs -%}
  {%- if fill_mode == 'gradient' -%}
    {%- liquid
      assign g_color_1 = section.settings.gradient_color_1 | default: '#ffffff'
      assign g_color_2 = section.settings.gradient_color_2 | default: '#000000'
      assign g_angle = section.settings.gradient_angle | default: 0
    -%}
    <defs>
      <linearGradient id="ms-divider-fill-{{ section.id }}" gradientTransform="rotate({{ g_angle }}, 0.5, 0.5)" gradientUnits="objectBoundingBox">
        <stop offset="0%" stop-color="{{ g_color_1 }}"/>
        {%- if section.settings.gradient_color_3 != blank -%}
          <stop offset="50%" stop-color="{{ section.settings.gradient_color_3 }}"/>
        {%- endif -%}
        <stop offset="100%" stop-color="{{ g_color_2 }}"/>
      </linearGradient>
    </defs>
  {%- elsif fill_mode == 'image' and section.settings.fill_image != blank -%}
    <defs>
      <pattern id="ms-divider-fill-{{ section.id }}" patternUnits="objectBoundingBox" width="1" height="1">
        <image href="{{ section.settings.fill_image | image_url: width: 1920 }}" x="0" y="0" width="1200" height="120" preserveAspectRatio="xMidYMid slice"/>
      </pattern>
    </defs>
  {%- endif -%}
{%- endcapture -%}

{%- comment -%} Cattura la forma per riuso in fill e clipPath {%- endcomment -%}
{%- capture divider_shape -%}
  {%- case divider_type -%}
    {%- when 'tilt' -%}
      <polygon _FILL_ points="1200 0 1200 120 0 120"/>
    {%- when 'triangle' -%}
      <polygon _FILL_ points="600 0 1200 120 0 120"/>
    {%- when 'arrow' -%}
      <path _FILL_ d="M649.97 0L550.03 0 0 120 600 75 1200 120z"/>
    {%- when 'split' -%}
      <polygon _FILL_ points="0 0 600 120 1200 0 1200 120 0 120"/>
    {%- when 'waves' -%}
      <path _FILL_ d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C57.1,118.92,130.23,103.37,193,87.11,241.07,75.15,286.54,66,321.39,56.44Z"/>
    {%- when 'waves_multi' -%}
      <path _FILL_ opacity=".25" d="M0,0V46.29c47.79,22.2,103.59,32.17,158,28,70.36-5.37,136.33-33.31,206.8-37.5C438.64,32.43,512.34,53.67,583,72.05c69.27,18,138.3,24.88,209.4,13.08,36.15-6,69.85-17.84,104.45-29.34C989.49,25,1113-14.29,1200,52.47V120H0Z"/>
      <path _FILL_ opacity=".5" d="M0,0V15.81C13,36.92,27.64,56.86,47.69,72.05,99.41,111.27,165,111,224.58,91.58c31.15-10.15,60.09-26.07,89.67-39.8,40.92-19,84.73-46,130.83-49.67,36.26-2.85,70.9,9.42,98.6,31.56,31.77,25.39,62.32,62,103.63,73,40.44,10.79,81.35-6.69,119.13-24.28s75.16-39,116.92-43.05c59.73-5.85,113.28,22.88,168.9,38.84,30.2,8.66,59,6.17,87.09-7.5,22.43-10.89,48-26.93,60.65-49.24V120H0Z"/>
      <path _FILL_ d="M0,0V5.63C149.93,59,314.09,71.32,475.83,42.57c43-7.64,84.23-20.12,127.61-26.46,59-8.63,112.48,12.24,165.56,35.4C827.93,77.22,886,95.24,951.2,90c86.53-7,172.46-45.71,248.8-84.81V120H0Z"/>
    {%- when 'curve' -%}
      <path _FILL_ d="M600,112.77C268.63,112.77,0,65.52,0,7.23V120H1200V7.23C1200,65.52,931.37,112.77,600,112.77Z"/>
    {%- when 'curve_asymmetric' -%}
      <path _FILL_ d="M0,0V7.23C0,65.52,268.63,112.77,600,112.77S1200,65.52,1200,7.23V120H0Z"/>
    {%- when 'zigzag' -%}
      <path _FILL_ d="M0,0 L60,120 L120,0 L180,120 L240,0 L300,120 L360,0 L420,120 L480,0 L540,120 L600,0 L660,120 L720,0 L780,120 L840,0 L900,120 L960,0 L1020,120 L1080,0 L1140,120 L1200,0 V120 H0 Z"/>
    {%- when 'mountains' -%}
      <path _FILL_ d="M1200,0H0V120l214.67-72,223.33,48L602.34,12l183.32,72,198-36.67Z"/>
    {%- when 'clouds' -%}
      <path _FILL_ d="M0,0V120H1200V0s-79.51,68.49-181,68.49c-68.4,0-112.65-26.09-161-44.49-53.67-20.39-112.53-24-169,0-52.09,22.13-95.54,44.49-164,44.49C456.31,68.49,400,40,345.65,23.51,285.39,5.1,234.34,0,185,12.49,127.52,27.1,82.43,68.49,0,68.49Z"/>
    {%- when 'drops' -%}
      <path _FILL_ d="M0,120V73.07c7.64-14.64,26.45-26.15,52-28.62,38.3-3.71,63.65,17.82,96,17.82S222.73,44.45,261,48.16c25.59,2.47,44.4,14,52,28.62v.29c7.64-14.64,26.45-26.15,52-28.62,38.3-3.71,63.65,17.82,96,17.82s74.73-17.82,113-14.11c25.59,2.47,44.4,14,52,28.62v.29c7.64-14.64,26.45-26.15,52-28.62,38.3-3.71,63.65,17.82,96,17.82s74.73-17.82,113-14.11c25.59,2.47,44.4,14,52,28.62v.29c7.64-14.64,26.45-26.15,52-28.62,38.3-3.71,63.65,17.82,96,17.82s74.73-17.82,113-14.11c25.59,2.47,44.4,14,52,28.62V120Z"/>
    {%- when 'book' -%}
      <path _FILL_ d="M0,0S350,100,600,100,1200,0,1200,0V120H0Z"/>
    {%- when 'fan' -%}
      <path _FILL_ d="M0,0V120l100-10,100,10,100-10,100,10,100-10,100,10,100-10,100,10,100-10,100,10,100-10,100,10V0Z"/>
  {%- endcase -%}
{%- endcapture -%}

<div class="{{ css_classes }} color-{{ section.settings.color_scheme }}" id="section-{{ section.id }}" aria-hidden="true">
  <div class="{{ sw_class }}">
  {%- if divider_type == 'line' -%}
    {%- if fill_mode == 'scheme_gradient' -%}
      <div class="ms-divider__line ms-divider__line--scheme" style="height: {{ section.settings.line_weight }}px; background: {{ scheme_background_value }}; background-attachment: local;"></div>
    {%- elsif fill_mode == 'gradient' -%}
      <div class="ms-divider__line" style="height: {{ section.settings.line_weight }}px; background: linear-gradient({{ section.settings.gradient_angle | default: 0 }}deg, {{ section.settings.gradient_color_1 | default: '#ffffff' }}{% if section.settings.gradient_color_3 != blank %}, {{ section.settings.gradient_color_3 }}{% endif %}, {{ section.settings.gradient_color_2 | default: '#000000' }});"></div>
    {%- elsif fill_mode == 'image' and section.settings.fill_image != blank -%}
      <div class="ms-divider__line" style="height: {{ section.settings.line_weight }}px; background: url('{{ section.settings.fill_image | image_url: width: 1920 }}') center/cover no-repeat;"></div>
    {%- else -%}
      <hr class="ms-divider__line" style="border-top: {{ section.settings.line_weight }}px {{ section.settings.line_style }} {{ divider_color }};">
    {%- endif -%}
  {%- else -%}
    <div class="ms-divider__svg">

      {%- if fill_mode == 'scheme_gradient' -%}
        {%- assign clip_shapes = divider_shape | replace: '_FILL_', '' | replace: ' opacity=".25"', '' | replace: ' opacity=".5"', '' -%}
        <svg viewBox="0 0 1200 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="ms-divider-clip-{{ section.id }}">
              {{ clip_shapes }}
            </clipPath>
          </defs>
          <foreignObject width="1200" height="120" clip-path="url(#ms-divider-clip-{{ section.id }})">
            <div xmlns="http://www.w3.org/1999/xhtml" style="width:100%;height:100%;background: {{ scheme_background_value }};"></div>
          </foreignObject>
        </svg>
      {%- else -%}
        <svg viewBox="0 0 1200 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          {{ svg_defs }}
          {{ divider_shape | replace: '_FILL_', fill_ref_attr }}
        </svg>
      {%- endif -%}

    </div>
  {%- endif -%}
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Divisore",
  "tag": "section",
  "class": "ms-divider-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "full_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colori",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Divisore"
    },
    {
      "type": "select",
      "id": "divider_type",
      "label": "Tipo divisore",
      "options": [
        { "value": "line", "label": "Linea semplice" },
        { "value": "tilt", "label": "Inclinato" },
        { "value": "triangle", "label": "Triangolo" },
        { "value": "arrow", "label": "Freccia" },
        { "value": "split", "label": "Split (V rovesciata)" },
        { "value": "waves", "label": "Onda" },
        { "value": "waves_multi", "label": "Onde multiple" },
        { "value": "curve", "label": "Curva" },
        { "value": "curve_asymmetric", "label": "Curva asimmetrica" },
        { "value": "zigzag", "label": "Zigzag" },
        { "value": "mountains", "label": "Montagne" },
        { "value": "clouds", "label": "Nuvole" },
        { "value": "drops", "label": "Gocce" },
        { "value": "book", "label": "Libro" },
        { "value": "fan", "label": "Ventaglio" }
      ],
      "default": "tilt"
    },
    {
      "type": "select",
      "id": "fill_mode",
      "label": "Modalita riempimento",
      "options": [
        { "value": "solid", "label": "Colore solido" },
        { "value": "scheme_gradient", "label": "Gradiente schema colore" },
        { "value": "gradient", "label": "Gradiente personalizzato" },
        { "value": "image", "label": "Immagine" }
      ],
      "default": "solid",
      "info": "Scegli come riempire la forma del divisore. Il gradiente dello schema colore usa il gradiente configurato nello schema colore selezionato."
    },
    {
      "type": "header",
      "content": "Colore solido"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Colore divisore",
      "default": "#ffffff",
      "info": "Usato quando la modalita e Colore solido. Tipicamente il colore di sfondo della sezione sottostante."
    },
    {
      "type": "header",
      "content": "Gradiente"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Colore iniziale",
      "default": "#ffffff",
      "info": "Primo colore del gradiente."
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Colore finale",
      "default": "#000000",
      "info": "Ultimo colore del gradiente."
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Colore intermedio (opzionale)",
      "info": "Se impostato, viene aggiunto al centro del gradiente."
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Angolo gradiente",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "°",
      "default": 0,
      "info": "Direzione del gradiente in gradi. 0 = da sinistra a destra, 90 = dall'alto al basso."
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "image_picker",
      "id": "fill_image",
      "label": "Immagine riempimento",
      "info": "L'immagine viene usata come riempimento della forma. Usata quando la modalita e Immagine."
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Altezza desktop",
      "min": 10,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "divider_height_mobile",
      "label": "Altezza mobile",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "flip_horizontal",
      "label": "Specchia orizzontalmente",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "flip_vertical",
      "label": "Specchia verticalmente",
      "default": false,
      "info": "Inverte la direzione del divisore (es. da puntare verso il basso a puntare verso l'alto)."
    },
    {
      "type": "header",
      "content": "Linea semplice"
    },
    {
      "type": "range",
      "id": "line_weight",
      "label": "Spessore linea",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1,
      "info": "Applicato solo quando il tipo divisore e \"Linea semplice\"."
    },
    {
      "type": "select",
      "id": "line_style",
      "label": "Stile linea",
      "options": [
        { "value": "solid", "label": "Continua" },
        { "value": "dashed", "label": "Tratteggiata" },
        { "value": "dotted", "label": "Puntinata" },
        { "value": "double", "label": "Doppia" }
      ],
      "default": "solid",
      "info": "Applicato solo quando il tipo divisore e \"Linea semplice\"."
    }
  ],
  "blocks": [
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_padding_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_margin_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_margin_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_margin_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "BG Image"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "BG Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Divisore",
      "category": "Contenuti"
    }
  ]
}
{% endschema %}
