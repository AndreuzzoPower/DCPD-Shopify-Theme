{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'ms_slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'full_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full' or sw == 'full_bleed'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign pagination_style = section.settings.pagination_style | default: 'counter'
  assign show_arrows = section.settings.show_arrows
  assign show_pagination = section.settings.show_pagination
  assign arrows_overlay = false
  if section.settings.arrows_position == 'overlay_sides'
    assign arrows_overlay = true
  endif

  assign autoplay_overlay = false
  if section.settings.auto_rotate and section.settings.autoplay_position == 'overlay'
    assign autoplay_overlay = true
  endif

  assign has_multiple_slides = false
  assign real_slide_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign real_slide_count = real_slide_count | plus: 1
    endif
  endfor
  if real_slide_count > 1
    assign has_multiple_slides = true
  endif
-%}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'section_padding' -%}
    {%- style -%}
      #section-{{ section.id }} .slideshow__text-wrapper.banner__content {
        padding-top: {{ block.settings.section_padding_top }}px;
        padding-bottom: {{ block.settings.section_padding_bottom }}px;
      }
      @media all and (min-width: 768px) and (max-width: 991px) {
        #section-{{ section.id }} .slideshow__text-wrapper.banner__content {
          padding-top: {{ block.settings.section_padding_top_md }}px;
          padding-bottom: {{ block.settings.section_padding_bottom_md }}px;
        }
      }
      @media all and (max-width: 767px) {
        #section-{{ section.id }} .slideshow__text-wrapper.banner__content {
          padding-top: {{ block.settings.section_padding_top_xs }}px;
          padding-bottom: {{ block.settings.section_padding_bottom_xs }}px;
        }
      }
    {%- endstyle -%}
  {%- endif -%}
{%- endfor -%}

<slideshow-component
  id="section-{{ section.id }}"
  class="slider-mobile-gutter color-{{ section.settings.color_scheme }}{% if sw_class != blank %} {{ sw_class }}{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %}{% if arrows_overlay and has_multiple_slides %} ms-slideshow--arrows-overlay{% endif %}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
>
  {%- comment -%} Top controls — only when auto_rotate is active {%- endcomment -%}
  {%- if has_multiple_slides and section.settings.auto_rotate -%}
    <div class="slideshow__controls slideshow__controls--top slider-buttons{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      {%- if show_arrows and arrows_overlay == false -%}
        <button
          type="button"
          class="slider-button slider-button--prev"
          name="previous"
          aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
        </button>
      {%- endif -%}
      {%- if show_pagination and pagination_style != 'none' -%}
        <div class="slider-counter slider-counter--{{ pagination_style }}{% if pagination_style == 'counter' or pagination_style == 'numbers' %} caption{% endif %}">
          {%- if pagination_style == 'counter' -%}
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ real_slide_count }}</span>
          {%- else -%}
            <div class="slideshow__control-wrapper">
              {%- for block in section.blocks -%}
                {%- if block.type == 'slide' -%}
                  <button
                    class="slider-counter__link slider-counter__link--{{ pagination_style }} link"
                    aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ real_slide_count }}"
                    aria-controls="Slider-{{ section.id }}"
                  >
                    {%- if pagination_style == 'numbers' -%}
                      {{ forloop.index -}}
                    {%- else -%}
                      <span class="dot"></span>
                    {%- endif -%}
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if show_arrows and arrows_overlay == false -%}
        <button
          type="button"
          class="slider-button slider-button--next"
          name="next"
          aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
        </button>
      {%- endif -%}
      {%- unless autoplay_overlay -%}
      <button
        type="button"
        class="slideshow__autoplay slider-button{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
        aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
      >
        {%- render 'ms_icon', icon: settings.ms_icon_pause -%}
        {%- render 'ms_icon', icon: settings.ms_icon_play -%}
      </button>
      {%- endunless -%}
    </div>
  {%- endif -%}

  <div class="ms-slideshow__media-wrapper">
  <div
    class="slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- liquid
      assign slide_index = 0
    -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- comment -%} Temporizzazione: salta slide non visibili (in design_mode mostrale tutte con badge) {%- endcomment -%}
        {%- capture ms_slide_vis -%}
          {%- render 'ms_schedule_check', schedule_enabled: block.settings.schedule_enabled, schedule_start: block.settings.schedule_start, schedule_end: block.settings.schedule_end -%}
        {%- endcapture -%}
        {%- assign ms_slide_vis = ms_slide_vis | strip -%}
        {%- unless ms_slide_vis == 'true' or request.design_mode -%}
          {%- continue -%}
        {%- endunless -%}
        {%- liquid
          assign is_slide_scheduled_hidden = false
          if ms_slide_vis != 'true' and request.design_mode
            assign is_slide_scheduled_hidden = true
          endif

          assign slide_index = slide_index | plus: 1
          assign box_opacity = block.settings.box_opacity | default: 100
          assign has_custom_opacity = false
          if box_opacity < 100
            assign has_custom_opacity = true
          endif

          assign slide_aria_label = slide_index | append: ' / ' | append: real_slide_count
          if block.settings.slide_accessibility_label != blank
            assign slide_aria_label = block.settings.slide_accessibility_label | escape | append: ' — ' | append: slide_index | append: ' / ' | append: real_slide_count
          endif
        -%}
        {%- style -%}
          #Slide-{{ section.id }}-{{ slide_index }} .banner__media::after {
            opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
          }
          {%- assign box_radius = block.settings.box_border_radius | default: 0 -%}
          {%- if has_custom_opacity or box_radius > 0 -%}
            #Slide-{{ section.id }}-{{ slide_index }} .banner__box {
              {%- if has_custom_opacity -%}
                --ms-box-bg-opacity: {{ box_opacity | divided_by: 100.0 }};
              {%- endif -%}
              {%- if box_radius > 0 -%}
                border-radius: {{ box_radius }}px;
              {%- endif -%}
            }
          {%- endif -%}
        {%- endstyle -%}
        <div
          class="slideshow__slide grid__item grid--1-col slider__slide{% if is_slide_scheduled_hidden %} ms-slide--schedule-pending{% endif %}"
          id="Slide-{{ section.id }}-{{ slide_index }}"
          {{ block.shopify_attributes }}
          role="group"
          aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
          aria-label="{{ slide_aria_label }}"
          tabindex="-1"
          data-ms-overlay-light="{{ block.settings.overlay_controls_light | default: false }}"
        >
          <div class="slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
            {%- if block.settings.image -%}
              {%- liquid
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                if section.settings.image_behavior == 'ambient'
                  assign sizes = '120vw'
                  assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
                else
                  assign sizes = '100vw'
                  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                endif
                assign fetch_priority = 'auto'
                if section.index == 1
                  assign fetch_priority = 'high'
                endif
              -%}
              {%- if block.settings.image_mobile -%}
                <span class="ms-slide__img-desktop">
              {%- endif -%}
              {%- if slide_index == 1 %}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
                }}
              {%- endif -%}
              {%- if block.settings.image_mobile -%}
                </span>
                <span class="ms-slide__img-mobile">
                  {%- liquid
                    assign mobile_height = block.settings.image_mobile.width | divided_by: block.settings.image_mobile.aspect_ratio | round
                  -%}
                  {{
                    block.settings.image_mobile
                    | image_url: width: 750
                    | image_tag: loading: 'lazy', height: mobile_height, sizes: '100vw', widths: '375, 550, 750'
                  }}
                </span>
              {%- endif -%}
            {%- else -%}
              {%- assign placeholder_slide = slide_index | modulo: 2 -%}
              {%- if placeholder_slide == 1 -%}
                {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>
          <div class="slideshow__text-wrapper banner__content banner__content--{{ block.settings.box_align }} page-width{% if block.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if settings.animations_reveal_on_scroll and slide_index == 1 %} scroll-trigger animate--slide-in{% endif %}{% if block.settings.hide_text_on_mobile %} ms-slideshow__content--hide-mobile{% endif %}">
            <div class="slideshow__text banner__box{% if has_custom_opacity %} ms-slide__box-custom-opacity{% endif %} content-container content-container--full-width-mobile color-{{ block.settings.color_scheme }} gradient slideshow__text--{{ block.settings.text_alignment }} slideshow__text-mobile--{{ block.settings.text_alignment_mobile }}">
              {%- if block.settings.heading != blank -%}
                {%- liquid
                  assign heading_tag = block.settings.heading_tag | default: 'h2'
                  assign heading_classes = 'banner__heading inline-richtext ' | append: block.settings.heading_size
                  if block.settings.heading_custom_class != blank
                    assign heading_classes = heading_classes | append: ' ' | append: block.settings.heading_custom_class
                  endif
                -%}
                <{{ heading_tag }} class="{{ heading_classes }}">
                  {{ block.settings.heading }}
                </{{ heading_tag }}>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}
                {%- liquid
                  assign subheading_tag = block.settings.subheading_tag | default: 'p'
                  assign subheading_classes = 'banner__text rte'
                  if block.settings.subheading_custom_class != blank
                    assign subheading_classes = subheading_classes | append: ' ' | append: block.settings.subheading_custom_class
                  endif
                -%}
                <div class="{{ subheading_classes }}">
                  <{{ subheading_tag }}>{{ block.settings.subheading }}</{{ subheading_tag }}>
                </div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="banner__buttons">
                  <a
                    {% if block.settings.link %}
                      href="{{ block.settings.link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                    class="{%- render 'ms_button_classes', type: block.settings.button_type, secondary: block.settings.button_style_secondary, size: block.settings.button_size -%}"
                  >
                    {%- render 'ms_button_icon', icon: block.settings.button_icon, position: block.settings.button_icon_position, slot: 'before' -%}
                    {{- block.settings.button_label | escape -}}
                    {%- render 'ms_button_icon', icon: block.settings.button_icon, position: block.settings.button_icon_position, slot: 'after' -%}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
  {%- comment -%} Overlay arrows — outside the scroll container so they stay fixed while slides scroll {%- endcomment -%}
  {%- if has_multiple_slides and arrows_overlay and show_arrows -%}
    <div class="ms-slideshow__arrows-overlay" role="group" aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
      </button>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
      </button>
    </div>
  {%- endif -%}
  {%- if section.settings.auto_rotate and autoplay_overlay -%}
    <button
      type="button"
      class="slideshow__autoplay slider-button ms-slideshow__autoplay-overlay"
      aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
    >
      {%- render 'ms_icon', icon: settings.ms_icon_pause -%}
      {%- render 'ms_icon', icon: settings.ms_icon_play -%}
    </button>
  {%- endif -%}
  </div>

  {%- comment -%} Bottom controls — manual mode only {%- endcomment -%}
  {%- if has_multiple_slides and section.settings.auto_rotate == false -%}
    {%- if arrows_overlay -%}
      {%- comment -%} Overlay mode: only pagination below {%- endcomment -%}
      {%- if show_pagination and pagination_style != 'none' -%}
        <div class="ms-slideshow__pagination-below slider-buttons{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
          <div class="slider-counter slider-counter--{{ pagination_style }}{% if pagination_style == 'counter' or pagination_style == 'numbers' %} caption{% endif %}">
            {%- if pagination_style == 'counter' -%}
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ real_slide_count }}</span>
            {%- else -%}
              <div class="slideshow__control-wrapper">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' -%}
                    <button
                      class="slider-counter__link slider-counter__link--{{ pagination_style }} link"
                      aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ real_slide_count }}"
                      aria-controls="Slider-{{ section.id }}"
                    >
                      {%- if pagination_style == 'numbers' -%}
                        {{ forloop.index -}}
                      {%- else -%}
                        <span class="dot"></span>
                      {%- endif -%}
                    </button>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- else -%}
      {%- comment -%} Normal mode: arrows + pagination together below {%- endcomment -%}
      {%- if show_arrows or show_pagination -%}
        <div class="slideshow__controls slider-buttons{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
          {%- if show_arrows -%}
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
              aria-controls="Slider-{{ section.id }}"
            >
              {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
            </button>
          {%- endif -%}
          {%- if show_pagination and pagination_style != 'none' -%}
            <div class="slider-counter slider-counter--{{ pagination_style }}{% if pagination_style == 'counter' or pagination_style == 'numbers' %} caption{% endif %}">
              {%- if pagination_style == 'counter' -%}
                <span class="slider-counter--current">1</span>
                <span aria-hidden="true"> / </span>
                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                <span class="slider-counter--total">{{ real_slide_count }}</span>
              {%- else -%}
                <div class="slideshow__control-wrapper">
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'slide' -%}
                      <button
                        class="slider-counter__link slider-counter__link--{{ pagination_style }} link"
                        aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ real_slide_count }}"
                        aria-controls="Slider-{{ section.id }}"
                      >
                        {%- if pagination_style == 'numbers' -%}
                          {{ forloop.index -}}
                        {%- else -%}
                          <span class="dot"></span>
                        {%- endif -%}
                      </button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if show_arrows -%}
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
              aria-controls="Slider-{{ section.id }}"
            >
              {%- render 'ms_icon', icon: settings.ms_icon_caret -%}
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
</slideshow-component>

{%- render 'ms_section-style' -%}

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script>
(function() {
  /**
   * Per ogni media-wrapper dello slideshow imposta un IntersectionObserver
   * che rileva quale slide è in vista e aggiorna la classe
   * ms-overlay-controls--light sulle frecce e sul play/pausa overlay.
   */
  function initOverlayControlsColor(wrapper) {
    var slider = wrapper.querySelector('.slideshow');
    if (!slider) return;
    var slides = Array.from(slider.querySelectorAll('.slideshow__slide'));
    var controlEls = [
      wrapper.querySelector('.ms-slideshow__arrows-overlay'),
      wrapper.querySelector('.ms-slideshow__autoplay-overlay')
    ].filter(Boolean);
    if (!slides.length || !controlEls.length) return;

    function applyFromSlide(slide) {
      var isLight = slide.dataset.msOverlayLight === 'true';
      controlEls.forEach(function(el) {
        el.classList.toggle('ms-overlay-controls--light', isLight);
      });
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) applyFromSlide(entry.target);
      });
    }, { root: slider, threshold: 0.5 });

    slides.forEach(function(slide) { observer.observe(slide); });
    applyFromSlide(slides[0]); // stato iniziale
  }

  function initAll() {
    document.querySelectorAll('.ms-slideshow__media-wrapper').forEach(initOverlayControlsColor);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }

  /* Re-init quando Shopify ricarica la sezione nell'editor */
  document.addEventListener('shopify:section:load', function(e) {
    var wrapper = e.target.querySelector('.ms-slideshow__media-wrapper');
    if (wrapper) initOverlayControlsColor(wrapper);
  });
})();
</script>

{% schema %}
{
  "name": "MS Slideshow",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "full_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "select",
      "id": "slide_height",
      "options": [
        {
          "value": "adapt_image",
          "label": "t:sections.slideshow.settings.slide_height.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.slideshow.settings.slide_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.slideshow.settings.slide_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.slideshow.settings.slide_height.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.slideshow.settings.slide_height.label"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "image_behavior",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.animation.image_behavior.options__1.label"
        },
        {
          "value": "ambient",
          "label": "t:sections.all.animation.image_behavior.options__2.label"
        }
      ],
      "default": "none",
