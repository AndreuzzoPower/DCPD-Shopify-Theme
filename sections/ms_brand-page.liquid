{%- comment -%}
  MS Brand Page — Pagina singola brand (metaobject).
  Mostra logo, nome, descrizione e griglia prodotti collegati.

  Usa metaobject.system per accedere ai dati del brand corrente.
  Con collezione: paginazione e infinite scroll (nessun limite prodotti).
  Senza collezione: filtra collections.all per vendor (max 50 prodotti, limite Shopify).
{%- endcomment -%}

{{ 'ms_brand-page.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- if section.settings.products_image_shape == 'blob' -%}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.products_quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.products_quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.products_quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.enable_infinite_scroll -%}
  <script src="{{ 'ms_infinite-scroll.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign brand = metaobject
  assign brand_name = brand.nome.value | default: brand.system.handle
  assign brand_logo = brand.logo.value
  assign brand_desc = brand.descrizione.value
  assign brand_collection = brand.collezione.value

  assign title_tag = section.settings.title_tag | default: 'h1'
  assign title_classes = section.settings.heading_size | default: 'h0'
  if section.settings.title_custom_class != blank
    assign title_classes = title_classes | append: ' ' | append: section.settings.title_custom_class
  endif

  assign products_title_tag = section.settings.products_title_tag | default: 'h2'
  assign products_title_classes = section.settings.products_heading_size | default: 'h1'

  assign bp_products_per_page = section.settings.products_per_page | default: 16
  assign bp_cols_desktop = section.settings.products_columns_desktop | default: 4
  assign bp_cols_mobile = section.settings.products_columns_mobile | default: '2'

  assign bp_show_title = section.settings.show_title | default: true
  assign bp_show_logo = section.settings.show_logo | default: true
  assign bp_show_description = section.settings.show_description | default: true
  assign bp_image_position = section.settings.image_position | default: 'left'
  assign bp_logo_max_w = section.settings.logo_max_width | default: 300
  assign bp_logo_max_h = section.settings.logo_max_height | default: 200
-%}

{%- render 'ms_mobile-padding' -%}

{%- style -%}
  #section-{{ section.id }} .ms-bp__logo-wrap {
    --bp-logo-max-width: {{ bp_logo_max_w }}px;
    --bp-logo-max-height: {{ bp_logo_max_h }}px;
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="ms-brand-page color-{{ section.settings.color_scheme }} gradient">
  <div class="{{ sw_class }}">

    {%- comment -%} Hero brand {%- endcomment -%}
    <div class="ms-bp__hero ms-bp__hero--image-{{ bp_image_position }}{% if bp_show_logo and brand_logo != blank %} ms-bp__hero--has-image{% endif %}">
      {%- if bp_show_logo and brand_logo != blank -%}
        <div class="ms-bp__logo-wrap">
          {{
            brand_logo
            | image_url: width: 600
            | image_tag:
                class: 'ms-bp__logo',
                loading: 'eager',
                alt: brand_name,
                widths: '200, 400, 600',
                sizes: '(min-width: 750px) 300px, 200px'
          }}
        </div>
      {%- endif -%}

      <div class="ms-bp__hero-content">
        {%- if bp_show_title -%}
          <{{ title_tag }} class="{{ title_classes }} ms-bp__title">
            {{- brand_name | escape -}}
          </{{ title_tag }}>
        {%- endif -%}

        {%- if bp_show_description and brand_desc != blank -%}
          <div class="ms-bp__description rte text-body">
            {{ brand_desc }}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Griglia prodotti (stessa struttura e opzioni di main-collection-product-grid) {%- endcomment -%}

    <div class="ms-bp__products">
      {%- if section.settings.products_title != blank -%}
        <{{ products_title_tag }} class="{{ products_title_classes }} ms-bp__products-title">
          {{- section.settings.products_title | escape -}}
        </{{ products_title_tag }}>
      {%- endif -%}

      {%- if brand_collection != blank -%}
        {%- comment -%} Con collezione: paginazione + infinite scroll (nessun limite 50) {%- endcomment -%}
        {%- paginate brand_collection.products by bp_products_per_page -%}
          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
          >
            {%- if brand_collection.products.size == 0 -%}
              <div class="collection collection--empty {{ sw_class }}" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <p class="title title--primary">{{ 'sections.collection_template.empty' | t }}</p>
              </div>
            {%- else -%}
              <div
                class="collection {{ sw_class }}"
                {% if section.settings.enable_infinite_scroll %}
                  data-infinite-scroll
                  data-infinite-grid="#product-grid"
                  data-infinite-item="#product-grid > li"
                {% endif %}
              >
                <div class="loading-overlay gradient"></div>
                <ul
                  id="product-grid"
                  data-id="{{ section.id }}"
                  class="
                    grid product-grid grid--{{ bp_cols_mobile }}-col-tablet-down
                    grid--{{ bp_cols_desktop }}-col-desktop
                    {% if section.settings.products_quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
                  "
                >
                  {%- assign skip_card_product_styles = false -%}
                  {%- for product in brand_collection.products -%}
                    {%- assign lazy_load = false -%}
                    {%- if forloop.index > 2 -%}{%- assign lazy_load = true -%}{%- endif -%}
                    <li
                      class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      {%- render 'card-product',
                        card_product: product,
                        media_aspect_ratio: section.settings.products_image_ratio,
                        image_shape: section.settings.products_image_shape,
                        show_secondary_image: section.settings.products_show_secondary_image,
                        show_vendor: section.settings.products_show_vendor,
                        show_rating: section.settings.products_show_rating,
                        show_min_order: section.settings.products_show_min_order,
                        lazy_load: lazy_load,
                        skip_styles: skip_card_product_styles,
                        quick_add: section.settings.products_quick_add,
                        section_id: section.id
                      -%}
                    </li>
                    {%- assign skip_card_product_styles = true -%}
                  {%- endfor -%}
                </ul>
                {%- if paginate.pages > 1 -%}
                  {%- render 'pagination', paginate: paginate, anchor: '' -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endpaginate -%}
      {%- else -%}
        {%- comment -%} Senza collezione: filtra per vendor (max 50 prodotti, limite Liquid) {%- endcomment -%}
        {%- capture vendor_grid_items -%}
          {%- assign skip_card_product_styles = false -%}
          {%- assign item_index = 0 -%}
          {%- for product in collections.all.products limit: 50 -%}
            {%- if product.vendor == brand_name -%}
              {%- assign item_index = item_index | plus: 1 -%}
              {%- if item_index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- else -%}
                {%- assign lazy_load = false -%}
              {%- endif -%}
              <li
                class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ item_index }};"
                {% endif %}
              >
                {%- render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.products_image_ratio,
                  image_shape: section.settings.products_image_shape,
                  show_secondary_image: section.settings.products_show_secondary_image,
                  show_vendor: section.settings.products_show_vendor,
                  show_rating: section.settings.products_show_rating,
                  show_min_order: section.settings.products_show_min_order,
                  lazy_load: lazy_load,
                  skip_styles: skip_card_product_styles,
                  quick_add: section.settings.products_quick_add,
                  section_id: section.id
                -%}
              </li>
              {%- assign skip_card_product_styles = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}
        {%- if vendor_grid_items != blank -%}
          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
          >
            <div class="collection {{ sw_class }}">
              <div class="loading-overlay gradient"></div>
              <ul
                id="product-grid"
                data-id="{{ section.id }}"
                class="
                  grid product-grid grid--{{ bp_cols_mobile }}-col-tablet-down
                  grid--{{ bp_cols_desktop }}-col-desktop
                  {% if section.settings.products_quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
                "
              >
                {{ vendor_grid_items }}
              </ul>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.products_image_shape == 'arch' -%}
        {{ 'mask-arch.svg' | inline_asset_content }}
      {%- endif -%}
    </div>

  </div>
</div>

{%- comment -%} Dati strutturati {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "name": {{ brand_name | json }}
    {%- if brand.system.url != blank -%}
      ,"url": {{ brand.system.url | json }}
    {%- endif -%}
    {%- if brand_logo != blank -%}
      ,"logo": {{ brand_logo | image_url: width: 600 | json }}
    {%- endif -%}
    {%- if brand_desc != blank -%}
      {%- assign sd_desc = brand_desc | strip_html | strip | truncate: 5000 -%}
      ,"description": {{ sd_desc | json }}
    {%- endif -%}
  }
</script>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Brand Page",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza blocco",
      "options": [
        { "label": "Stretta (narrow)", "value": "narrow" },
        { "label": "Larghezza pagina", "value": "page_width" },
        { "label": "Larghezza fluida", "value": "page_fluid" },
        { "label": "Piena larghezza", "value": "full_width" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione colori",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },

    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo brand",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Dimensione titolo brand",
      "options": [
        { "label": "Piccola", "value": "h2" },
        { "label": "Media", "value": "h1" },
        { "label": "Grande", "value": "h0" },
        { "label": "Extra grande", "value": "hxl" },
        { "label": "Extra extra grande", "value": "hxxl" }
      ],
      "default": "h0"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "header",
      "content": "Informazioni brand (hero)"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Mostra titolo",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Mostra logo",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Mostra descrizione",
      "default": true
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posizione immagine (logo)",
      "options": [
        { "label": "Sinistra", "value": "left" },
        { "label": "Destra", "value": "right" }
      ],
      "default": "left",
      "info": "Su desktop: logo a lato del testo. Su mobile resta centrato."
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Larghezza massima logo (px)",
      "min": 80,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Altezza massima logo (px)",
      "min": 60,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },

    {
      "type": "header",
      "content": "Prodotti"
    },
    {
      "type": "text",
      "id": "products_title",
      "label": "Titolo sezione prodotti",
      "default": "Prodotti"
    },
    {
      "type": "select",
      "id": "products_title_tag",
      "label": "Tag titolo prodotti",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "products_heading_size",
      "label": "Dimensione titolo prodotti",
      "options": [
        { "label": "Piccola", "value": "h2" },
        { "label": "Media", "value": "h1" },
        { "label": "Grande", "value": "h0" },
        { "label": "Extra grande", "value": "hxl" },
        { "label": "Extra extra grande", "value": "hxxl" }
      ],
      "default": "h1"
    },
    {
      "type": "paragraph",
      "content": "Con collezione assegnata al brand: paginazione e infinite scroll, nessun limite. Senza collezione (solo vendor): max 50 prodotti (limite Shopify)."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Prodotti per pagina",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "info": "Usato quando il brand ha una collezione assegnata (paginazione)."
    },
    {
      "type": "range",
      "id": "products_columns_desktop",
      "label": "Colonne desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_columns_mobile",
      "label": "Colonne mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "header",
      "content": "Media prodotti"
    },
    {
      "type": "select",
      "id": "products_image_ratio",
      "label": "Proporzione immagine",
      "options": [
        { "value": "adapt", "label": "Adatta" },
        { "value": "portrait", "label": "Ritratto" },
        { "value": "square", "label": "Quadrata" }
      ],
      "default": "adapt"
    },
    {
      "type": "select",
      "id": "products_image_shape",
      "label": "Forma immagine",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "arch", "label": "Arco" },
        { "value": "blob", "label": "Blob" },
        { "value": "chevronleft", "label": "Chevron sinistra" },
        { "value": "chevronright", "label": "Chevron destra" },
        { "value": "diamond", "label": "Diamante" },
        { "value": "parallelogram", "label": "Parallelogramma" },
        { "value": "round", "label": "Rotondo" }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "products_show_secondary_image",
      "label": "Mostra seconda immagine al passaggio",
      "default": false
    },
    {
      "type": "header",
      "content": "Scheda prodotto"
    },
    {
      "type": "checkbox",
      "id": "products_show_vendor",
      "label": "Mostra vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "products_show_rating",
      "label": "Mostra valutazione",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "products_show_min_order",
      "label": "Mostra quantita minima",
      "default": true
    },
    {
      "type": "select",
      "id": "products_quick_add",
      "label": "Quick add",
      "default": "none",
      "options": [
        { "value": "none", "label": "Nessuno" },
        { "value": "standard", "label": "Standard" },
        { "value": "bulk", "label": "Bulk" }
      ]
    },
    {
      "type": "header",
      "content": "Infinite scroll"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "Abilita infinite scroll",
      "default": false,
      "info": "Solo con collezione assegnata al brand. Carica automaticamente i prodotti successivi."
    }
  ],
  "blocks": [
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range", "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
