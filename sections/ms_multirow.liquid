{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  if section.settings.image_layout contains 'right'
    assign odd_class = ' image-with-text__grid--reverse'
  else
    assign even_class = ' image-with-text__grid--reverse'
  endif

  if section.settings.row_color_scheme == section.settings.color_scheme
    assign no_content_background = true
  endif

  if settings.text_boxes_shadow == 'none' and settings.text_boxes_border_thickness == 0 or settings.text_boxes_border_opacity == 0
    assign no_content_styles = true
  endif

  if settings.text_boxes_border_thickness > 0 and settings.text_boxes_border_opacity > 0 and settings.media_border_thickness > 0 and settings.media_border_opacity > 0
    assign borders_class = ' collapse-borders'
  endif

  if no_content_background and no_content_styles
    assign padding_class = ' collapse-padding'
  endif

  unless no_content_background and no_content_styles
    assign corners_class = ' collapse-corners'
  endunless

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_classes = 'image-with-text__heading ' | append: section.settings.heading_size
  if section.settings.heading_custom_class != blank
    assign heading_classes = heading_classes | append: ' ' | append: section.settings.heading_custom_class
  endif
-%}

{%- style -%}
  #section-{{ section.id }} .multirow__inner {
    gap: {{ section.settings.row_space_mobile }}px !important;
  }

  @media screen and (min-width: 768px) and (max-width: 991px) {
    #section-{{ section.id }} .multirow__inner {
      gap: {{ section.settings.row_space_tablet }}px !important;
    }
  }

  @media screen and (min-width: 992px) {
    #section-{{ section.id }} .multirow__inner {
      gap: {{ section.settings.row_space }}px !important;
    }
  }
{%- endstyle -%}

{%- render 'ms_mobile-padding' -%}

{% assign rowCounter = 0 %}
<div
  class="multirow ms_multirow color-{{ section.settings.color_scheme }} gradient"
  id="section-{{ section.id }}"
>
  <div class="multirow__inner {{ sw_class }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'row' -%}
        {% assign rowCounter = rowCounter | plus: 1 %}
        <div
          id="block-{{ block.id }}"
          class="image-with-text isolate{{ borders_class }}{{ corners_class }}{{ padding_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="image-with-text__grid grid grid--gapless grid--1-col grid--{% if section.settings.desktop_image_width == 'medium' %}2-col-tablet{% else %}3-col-tablet{% endif %}{% if section.settings.image_layout contains 'alternate' %}{% cycle odd_class, even_class %}{% else %}{{ odd_class }}{% endif %}">
            <div class="image-with-text__media-item image-with-text__media-item--{{ section.settings.desktop_image_width }} image-with-text__media-item--{{ section.settings.desktop_content_position }} grid__item">
              <div
                class="image-with-text__media image-with-text__media--{{ section.settings.image_height }} gradient color-{{ section.settings.row_color_scheme }} global-media-settings{% if block.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}"
                {% if section.settings.image_height == 'adapt' and block.settings.image != blank %}
                  style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if block.settings.image != blank -%}
                  {%- capture sizes -%}
                    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                    (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                  {%- endcapture -%}

                  {%- capture img_alt -%}
                    {%- render 'ms_image_alt', image: block.settings.image, custom_alt: block.settings.image_alt, fallback_title: block.settings.heading -%}
                  {%- endcapture -%}
                  {%- assign img_alt = img_alt | strip -%}

                  {{
                    block.settings.image
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500', alt: img_alt
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
            <div class="image-with-text__text-item grid__item">
              <div class="image-with-text__content image-with-text__content--{{ section.settings.desktop_content_position }} image-with-text__content--desktop-{{ section.settings.desktop_content_alignment }} image-with-text__content--mobile-{{ section.settings.mobile_content_alignment }} image-with-text__content--{{ section.settings.image_height }} content-container{% unless no_content_background and no_content_styles %} gradient color-{{ section.settings.row_color_scheme }}{% else %} background-transparent{% endunless %}">
                {%- if block.settings.caption -%}
                  <p class="image-with-text__text image-with-text__text--caption caption-with-letter-spacing caption-with-letter-spacing--medium">
                    {{ block.settings.caption | escape }}
                  </p>
                {%- endif -%}
                {%- if block.settings.heading -%}
                  <{{ heading_tag }} class="{{ heading_classes }} rte">
                    {{ block.settings.heading }}
                  </{{ heading_tag }}>
                {%- endif -%}
                {%- if block.settings.text -%}
                  <div class="image-with-text__text rte {{ section.settings.text_style }}">
                    {{ block.settings.text }}
                  </div>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    {% if block.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link }}"
                    {% endif %}
                    class="{%- render 'ms_button_classes', type: section.settings.button_type, secondary: section.settings.button_style_secondary, size: section.settings.button_size -%}"
                  >
                    {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'before' -%}
                    {{ block.settings.button_label | escape }}
                    {%- render 'ms_button_icon', icon: section.settings.button_icon, position: section.settings.button_icon_position, slot: 'after' -%}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "MS Multirow",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width",
      "label": "Full width da mobile",
      "default": false,
      "info": "Se attivo, la sezione occupa tutta la larghezza su mobile/tablet senza padding laterale."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione di colori sezione",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "adapt", "label": "Adatta all'immagine" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "medium",
      "label": "Altezza immagine"
    },
    {
      "type": "select",
      "id": "desktop_image_width",
      "options": [
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "medium",
      "label": "Larghezza immagine desktop"
    },
    {
      "type": "select",
      "id": "image_layout",
      "options": [
        { "value": "alternate-left", "label": "Alternato da sinistra" },
        { "value": "alternate-right", "label": "Alternato da destra" },
        { "value": "align-left", "label": "Allineato a sinistra" },
        { "value": "align-right", "label": "Allineato a destra" }
      ],
      "default": "alternate-left",
      "label": "Disposizione immagine"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Piccolo" },
        { "value": "h1", "label": "Medio" },
        { "value": "h0", "label": "Grande" },
        { "value": "hxl", "label": "Extra grande" },
        { "value": "hxxl", "label": "Extra extra grande" }
      ],
      "default": "h1",
      "label": "Dimensione titolo"
    },
    {
      "type": "text",
      "id": "heading_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "select",
      "id": "text_style",
      "options": [
        { "value": "body", "label": "Corpo" },
        { "value": "subtitle", "label": "Sottotitolo" }
      ],
      "default": "body",
      "label": "Stile testo"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        { "value": "top", "label": "In alto" },
        { "value": "middle", "label": "Al centro" },
        { "value": "bottom", "label": "In basso" }
      ],
      "default": "middle",
      "label": "Posizione contenuto desktop"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "left",
      "label": "Allineamento contenuto desktop"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "left",
      "label": "Allineamento contenuto mobile"
    },
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "default": true,
      "label": "Stile contorno",
      "info": "Se attivo, il pulsante ha bordo visibile e sfondo trasparente."
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Tipo pulsante",
      "default": "button",
      "options": [
        { "value": "button", "label": "Pulsante" },
        { "value": "pill", "label": "Pill (arrotondato)" },
        { "value": "link", "label": "Solo link" }
      ]
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Dimensione pulsante",
      "info": "\"Predefinita\" usa il valore globale da Impostazioni tema.",
      "default": "default",
      "options": [
        { "value": "default", "label": "Predefinita" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "jumbo", "label": "Jumbo" },
        { "value": "extra_jumbo", "label": "Extra Jumbo" }
      ]
    },
    {
      "type": "text",
      "id": "button_icon",
      "label": "Icona pulsante",
      "info": "Nome file SVG (es. icon-arrow.svg) o classe icone (es. fa-solid fa-arrow-right). Vuoto = nessuna icona."
    },
    {
      "type": "select",
      "id": "button_icon_position",
      "label": "Posizione icona",
      "default": "before",
      "options": [
        { "value": "before", "label": "Prima del testo" },
        { "value": "after", "label": "Dopo il testo" }
      ]
    },
    {
      "type": "header",
      "content": "Colori riga"
    },
    {
      "type": "color_scheme",
      "id": "row_color_scheme",
      "label": "Combinazione colori riga",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spaziatura righe"
    },
    {
      "type": "range",
      "id": "row_space",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Spazio tra le righe desktop",
      "default": 16
    },
    {
      "type": "range",
      "id": "row_space_tablet",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Spazio tra le righe tablet",
      "default": 16
    },
    {
      "type": "range",
      "id": "row_space_mobile",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Spazio tra le righe mobile",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Riga",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Testo alternativo (ALT)",
          "info": "Se vuoto, viene usato l'ALT dell'immagine caricata su Shopify. Se anche quello è vuoto, viene generato dal nome del file."
        },
        {
          "type": "liquid",
          "id": "caption",
          "default": "Didascalia",
          "label": "Didascalia"
        },
        {
          "type": "liquid",
          "id": "heading",
          "default": "<strong>Titolo riga</strong>",
          "label": "Titolo"
        },
        {
          "type": "liquid",
          "id": "text",
          "default": "Associa un testo a un'immagine per dare importanza al prodotto, alla collezione o all'articolo del blog di tua scelta.",
          "label": "Testo"
        },
        {
          "type": "liquid",
          "id": "button_label",
          "default": "Etichetta pulsante",
          "label": "Etichetta pulsante",
          "info": "Lascia vuoto per nascondere il pulsante."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link pulsante"
        }
      ]
    },
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 100
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_padding_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 80
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_padding_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_padding_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 60
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Large/Desktop Device" },
        {
          "type": "range",
          "id": "section_margin_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet Device" },
        {
          "type": "range",
          "id": "section_margin_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile Device" },
        {
          "type": "range",
          "id": "section_margin_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "section_margin_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "BG Image"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "BG Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Multirow",
      "category": "Contenuti",
      "blocks": [
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
