{%- comment -%}
  MS Prodotti da Metafield
  ═══════════════════════════════════════════════════════════════
  Renderizza una griglia di prodotti selezionati tramite metafield.
  Supporta slider desktop/mobile, quick add, autoplay.
  Blocchi ms_section-style per padding, margin e background.
{%- endcomment -%}

{%- liquid
  assign products_list = section.settings.mf
  assign products_count = products_list.size | default: 0
-%}

{%- if products_count > 0 -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'template-collection.css' | asset_url | stylesheet_tag }}

  {%- if section.settings.image_shape == 'blob' -%}
    {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- unless section.settings.quick_add == 'none' -%}
    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- endunless -%}

  {%- if section.settings.quick_add == 'standard' -%}
    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if section.settings.quick_add == 'bulk' -%}
    <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- liquid
    comment
      ── Larghezza TITOLO ──
    endcomment
    assign tw = section.settings.title_width | default: 'page_width'
    if tw == 'default'
      assign tw = 'page_width'
    endif
    case tw
      when 'narrow'
        assign title_pw_class = 'page-width page-width--narrow'
      when 'page_fluid'
        assign title_pw_class = 'page-width page-width--fluid'
      when 'full_width'
        assign title_pw_class = ''
      else
        assign title_pw_class = 'page-width'
    endcase

    comment
      ── Larghezza SLIDER / GRIGLIA ──
      is_slider_full_width serve per le classi Dawn (collection--full-width,
      slider-component-full-width, title-wrapper--self-padded-tablet-down).
    endcomment
    assign sw = section.settings.slider_width | default: 'page_width'
    if sw == 'default'
      assign sw = 'page_width'
    endif
    assign is_slider_full_width = false
    if sw == 'full_width'
      assign is_slider_full_width = true
    endif
    assign peek = section.settings.carousel_peek_size | default: 'medium'
    case sw
      when 'narrow'
        assign slider_pw_class = 'page-width page-width--narrow'
      when 'page_fluid'
        assign slider_pw_class = 'page-width page-width--fluid'
      when 'full_width'
        assign slider_pw_class = ''
      else
        assign slider_pw_class = 'page-width'
    endcase

    assign products_to_show = section.settings.products_to_show
    if products_count > products_to_show
      assign products_to_display = products_to_show
    else
      assign products_to_display = products_count
    endif

    assign columns_mobile_int = section.settings.columns_mobile | plus: 0
    assign show_mobile_slider = false
    if section.settings.swipe_on_mobile and products_to_display > columns_mobile_int
      assign show_mobile_slider = true
    endif

    assign show_desktop_slider = false
    if section.settings.enable_desktop_slider and products_to_display > section.settings.columns_desktop
      assign show_desktop_slider = true
    endif
  -%}

  {%- unless is_slider_full_width -%}
    {%- if show_desktop_slider -%}
      {% style %}
        @media screen and (min-width: 990px) {
          #collection-{{ section.id }} .slider.slider--desktop {
            margin-left: 0;
            scroll-padding-left: 0;
          }
          {%- if peek == 'none' -%}
          #collection-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: 100%; }
          #collection-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2); }
          #collection-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
          #collection-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(25% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
          #collection-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(20% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
          #collection-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(16.66% - var(--grid-desktop-horizontal-spacing) * 5 / 6); }
          {%- elsif peek == 'small' -%}
          #collection-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(75% - var(--grid-desktop-horizontal-spacing) * 3 / 4); }
          #collection-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(42.857% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
          #collection-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(30% - var(--grid-desktop-horizontal-spacing) * 9 / 10); }
          #collection-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(23.077% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
          #collection-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.75% - var(--grid-desktop-horizontal-spacing) * 15 / 16); }
          #collection-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.789% - var(--grid-desktop-horizontal-spacing) * 18 / 19); }
          {%- elsif peek == 'large' -%}
          #collection-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(57.143% - var(--grid-desktop-horizontal-spacing) * 4 / 7); }
          #collection-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(36.364% - var(--grid-desktop-horizontal-spacing) * 8 / 11); }
          #collection-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(26.667% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
          #collection-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(21.053% - var(--grid-desktop-horizontal-spacing) * 16 / 19); }
          #collection-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(17.391% - var(--grid-desktop-horizontal-spacing) * 20 / 23); }
          #collection-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(14.815% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
          {%- else -%}
          #collection-{{ section.id }} .slider--desktop.grid--1-col-desktop .grid__item { width: calc(66.667% - var(--grid-desktop-horizontal-spacing) * 2 / 3); }
          #collection-{{ section.id }} .slider--desktop.grid--2-col-desktop .grid__item { width: calc(40% - var(--grid-desktop-horizontal-spacing) * 4 / 5); }
          #collection-{{ section.id }} .slider--desktop.grid--3-col-desktop .grid__item { width: calc(28.571% - var(--grid-desktop-horizontal-spacing) * 6 / 7); }
          #collection-{{ section.id }} .slider--desktop.grid--4-col-desktop .grid__item { width: calc(22.222% - var(--grid-desktop-horizontal-spacing) * 8 / 9); }
          #collection-{{ section.id }} .slider--desktop.grid--5-col-desktop .grid__item { width: calc(18.182% - var(--grid-desktop-horizontal-spacing) * 10 / 11); }
          #collection-{{ section.id }} .slider--desktop.grid--6-col-desktop .grid__item { width: calc(15.385% - var(--grid-desktop-horizontal-spacing) * 12 / 13); }
          {%- endif -%}
        }
      {% endstyle %}
    {%- endif -%}
  {%- endunless -%}

  <div class="color-{{ section.settings.color_scheme }} isolate gradient" id="section-{{ section.id }}">
    <div
      class="collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if is_slider_full_width %} collection--full-width{% endif %}"
      id="collection-{{ section.id }}"
      data-id="{{ section.id }}"
    >

      {%- comment -%} ── TITOLO / TESTO — wrapper indipendente ── {%- endcomment -%}
      {%- if title_pw_class != blank -%}<div class="{{ title_pw_class }}">{%- endif -%}
      <div class="collection__title title-wrapper title-wrapper--no-top-margin{% if show_mobile_slider and tw == 'full_width' %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
        {%- if section.settings.title != blank -%}
          {%- assign t_tag = section.settings.title_tag | default: 'h2' -%}
          <{{ t_tag }} class="title {{ section.settings.heading_size }}{% if section.settings.title_custom_class != blank %} {{ section.settings.title_custom_class }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
            {{- section.settings.title | escape -}}
          </{{ t_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
      {%- if title_pw_class != blank -%}</div>{%- endif -%}

      {%- comment -%}
        ── SLIDER / GRIGLIA — wrapper indipendente ──
        page-width è applicato sul wrapper (e non sullo slider) perché Dawn
        sovrascrive max-width su .slider-component-desktop.page-width
        (component-slider.css:136).
      {%- endcomment -%}
      {%- if slider_pw_class != blank -%}<div class="{{ slider_pw_class }}">{%- endif -%}
      <slider-component
        data-autoplay="{{ section.settings.enable_desktop_slider_autoplay }}"
        data-speed="{{ section.settings.desktop_slider_autoplay_velocita }}000"
        data-scroll-mode="{{ section.settings.carousel_scroll_mode | default: 'page' }}"
        data-loop="{{ section.settings.carousel_loop | default: 'circular' }}"
        data-peek="{{ section.settings.carousel_peek_size | default: 'medium' }}"
        class="slider-mobile-gutter{% if is_slider_full_width %} slider-component-full-width{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if section.settings.carousel_arrows_position == 'overlay_sides' %} ms-carousel--arrows-overlay-sides{% elsif section.settings.carousel_arrows_position == 'above_right' %} ms-carousel--arrows-above-right{% endif %}{% if section.settings.carousel_arrows_overlay_dark %} ms-carousel--arrows-overlay-dark{% endif %}{% unless section.settings.carousel_show_arrows == nil %}{% unless section.settings.carousel_show_arrows %} ms-carousel--no-arrows{% endunless %}{% endunless %}{% unless section.settings.carousel_show_pagination == nil %}{% unless section.settings.carousel_show_pagination %} ms-carousel--no-pagination{% endunless %}{% endunless %}"
        {% unless is_slider_full_width %}style="--desktop-margin-left-first-item: 0px"{% endunless %}
      >
        <ul
          id="Slider-{{ section.id }}"
          class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
          role="list"
          aria-label="{{ section.settings.title | default: 'Prodotti correlati' | escape }}"
        >
          {%- for product in products_list limit: products_to_show -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}"
            >
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                show_min_order: section.settings.show_min_order,
                section_id: section.id,
                quick_add: section.settings.quick_add
              %}
            </li>
          {%- endfor -%}
        </ul>

        {%- if show_mobile_slider or show_desktop_slider -%}
          {%- render 'ms_carousel-controls',
            section_id: section.id,
            total_items: products_to_display,
            pagination_style: section.settings.carousel_pagination_style,
            show_arrows: section.settings.carousel_show_arrows,
            show_pagination: section.settings.carousel_show_pagination,
            enable_autoplay: section.settings.enable_desktop_slider_autoplay
          -%}
        {%- endif -%}
      </slider-component>
      {%- if slider_pw_class != blank -%}</div>{%- endif -%}

      {%- if section.settings.image_shape == 'arch' -%}
        {{ 'mask-arch.svg' | inline_asset_content }}
      {%- endif -%}
    </div>
  </div>

  {%- render 'ms_section-style' -%}

{%- elsif request.design_mode -%}
  <div class="page-width center" id="section-{{ section.id }}" style="padding: 50px; border: 1px dashed #ccc; margin: 20px auto;">
    <p><strong>MS Prodotti da Metafield:</strong> Nessun prodotto associato. Collega il metafield nell'editor.</p>
  </div>
  {%- render 'ms_section-style' -%}
{%- endif -%}

{% schema %}
{
  "name": "MS Prodotti da Metafield",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "title_width",
      "label": "Larghezza titolo / testo",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "select",
      "id": "slider_width",
      "label": "Larghezza carosello / griglia",
      "options": [
        { "value": "narrow", "label": "Stretta (narrow)" },
        { "value": "page_width", "label": "Larghezza pagina" },
        { "value": "page_fluid", "label": "Larghezza fluida" },
        { "value": "full_width", "label": "Piena larghezza" }
      ],
      "default": "page_width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "product_list",
      "id": "mf",
      "label": "Metafield prodotti",
      "info": "Seleziona i prodotti da mostrare. Utilizza un metafield di tipo product_list per il collegamento dinamico."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_to_show.label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Prodotti correlati",
      "label": "t:sections.featured-collection.settings.title.label"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Tag titolo",
      "options": [
        { "label": "H1", "value": "h1" },
        { "label": "H2", "value": "h2" },
        { "label": "H3", "value": "h3" },
        { "label": "H4", "value": "h4" },
        { "label": "H5", "value": "h5" },
        { "label": "H6", "value": "h6" },
        { "label": "Paragrafo", "value": "p" },
        { "label": "Div", "value": "div" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "title_custom_class",
      "label": "Classe CSS personalizzata titolo",
      "info": "Classe aggiuntiva (opzionale). Le classi esistenti vengono mantenute."
    },
    {
      "type": "liquid",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.featured-collection.settings.description_style.label",
      "options": [
        { "value": "body", "label": "t:sections.featured-collection.settings.description_style.options__1.label" },
        { "value": "subtitle", "label": "t:sections.featured-collection.settings.description_style.options__2.label" },
        { "value": "uppercase", "label": "t:sections.featured-collection.settings.description_style.options__3.label" }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.featured-collection.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.featured-collection.settings.image_ratio.options__2.label" },
        { "value": "square", "label": "t:sections.featured-collection.settings.image_ratio.options__3.label" }
      ],
      "default": "adapt",
      "label": "t:sections.featured-collection.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        { "value": "default", "label": "t:sections.all.image_shape.options__1.label" },
        { "value": "arch", "label": "t:sections.all.image_shape.options__2.label" },
        { "value": "blob", "label": "t:sections.all.image_shape.options__3.label" },
        { "value": "chevronleft", "label": "t:sections.all.image_shape.options__4.label" },
        { "value": "chevronright", "label": "t:sections.all.image_shape.options__5.label" },
        { "value": "diamond", "label": "t:sections.all.image_shape.options__6.label" },
        { "value": "parallelogram", "label": "t:sections.all.image_shape.options__7.label" },
        { "value": "round", "label": "t:sections.all.image_shape.options__8.label" }
      ],
      "default": "default",
      "label": "t:sections.all.image_shape.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_secondary_image.label"
    },
    {
      "type": "header",
      "content": "Carosello"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider_autoplay",
      "label": "Abilita autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_slider_autoplay_velocita",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Tempo transizione (sec.)"
    },
    {
      "type": "select",
      "id": "carousel_loop",
      "label": "Tipo loop",
      "default": "circular",
      "options": [
        { "value": "none",     "label": "Nessuno (si ferma alla fine)" },
        { "value": "rewind",   "label": "Rewind (torna all'inizio)" },
        { "value": "circular", "label": "Circolare (infinito)" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_peek_size",
      "label": "Anteprima prossimo elemento",
      "default": "medium",
      "options": [
        { "value": "none", "label": "Nessuna" },
        { "value": "small", "label": "Piccola" },
        { "value": "medium", "label": "Media" },
        { "value": "large", "label": "Grande" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_arrows_position",
      "label": "Posizionamento frecce",
      "default": "below_center",
      "options": [
        { "value": "below_center", "label": "Sotto (centrato)" },
        { "value": "overlay_sides", "label": "Ai lati (sovrapposto)" },
        { "value": "above_right", "label": "Sopra a destra" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_arrows_overlay_dark",
      "label": "Frecce overlay in tema scuro",
      "default": false,
      "info": "Attivo solo con posizionamento 'Ai lati (sovrapposto)'"
    },
    {
      "type": "select",
      "id": "carousel_pagination_style",
      "label": "Stile paginazione",
      "default": "counter",
      "options": [
        { "value": "counter", "label": "Contatore (1 / 5)" },
        { "value": "dots", "label": "Pallini" },
        { "value": "numbers", "label": "Numeri" },
        { "value": "none", "label": "Nessuna" }
      ]
    },
    {
      "type": "select",
      "id": "carousel_scroll_mode",
      "label": "Modalità scorrimento",
      "default": "page",
      "options": [
        { "value": "page", "label": "Pagina (set di elementi)" },
        { "value": "single", "label": "Singolo elemento" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_show_arrows",
      "label": "Mostra frecce",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel_show_pagination",
      "label": "Mostra paginazione",
      "default": true
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label" }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.featured-collection.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "Scheda prodotto"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_vendor.label"
