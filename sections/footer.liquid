{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<footer id="section-{{ section.id }}" class="footer color-{{ section.settings.color_scheme }} gradient">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width">
        {%- if section.blocks.size > 0 -%}
          {%- liquid
            if section.blocks.size == 9
              assign footer_grid_class = 'grid--3-col-tablet'
            elsif section.blocks.size > 6
              assign footer_grid_class = 'grid--4-col-desktop'
            elsif section.blocks.size > 4
              assign footer_grid_class = 'grid--3-col-tablet'
            endif
          -%}
          <div
            class="footer__blocks-wrapper grid grid--1-col grid--2-col grid--4-col-tablet {{ footer_grid_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- for block in section.blocks -%}
              {%- if block.type == 'section_padding' or block.type == 'section_margin' or block.type == 'section_background' -%}
                {%- continue -%}
              {%- endif -%}
              <div
                class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.heading != blank -%}
                  <div class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</div>
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- when 'link_list' -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <div class="footer-block__heading rte">{{ settings.brand_headline }}</div>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social' -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                    <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                      {%- if block.settings.image != blank -%}
                        {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ block.settings.image_width }}px);"
                        >
                          <img
                            srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                            src="{{ block.settings.image | image_url: width: 760 }}"
                            alt="{{ block.settings.image.alt | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                          >
                        </div>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div
          class="footer-block--newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {%- if section.settings.newsletter_enable -%}
            <div class="footer-block__newsletter">
              {%- if section.settings.newsletter_heading != blank -%}
                <div class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</div>
              {%- endif -%}
              {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-form__field-wrapper">
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="ContactFooter-error"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="ContactFooter-success"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                    <label class="field__label" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      id="Subscribe"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      {%- render 'ms_icon', icon: settings.ms_icon_arrow -%}
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="ContactFooter-error">
                      {%- render 'ms_icon', icon: settings.ms_icon_error -%}
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    {%- render 'ms_icon', icon: settings.ms_icon_success -%}
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- endif -%}

          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_social and has_social_icons -%}
            {%- render 'social-icons', class: 'footer__list-social' -%}
          {%- endif -%}
        </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

  <div
    class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <div class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</div>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <div class="h2 caption-large text-body" id="FooterLanguageLabel">
                  {{ 'localization.language_label' | t }}
                </div>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content"
          >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
        </small>
        |
        <small class="copyright__content"
          >powered by
          <a
            href="https://www.makingscience.com/"
            title="Making Science web site"
            aria-label="Making Science web site"
            rel="noopener"
            ><b>Making Science</b></a
          ></small
        >
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            {% if settings.iub_cookieid != blank %}
              <li>
                <small class="copyright__content"
                  ><a
                    href="https://www.iubenda.com/privacy-policy/{{ settings.iub_cookieid }}/cookie-policy"
                    class="legal-link"
                    data-title="{{ "dcpd.footer.cookie_link_label" | t }}"
                    data-policy-modal
                  >
                    {{ 'dcpd.footer.cookie_link_label' | t }}
                  </a></small
                >
              </li>
            {% endif %}
            {% if settings.iub_privacyid != blank %}
              {% assign handle-p = policy.url | split: '/' | last %}
              <li>
                <small class="copyright__content"
                  ><a
                    href="https://www.iubenda.com/privacy-policy/{{ settings.iub_privacyid }}/full-legal"
                    class="legal-link"
                    data-title="{{ 'dcpd.footer.privacy_link_label' | t }}"
                    data-policy-modal
                  >
                    {{ 'dcpd.footer.privacy_link_label' | t }}
                  </a></small
                >
              </li>
            {% endif %}
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                {% if settings.iub_privacyid != blank %}
                  {% assign handle-p = policy.url | split: '/' | last %}
                  {% unless handle-p == 'privacy-policy' %}
                    <li>
                      <small class="copyright__content"
                        ><a href="{{ policy.url }}" class="fetch-policy" data-title="{{ policy.title | escape }}">
                          {{- policy.title | escape -}}
                        </a></small
                      >
                    </li>
                  {% endunless %}
                {% else %}
                  <li>
                    <small class="copyright__content"
                      ><a href="{{ policy.url }}" class="fetch-policy" data-title="{{ policy.title | escape }}">
                          {{- policy.title | escape -}}
                        </a></small
                      >
                  </li>
                {% endif %}
              {% endif %}
            {%- endfor -%}
            {% if settings.iub_cookieid != blank and settings.iub_siteid != blank %}
              <li>
                <small class="copyright__content"
                  ><a href="#" class="iubenda-cs-preferences-link">
                    {{- 'dcpd.footer.cookie_modifica_label' | t -}}
                  </a></small
                >
              </li>
            {% endif %}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<div class="bootstrap-scope">
  <div class="modal fade" id="legalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-body" id="legalModalContent"></div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const modalEl = document.getElementById('legalModal');
    const modalScope = modalEl.closest('.bootstrap-scope');
    const modalContent = document.getElementById('legalModalContent');
    const modal = new bootstrap.Modal(modalEl);

    function insertBackdropInScope() {
      modalScope.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
      const backdrop = document.createElement('div');
      backdrop.className = 'modal-backdrop fade show';
      backdrop.innerHTML = '&nbsp;';
      modalScope.appendChild(backdrop);
    }

    function removeBackdropFromScope() {
      modalScope.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
    }

    modalEl.addEventListener('hidden.bs.modal', function () {
      removeBackdropFromScope();
    });

    function showModalWithContent(contentHTML) {
      modalContent.innerHTML = `
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ "dcpd.modal.close" | t }}"></button>
        ${contentHTML}
      `;
      insertBackdropInScope();
      modal.show();
    }

    document.querySelectorAll('a[data-policy-modal], a.fetch-policy').forEach(link => {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        const url = this.href;

        if (this.classList.contains('fetch-policy')) {
          modalContent.innerHTML = `
            <div class="d-flex justify-content-center align-items-center" style="height:200px;">
              <p>Caricamento...</p>
            </div>
          `;
          insertBackdropInScope();
          modal.show();

          fetch(url)
            .then(response => {
              if (!response.ok) throw new Error('Errore nel caricamento');
              return response.text();
            })
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const main = doc.querySelector('main') || doc.body;
              showModalWithContent(main.innerHTML);
            })
            .catch(() => {
              showModalWithContent(`
                <div class="d-flex justify-content-center align-items-center" style="height:200px;">
                  <p class="text-danger">Impossibile caricare il contenuto.</p>
                </div>
              `);
            });
        } else {
          showModalWithContent(`
            <iframe src="${url}" frameborder="0" width="100%" height="600px" style="border:0;"></iframe>
          `);
        }
      });
    });
  });
</script>

<style scoped>
  #legalModal .btn-close{position:sticky;top:10px;right:10px;float:right;}
  #legalModalContent {padding:30px 10%;}
</style>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Link rapidi",
          "label": "Titolo"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "Informazioni sul brand",
      "settings": [
        {
          "type": "paragraph",
          "content": "Gestisci le informazioni sul brand nelle impostazioni tema"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Icone social media",
          "info": "Gestisci account social nelle impostazioni tema"
        }
      ]
    },
    {
      "type": "text",
      "name": "Testo",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Titolo",
          "label": "Titolo"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Condividi informazioni di contatto, dettagli del negozio e contenuti del brand con i clienti.</p>",
          "label": "Sottotesto"
        }
      ]
    },
    {
      "type": "image",
      "name": "Immagine",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Larghezza",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Allineamento",
          "options": [
            { "value": "", "label": "Sinistra" },
            { "value": "center", "label": "Centro" },
            { "value": "right", "label": "Destra" }
          ],
          "default": "center"
        }
      ]
    },
    {
      "type": "section_padding",
      "name": "Section Padding",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Desktop" },
        {
          "type": "range", "id": "section_padding_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 35
        },
        {
          "type": "range", "id": "section_padding_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 35
        },
        { "type": "header", "content": "Tablet" },
        {
          "type": "range", "id": "section_padding_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 25
        },
        {
          "type": "range", "id": "section_padding_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 25
        },
        { "type": "header", "content": "Mobile" },
        {
          "type": "range", "id": "section_padding_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Top", "unit": "px", "default": 25
        },
        {
          "type": "range", "id": "section_padding_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Padding Bottom", "unit": "px", "default": 25
        }
      ]
    },
    {
      "type": "section_margin",
      "name": "Section Margin",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Desktop" },
        {
          "type": "range", "id": "section_margin_top",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range", "id": "section_margin_bottom",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Tablet" },
        {
          "type": "range", "id": "section_margin_top_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range", "id": "section_margin_bottom_md",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        },
        { "type": "header", "content": "Mobile" },
        {
          "type": "range", "id": "section_margin_top_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Top", "unit": "px", "default": 0
        },
        {
          "type": "range", "id": "section_margin_bottom_xs",
          "min": 0, "max": 150, "step": 5,
          "label": "Margin Bottom", "unit": "px", "default": 0
        }
      ]
    },
    {
      "type": "section_background",
      "name": "Section Background",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "section_bg_image",
          "label": "Immagine sfondo"
        },
        {
          "type": "color",
          "id": "section_bg_color",
          "label": "Colore sfondo",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinazione colori",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Iscrizione alla newsletter",
      "info": "Le iscrizioni vengono aggiunte ai profili cliente"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Mostra iscrizione newsletter"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "Iscriviti alle nostre email",
      "label": "Titolo newsletter"
    },
    {
      "type": "header",
      "content": "Utility"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": true,
      "label": "Segui su Shop",
      "info": "Shop Pay deve essere abilitato"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "Icone social media",
      "info": "Gestisci account social nelle impostazioni tema"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "Selettore Paese/area geografica",
      "info": "Gestisci Paesi nelle impostazioni Markets"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Selettore lingua",
      "info": "Gestisci lingue nelle impostazioni"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Icone metodi di pagamento"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "Link alle informative",
      "info": "Gestisci informative nelle impostazioni legali"
    }
