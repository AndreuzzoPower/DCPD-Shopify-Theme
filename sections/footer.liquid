{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'ms_footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sw = section.settings.section_width | default: 'page_width'
  if sw == 'default'
    assign sw = 'page_width'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
    else
      assign sw_class = 'page-width'
  endcase
-%}

{%- render 'ms_mobile-padding' -%}

<footer id="section-{{ section.id }}" class="footer color-{{ section.settings.color_scheme }} gradient">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    assign content_blocks_count = 0
    for block in section.blocks
      unless block.type == 'section_padding' or block.type == 'section_margin' or block.type == 'section_background'
        assign content_blocks_count = content_blocks_count | plus: 1
      endunless
    endfor

    if content_blocks_count == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}

  {%- if content_blocks_count > 0
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top {{ sw_class }}">
        {%- if content_blocks_count > 0 -%}
          <div class="ms-footer-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'section_padding' or block.type == 'section_margin' or block.type == 'section_background' -%}
                {%- continue -%}
              {%- endif -%}

              {%- liquid
                assign b_desk = block.settings.desktop_layout | default: 3
                assign b_tab = block.settings.tablet_layout | default: 6
                assign b_mob = block.settings.mobile_layout | default: 12
                assign b_heading_tag = block.settings.heading_tag | default: 'div'
                assign b_heading_size = block.settings.heading_size | default: 'h5'
                assign b_mobile_accordion = block.settings.mobile_accordion | default: false
                assign b_mobile_open = block.settings.mobile_accordion_open | default: false
              -%}

              <style>
                #footer-block-{{ block.id }} { grid-column: span {{ b_mob }}; }
                @media (min-width: 750px) { #footer-block-{{ block.id }} { grid-column: span {{ b_tab }}; } }
                @media (min-width: 990px) { #footer-block-{{ block.id }} { grid-column: span {{ b_desk }}; } }
              </style>

              {%- if block.type == 'image' and block.settings.hide_mobile -%}
                <div
                  id="footer-block-{{ block.id }}"
                  class="ms-footer-block ms-footer-block--hidden-mobile footer-block"
                  {{ block.shopify_attributes }}
                >
              {%- else -%}
                <div
                  id="footer-block-{{ block.id }}"
                  class="ms-footer-block footer-block{% if block.type == 'link_list' %} footer-block--menu{% endif %}"
                  {{ block.shopify_attributes }}
                >
              {%- endif -%}

                {%- if b_mobile_accordion and block.type != 'image' -%}
                  <div class="ms-footer-accordion{% if b_mobile_open %} ms-footer-accordion--open{% endif %}">
                    {%- if block.settings.heading != blank -%}
                      <div class="ms-footer-accordion__trigger" role="button" tabindex="0" aria-expanded="{{ b_mobile_open }}" aria-controls="footer-accordion-{{ block.id }}">
                        <{{ b_heading_tag }} class="footer-block__heading inline-richtext {{ b_heading_size }}">
                          {{- block.settings.heading -}}
                        </{{ b_heading_tag }}>
                        <svg class="ms-footer-accordion__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                      </div>
                    {%- endif -%}
                    <div class="ms-footer-accordion__content" id="footer-accordion-{{ block.id }}">
                {%- else -%}
                  {%- if block.settings.heading != blank -%}
                    <{{ b_heading_tag }} class="footer-block__heading inline-richtext {{ b_heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ b_heading_tag }}>
                  {%- endif -%}
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- when 'link_list' -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <div class="footer-block__heading rte">{{ settings.brand_headline }}</div>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social' -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                    {%- capture footer_img_alt -%}
                      {%- render 'ms_image_alt', image: block.settings.image, custom_alt: block.settings.image_alt -%}
                    {%- endcapture -%}
                    {%- assign footer_img_alt = footer_img_alt | strip -%}
                    <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                      {%- if block.settings.image != blank -%}
                        {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ block.settings.image_width }}px);"
                        >
                          <img
                            srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                            src="{{ block.settings.image | image_url: width: 760 }}"
                            alt="{{ footer_img_alt | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                          >
                        </div>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                  {%- when 'html_liquid' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.custom_content }}
                    </div>
                  {%- when 'newsletter' -%}
                    <div class="footer-block__newsletter">
                      {%- if block.settings.description != blank -%}
                        <div class="footer-block__description rte">{{ block.settings.description }}</div>
                      {%- endif -%}
                      {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="newsletter-form__field-wrapper">
                          <div class="field">
                            <input
                              id="NewsletterForm--{{ section.id }}"
                              type="email"
                              name="contact[email]"
                              class="field__input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              {% if form.errors %}
                                autofocus
                                aria-invalid="true"
                                aria-describedby="ContactFooter-error"
                              {% elsif form.posted_successfully? %}
                                aria-describedby="ContactFooter-success"
                              {% endif %}
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <label class="field__label" for="NewsletterForm--{{ section.id }}">
                              {{ 'newsletter.label' | t }}
                            </label>
                            <button
                              type="submit"
                              class="newsletter-form__button field__button"
                              name="commit"
                              id="Subscribe"
                              aria-label="{{ 'newsletter.button_label' | t }}"
                            >
                              {%- render 'ms_icon', icon: settings.ms_icon_arrow -%}
                            </button>
                          </div>
                          {%- if form.errors -%}
                            <small class="newsletter-form__message form__message" id="ContactFooter-error">
                              {%- render 'ms_icon', icon: settings.ms_icon_error -%}
                              {{- form.errors.translated_fields.email | capitalize }}
                              {{ form.errors.messages.email -}}
                            </small>
                          {%- endif -%}
                        </div>
                        {%- if block.settings.privacy_label != blank -%}
                          <div class="ms-newsletter-privacy">
                            <label class="ms-newsletter-privacy__label">
                              <input
                                type="checkbox"
                                name="contact[privacy_accepted]"
                                required
                                aria-required="true"
                                class="ms-newsletter-privacy__checkbox"
                              >
                              <span class="ms-newsletter-privacy__text rte">
                                {{ block.settings.privacy_label }}
                              </span>
                            </label>
                          </div>
                        {%- endif -%}
                        {%- if form.posted_successfully? -%}
                          <h3
                            class="newsletter-form__message newsletter-form__message--success form__message"
                            id="ContactFooter-success"
                            tabindex="-1"
                            autofocus
                          >
                            {%- render 'ms_icon', icon: settings.ms_icon_success -%}
                            {{- 'newsletter.success' | t }}
                          </h3>
                        {%- endif -%}
                      {%- endform -%}
                    </div>
                {%- endcase -%}

                {%- if b_mobile_accordion and block.type != 'image' -%}
                    </div>
                  </div>
                {%- endif -%}

              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
          <div class="footer__follow-on-shop">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {%- endif -%}

        {%- if section.settings.show_social and has_social_icons -%}
          <div class="footer__list-social-wrapper">
            {%- render 'social-icons', class: 'footer__list-social' -%}
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}
  {%- endif -%}

  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <div class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</div>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <div class="h2 caption-large text-body" id="FooterLanguageLabel">
                  {{ 'localization.language_label' | t }}
                </div>
                {%- render 'language-localization', localPosition: 'FooterLanguage', displayMode: section.settings.language_display_mode, displayFormat: section.settings.language_display_format -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content"
          >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
        </small>
        |
        <small class="copyright__content"
          >powered by
          <a
            href="https://www.makingscience.com/"
            title="Making Science web site"
            aria-label="Making Science web site"
            rel="noopener"
            ><b>Making Science</b></a
          ></small
        >
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            {% if settings.iub_cookieid != blank %}
              <li>
                <small class="copyright__content"
                  ><a
                    href="https://www.iubenda.com/privacy-policy/{{ settings.iub_cookieid }}/cookie-policy"
                    class="legal-link"
                    data-title="{{ "dcpd.footer.cookie_link_label" | t }}"
                    data-policy-modal
                  >
                    {{ 'dcpd.footer.cookie_link_label' | t }}
                  </a></small
                >
              </li>
            {% endif %}
            {% if settings.iub_privacyid != blank %}
              {% assign handle-p = policy.url | split: '/' | last %}
              <li>
                <small class="copyright__content"
                  ><a
                    href="https://www.iubenda.com/privacy-policy/{{ settings.iub_privacyid }}/full-legal"
                    class="legal-link"
                    data-title="{{ 'dcpd.footer.privacy_link_label' | t }}"
                    data-policy-modal
                  >
                    {{ 'dcpd.footer.privacy_link_label' | t }}
                  </a></small
                >
              </li>
            {% endif %}
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                {% if settings.iub_privacyid != blank %}
                  {% assign handle-p = policy.url | split: '/' | last %}
                  {% unless handle-p == 'privacy-policy' %}
                    <li>
                      <small class="copyright__content"
                        ><a href="{{ policy.url }}" class="fetch-policy" data-title="{{ policy.title | escape }}">
                          {{- policy.title | escape -}}
                        </a></small
                      >
                    </li>
                  {% endunless %}
                {% else %}
                  <li>
                    <small class="copyright__content"
                      ><a href="{{ policy.url }}" class="fetch-policy" data-title="{{ policy.title | escape }}">
                          {{- policy.title | escape -}}
                        </a></small
                      >
                  </li>
                {% endif %}
              {% endif %}
            {%- endfor -%}
            {% if settings.iub_cookieid != blank and settings.iub_siteid != blank %}
              <li>
                <small class="copyright__content"
                  ><a href="#" class="iubenda-cs-preferences-link">
                    {{- 'dcpd.footer.cookie_modifica_label' | t -}}
                  </a></small
                >
              </li>
            {% endif %}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<div class="bootstrap-scope">
  <div class="modal fade" id="legalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-body" id="legalModalContent"></div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const modalEl = document.getElementById('legalModal');
    const modalScope = modalEl.closest('.bootstrap-scope');
    const modalContent = document.getElementById('legalModalContent');
    const modal = new bootstrap.Modal(modalEl);

    function insertBackdropInScope() {
      modalScope.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
      const backdrop = document.createElement('div');
      backdrop.className = 'modal-backdrop fade show';
      backdrop.innerHTML = '&nbsp;';
      modalScope.appendChild(backdrop);
    }

    function removeBackdropFromScope() {
      modalScope.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
    }

    modalEl.addEventListener('hidden.bs.modal', function () {
      removeBackdropFromScope();
    });

    function showModalWithContent(contentHTML) {
      modalContent.innerHTML = `
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ "dcpd.modal.close" | t }}"></button>
        ${contentHTML}
      `;
      insertBackdropInScope();
      modal.show();
    }

    document.querySelectorAll('a[data-policy-modal], a.fetch-policy').forEach(link => {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        const url = this.href;

        if (this.classList.contains('fetch-policy')) {
          modalContent.innerHTML = `
            <div class="d-flex justify-content-center align-items-center" style="height:200px;">
              <p>Caricamento...</p>
            </div>
          `;
          insertBackdropInScope();
          modal.show();

          fetch(url)
            .then(response => {
              if (!response.ok) throw new Error('Errore nel caricamento');
              return response.text();
            })
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const main = doc.querySelector('main') || doc.body;
              showModalWithContent(main.innerHTML);
            })
            .catch(() => {
              showModalWithContent(`
                <div class="d-flex justify-content-center align-items-center" style="height:200px;">
                  <p class="text-danger">Impossibile caricare il contenuto.</p>
                </div>
              `);
            });
        } else {
          showModalWithContent(`
            <iframe src="${url}" frameborder="0" width="100%" height="600px" style="border:0;"></iframe>
          `);
        }
      });
    });
  });
</script>

<style scoped>
  #legalModal .btn-close{position:sticky;top:10px;right:10px;float:right;}
  #legalModalContent {padding:30px 10%;}
</style>

<script>
  (function() {
    document.querySelectorAll('.ms-footer-accordion__trigger').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var acc = this.closest('.ms-footer-accordion');
        acc.classList.toggle('ms-footer-accordion--open');
        this.setAttribute('aria-expanded', acc.classList.contains('ms-footer-accordion--open'));
      });
      trigger.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    });
  })();
</script>

{%- render 'ms_section-style' -%}

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "id": "desktop_layout",
          "label": "Colonne desktop",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 3,
          "info": "Schermi maggiori di 990px"
        },
        {
          "id": "tablet_layout",
          "label": "Colonne tablet",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 6,
          "info": "Schermi tra 750px e 990px"
        },
        {
          "id": "mobile_layout",
          "label": "Colonne mobile",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 12,
          "info": "Schermi sotto i 750px"
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "checkbox",
          "id": "mobile_accordion",
          "label": "Chiudibile su mobile",
          "default": true,
          "info": "Il blocco diventa un accordion su mobile"
        },
        {
          "type": "checkbox",
          "id": "mobile_accordion_open",
          "label": "Aperto di default su mobile",
          "default": false
        },
        {
          "type": "header",
          "content": "Contenuto"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Link rapidi",
          "label": "Titolo"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Tag titolo",
          "options": [
            { "label": "H2", "value": "h2" },
            { "label": "H3", "value": "h3" },
            { "label": "H4", "value": "h4" },
            { "label": "H5", "value": "h5" },
            { "label": "H6", "value": "h6" },
            { "label": "Div", "value": "div" }
          ],
          "default": "div"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Dimensione titolo",
          "options": [
            { "label": "Piccola", "value": "h6" },
            { "label": "Media", "value": "h5" },
            { "label": "Grande", "value": "h4" },
            { "label": "Extra grande", "value": "h3" }
          ],
          "default": "h5"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Testo",
      "settings": [
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "id": "desktop_layout",
          "label": "Colonne desktop",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 3,
          "info": "Schermi maggiori di 990px"
        },
        {
          "id": "tablet_layout",
          "label": "Colonne tablet",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 6,
          "info": "Schermi tra 750px e 990px"
        },
        {
          "id": "mobile_layout",
          "label": "Colonne mobile",
          "type": "range",
          "min": 1, "max": 12, "step": 1, "unit": "col",
          "default": 12,
          "info": "Schermi sotto i 750px"
        },
        {
          "type": "header",
          "content": "Mobile"
        },
        {
          "type": "checkbox",
          "id": "mobile_accordion",
          "label": "Chiudibile su mobile",
          "default": false,
