        { "label": "Naturale (proporzioni video)", "value": "natural" },
        { "label": "Piccola", "value": "small" },
        { "label": "Media", "value": "medium" },
        { "label": "Grande", "value": "large" },
        { "label": "Altezza viewport", "value": "viewport" }
      ],
      "default": "medium",
      "info": "\"Naturale\" adatta l'altezza alle proporzioni originali del video. Le altre opzioni fissano l'altezza e tagliano il video se necessario."
