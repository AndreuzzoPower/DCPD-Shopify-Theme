{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'ms_video.css' | asset_url | stylesheet_tag }}
{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- comment -%} Block-driven styles (padding, margin, background) {%- endcomment -%}
{% for block in section.blocks %}
  {% assign bs = block.settings %}
  {% if block.type == 'section_padding' %}
    {%- if section.settings.video_mode == 'background' -%}
      <style>
        #shopify-section-{{ section.id }} .banner__content {
          padding-top: {{ bs.section_padding_top }}px;
          padding-bottom: {{ bs.section_padding_bottom }}px;
        }
        @media all and (min-width: 768px) and (max-width: 991px) {
          #shopify-section-{{ section.id }} .banner__content {
            padding-top: {{ bs.section_padding_top_md }}px;
            padding-bottom: {{ bs.section_padding_bottom_md }}px;
          }
        }
        @media all and (max-width: 767px) {
          #shopify-section-{{ section.id }} .banner__content {
            padding-top: {{ bs.section_padding_top_xs }}px;
            padding-bottom: {{ bs.section_padding_bottom_xs }}px;
          }
        }
      </style>
    {%- else -%}
      <style>
        #shopify-section-{{ section.id }} {
          padding-top: {{ bs.section_padding_top }}px;
          padding-bottom: {{ bs.section_padding_bottom }}px;
        }
        @media all and (min-width: 768px) and (max-width: 991px) {
          #shopify-section-{{ section.id }} {
            padding-top: {{ bs.section_padding_top_md }}px;
            padding-bottom: {{ bs.section_padding_bottom_md }}px;
          }
        }
        @media all and (max-width: 767px) {
          #shopify-section-{{ section.id }} {
            padding-top: {{ bs.section_padding_top_xs }}px;
            padding-bottom: {{ bs.section_padding_bottom_xs }}px;
          }
        }
      </style>
    {%- endif -%}
  {% endif %}
  {% if block.type == 'section_margin' %}
    <style>
      #shopify-section-{{ section.id }} {
        margin-top: {{ bs.section_margin_top }}px;
        margin-bottom: {{ bs.section_margin_bottom }}px;
      }
      @media all and (min-width: 768px) and (max-width: 991px) {
        #shopify-section-{{ section.id }} {
          margin-top: {{ bs.section_margin_top_md }}px;
          margin-bottom: {{ bs.section_margin_bottom_md }}px;
        }
      }
      @media all and (max-width: 767px) {
        #shopify-section-{{ section.id }} {
          margin-top: {{ bs.section_margin_top_xs }}px;
          margin-bottom: {{ bs.section_margin_bottom_xs }}px;
        }
      }
    </style>
  {% endif %}
  {% if block.type == 'section_background' %}
    <style>
      #shopify-section-{{ section.id }} {
        background-color: {{ bs.section_bg_color }};
        {% if bs.section_bg_image != blank %}
          background-image: url({{ bs.section_bg_image | image_url }});
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;
        {% endif %}
      }
    </style>
  {% endif %}
{% endfor %}

{%- liquid
  assign video_mode = section.settings.video_mode | default: 'normal'

  assign sw = section.settings.section_width | default: 'full_width'
  if sw == 'default' or sw == 'contained'
    assign sw = 'page_width'
  elsif sw == 'full'
    assign sw = 'full_width'
  elsif sw == 'fluid'
    assign sw = 'page_fluid'
  endif
  case sw
    when 'narrow'
      assign sw_class = 'page-width page-width--narrow'
    when 'page_width'
      assign sw_class = 'page-width'
    when 'page_fluid'
      assign sw_class = 'page-width page-width--fluid'
    when 'full_width'
      assign sw_class = ''
  endcase

  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign video_alt = section.settings.video.alt | default: section.settings.description
  assign alt = 'sections.video.load_video' | t: description: video_alt | escape
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image

  assign has_shopify_video = false
  if section.settings.video != null
    assign has_shopify_video = true
  endif

  assign has_video_url = false
  if section.settings.video_url != null
    assign has_video_url = true
  endif

  if has_shopify_video and poster != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif

  assign loop_param = ''
  if section.settings.enable_video_looping
    assign loop_param = '&loop=1&playlist=' | append: video_id
  endif
-%}

{%- if video_mode == 'background' -%}
  {%- comment -%} ======================== BACKGROUND MODE ======================== {%- endcomment -%}

  {%- liquid
    assign content_layout = section.settings.content_layout | default: 'full'
    assign cp_top    = section.settings.content_padding_top    | default: 0
    assign cp_bottom = section.settings.content_padding_bottom | default: 0
    assign cp_left   = section.settings.content_padding_left   | default: 0
    assign cp_right  = section.settings.content_padding_right  | default: 0
    assign cp_top_m    = section.settings.content_padding_top_mobile    | times: 1
    assign cp_bottom_m = section.settings.content_padding_bottom_mobile | times: 1
    assign cp_left_m   = section.settings.content_padding_left_mobile   | times: 1
    assign cp_right_m  = section.settings.content_padding_right_mobile  | times: 1
  -%}

  {%- liquid
    assign mobile_scheme_id = section.settings.mobile_color_scheme | strip
    assign desktop_scheme_id = section.settings.color_scheme | strip
    assign ms_scheme = nil
    for scheme in settings.color_schemes
      if scheme.id == mobile_scheme_id
        assign ms_scheme = scheme
      endif
    endfor
    if ms_scheme
      assign ms_bg = ms_scheme.settings.background
      assign ms_bg_brightness = ms_bg | color_brightness
      if ms_bg_brightness <= 26
        assign ms_bg_contrast = ms_bg | color_lighten: 50
      elsif ms_bg_brightness <= 65
        assign ms_bg_contrast = ms_bg | color_lighten: 5
      else
        assign ms_bg_contrast = ms_bg | color_darken: 25
      endif
    endif
  -%}

  {%- style -%}
    #Banner-{{ section.id }}::after {
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
    {%- if section.settings.video_height == 'natural' -%}
      #Banner-{{ section.id }} .ms-video-banner__media {
        aspect-ratio: {{ section.settings.video.aspect_ratio | default: 1.7778 }};
      }
    {%- endif -%}
    #Banner-{{ section.id }} .banner__content {
      padding-top: {{ cp_top }}px;
      padding-bottom: {{ cp_bottom }}px;
      padding-left: {{ cp_left }}px;
      padding-right: {{ cp_right }}px;
    }
    @media screen and (max-width: 749px) {
      #Banner-{{ section.id }} .banner__content {
        padding-top: {{ cp_top_m }}px;
        padding-bottom: {{ cp_bottom_m }}px;
        padding-left: {{ cp_left_m }}px;
        padding-right: {{ cp_right_m }}px;
      }
      {%- if ms_scheme and mobile_scheme_id != desktop_scheme_id -%}
        #Banner-{{ section.id }} .banner__box {
          --color-background: {{ ms_scheme.settings.background.red }},{{ ms_scheme.settings.background.green }},{{ ms_scheme.settings.background.blue }};
          {%- if ms_scheme.settings.background_gradient != empty -%}
            --gradient-background: {{ ms_scheme.settings.background_gradient }};
          {%- else -%}
            --gradient-background: {{ ms_scheme.settings.background }};
          {%- endif -%}
          --color-foreground: {{ ms_scheme.settings.text.red }},{{ ms_scheme.settings.text.green }},{{ ms_scheme.settings.text.blue }};
          --color-background-contrast: {{ ms_bg_contrast.red }},{{ ms_bg_contrast.green }},{{ ms_bg_contrast.blue }};
          --color-shadow: {{ ms_scheme.settings.shadow.red }},{{ ms_scheme.settings.shadow.green }},{{ ms_scheme.settings.shadow.blue }};
          --color-button: {{ ms_scheme.settings.button.red }},{{ ms_scheme.settings.button.green }},{{ ms_scheme.settings.button.blue }};
          --color-button-text: {{ ms_scheme.settings.button_label.red }},{{ ms_scheme.settings.button_label.green }},{{ ms_scheme.settings.button_label.blue }};
          --color-secondary-button: {{ ms_scheme.settings.background.red }},{{ ms_scheme.settings.background.green }},{{ ms_scheme.settings.background.blue }};
          --color-secondary-button-text: {{ ms_scheme.settings.secondary_button_label.red }},{{ ms_scheme.settings.secondary_button_label.green }},{{ ms_scheme.settings.secondary_button_label.blue }};
          --color-link: {{ ms_scheme.settings.secondary_button_label.red }},{{ ms_scheme.settings.secondary_button_label.green }},{{ ms_scheme.settings.secondary_button_label.blue }};
          --payment-terms-background-color: rgb({{ ms_scheme.settings.background.rgb }});
          background: rgb(var(--color-background));
        }
      {%- endif -%}
    }
  {%- endstyle -%}

  <div id="section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
    <ms-video-bg
      id="Banner-{{ section.id }}"
      class="banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }}{% if section.settings.video_height == 'natural' %} ms-video-banner--natural{% else %} banner--{{ section.settings.video_height }}{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.settings.hide_content_mobile %} ms-video--hide-content-mobile{% endif %}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
      data-playing
      data-muted
    >
      <div class="banner__media media ms-video-banner__media ms-video-banner__media--pos-{{ section.settings.video_position | default: 'center' }}">
        {%- if has_shopify_video -%}
          {{
            section.settings.video
            | video_tag:
              image_size: '3840x',
              autoplay: true,
              loop: section.settings.enable_video_looping,
              muted: true,
              controls: false
          }}
        {%- elsif has_video_url -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1{{ loop_param }}&controls=0&showinfo=0&rel=0&playsinline=1"
              class="js-youtube"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- else -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1{{ loop_param }}&controls=0&background=1"
              class="js-vimeo"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- endif -%}
        {%- elsif request.design_mode -%}
          <div class="ms-video-banner__placeholder">
            <p>Nessun video configurato. Carica un video Shopify o inserisci un URL YouTube/Vimeo.</p>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.show_controls and has_shopify_video -%}
        {%- liquid
          assign vol_icon = section.settings.icon_unmute | default: 'icon-volume.svg'
          assign vol_mute_icon = section.settings.icon_mute | default: 'icon-volume-mute.svg'
        -%}
        <div class="ms-video-controls ms-video-controls--{{ section.settings.controls_position }} ms-video-controls--{{ section.settings.controls_theme | default: 'dark' }}" role="group" aria-label="Controlli video">
          <button
            class="ms-video-controls__btn"
            data-ms-video-action="play-pause"
            type="button"
            aria-label="Pausa"
          >
            <span class="ms-video-controls__icon ms-video-controls__icon--play" aria-hidden="true">
              {%- render 'ms_icon', icon: settings.ms_icon_play -%}
            </span>
            <span class="ms-video-controls__icon ms-video-controls__icon--pause" aria-hidden="true">
              {%- render 'ms_icon', icon: settings.ms_icon_pause -%}
            </span>
          </button>
          <button
            class="ms-video-controls__btn"
            data-ms-video-action="mute-unmute"
            type="button"
            aria-label="Attiva audio"
          >
            <span class="ms-video-controls__icon ms-video-controls__icon--unmuted" aria-hidden="true">
              {%- render 'ms_icon', icon: vol_icon -%}
            </span>
            <span class="ms-video-controls__icon ms-video-controls__icon--muted" aria-hidden="true">
              {%- render 'ms_icon', icon: vol_mute_icon -%}
            </span>
          </button>
        </div>
      {%- endif -%}

      <div class="banner__content banner__content--{{ section.settings.desktop_content_position }}{% if section.settings.mobile_content_position != 'inherit' and section.settings.mobile_content_position != blank %} banner__content--mobile-{{ section.settings.mobile_content_position }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if content_layout == 'contained' -%}<div class="page-width" style="width:100%;">{%- endif -%}
        <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient" style="{% unless section.settings.show_text_box %}padding:0;{% endunless %}max-width:none;min-width:0;">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                {%- liquid
                  assign title_tag = block.settings.title_tag | default: 'div'
                  assign title_classes = 'banner__heading inline-richtext ' | append: block.settings.heading_size
                  if block.settings.title_custom_class != blank
                    assign title_classes = title_classes | append: ' ' | append: block.settings.title_custom_class
                  endif
                -%}
                <{{ title_tag }}
                  class="{{ title_classes }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.heading }}
                </{{ title_tag }}>
              {%- when 'text' -%}
                <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                  <p>{{ block.settings.text }}</p>
                </div>
              {%- when 'buttons' -%}
                <div
                  class="banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.button_label_1 != blank and block.settings.button_link_1 != blank -%}
                    <a
                      {% if block.settings.button_link_1 == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ block.settings.button_link_1 }}"
                      {% endif %}
                      class="{%- render 'ms_button_classes', type: block.settings.button_type_1, secondary: block.settings.button_style_secondary_1, size: block.settings.button_size_1 -%}"
                    >
                      {%- render 'ms_button_icon', icon: block.settings.button_icon_1, position: block.settings.button_icon_position_1, slot: 'before' -%}
                      {{- block.settings.button_label_1 | escape -}}
                      {%- render 'ms_button_icon', icon: block.settings.button_icon_1, position: block.settings.button_icon_position_1, slot: 'after' -%}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank and block.settings.button_link_2 != blank -%}
                    <a
                      {% if block.settings.button_link_2 == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ block.settings.button_link_2 }}"
                      {% endif %}
                      class="{%- render 'ms_button_classes', type: block.settings.button_type_2, secondary: block.settings.button_style_secondary_2, size: block.settings.button_size_2 -%}"
                    >
                      {%- render 'ms_button_icon', icon: block.settings.button_icon_2, position: block.settings.button_icon_position_2, slot: 'before' -%}
                      {{- block.settings.button_label_2 | escape -}}
                      {%- render 'ms_button_icon', icon: block.settings.button_icon_2, position: block.settings.button_icon_position_2, slot: 'after' -%}
                    </a>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {%- if content_layout == 'contained' -%}</div>{%- endif -%}
      </div>
    </ms-video-bg>

  </div>

{%- else -%}
  {%- comment -%} ======================== NORMAL MODE ======================== {%- endcomment -%}

  {%- capture sizes -%}
    {%- if sw == 'full_width' -%}
      100vw
    {%- else -%}
      (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), 100vw
    {%- endif -%}
  {%- endcapture -%}

  <div id="section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
    <div class="video-section isolate{% unless sw_class == blank %} {{ sw_class }}{% endunless %}">

      {%- liquid
        assign ms_video_media_class = 'video-section__media global-media-settings'
        if sw == 'full_width'
          assign ms_video_media_class = ms_video_media_class | append: ' global-media-settings--full-width'
        endif
        if fix_ratio
          assign ms_video_media_class = ms_video_media_class | append: ' media-fit-cover'
        endif
        if settings.animations_reveal_on_scroll
          assign ms_video_media_class = ms_video_media_class | append: ' scroll-trigger animate--slide-in'
        endif
      -%}

      {%- if poster != null -%}
        <deferred-media
          class="{{ ms_video_media_class }} deferred-media gradient"
          data-media-id="{{ video_id }}"
          style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
        >
          <button
            id="Deferred-Poster-Modal-{{ video_id }}"
            class="video-section__poster media deferred-media__poster media--landscape"
            type="button"
            aria-label="{{ alt }}"
          >
            {{
              poster
              | image_url: width: 3840
              | image_tag: sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: alt
            }}
            <span class="deferred-media__poster-button motion-reduce">
              {%- render 'ms_icon', icon: settings.ms_icon_play -%}
            </span>
          </button>
          <template>
            {%- if has_shopify_video -%}
              {{
                section.settings.video
                | video_tag:
                  image_size: '1100x',
                  autoplay: true,
                  loop: section.settings.enable_video_looping,
                  controls: true,
                  muted: false
              }}
            {%- elsif has_video_url -%}
              {%- if section.settings.video_url.type == 'youtube' -%}
                <iframe
                  src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1{{ loop_param }}"
                  class="js-youtube"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  title="{{ section.settings.description | escape }}"
                ></iframe>
              {%- else -%}
                <iframe
                  src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1{{ loop_param }}"
                  class="js-vimeo"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  title="{{ section.settings.description | escape }}"
                ></iframe>
              {%- endif -%}
            {%- endif -%}
          </template>
        </deferred-media>

      {%- elsif has_shopify_video -%}
        <div class="{{ ms_video_media_class }}">
          {{
            section.settings.video
            | video_tag:
              image_size: '1100x',
              autoplay: false,
              loop: section.settings.enable_video_looping,
              controls: true,
              muted: false
          }}
        </div>

      {%- elsif has_video_url -%}
        <div class="{{ ms_video_media_class }}">
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1{{ loop_param }}"
              class="js-youtube"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- else -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}{{ loop_param }}"
              class="js-vimeo"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- endif -%}
        </div>

      {%- elsif request.design_mode -%}
        <div class="{{ ms_video_media_class }}" style="display:flex;align-items:center;justify-content:center;aspect-ratio:16/9;background:#f0f0f0;">
          <p style="color:#666;font-size:0.9rem;">Nessun video configurato. Carica un video Shopify o inserisci un URL YouTube/Vimeo.</p>
        </div>
      {%- endif -%}

    </div>
  </div>

{%- endif -%}

<script>
(function () {
  if (customElements.get('ms-video-bg')) return;

  class MsVideoBg extends HTMLElement {
    connectedCallback() {
      this.video = this.querySelector('video');
      if (!this.video) return;

      this.video.setAttribute('playsinline', '');
      this.video.playsInline = true;

      this.querySelectorAll('[data-ms-video-action]').forEach(function (btn) {
        btn.addEventListener('click', this.onControlClick.bind(this));
      }.bind(this));

      this.video.addEventListener('play', this.syncState.bind(this));
      this.video.addEventListener('pause', this.syncState.bind(this));
      this.video.addEventListener('volumechange', this.syncState.bind(this));

      requestAnimationFrame(this.syncState.bind(this));
    }

    onControlClick(e) {
      var action = e.currentTarget.getAttribute('data-ms-video-action');
      if (action === 'play-pause') {
        if (this.video.paused) {
          this.video.play();
        } else {
          this.video.pause();
        }
      } else if (action === 'mute-unmute') {
        this.video.muted = !this.video.muted;
      }
    }

    syncState() {
      if (!this.video) return;

      if (this.video.paused) {
        this.removeAttribute('data-playing');
      } else {
        this.setAttribute('data-playing', '');
      }

      if (this.video.muted) {
        this.setAttribute('data-muted', '');
      } else {
        this.removeAttribute('data-muted');
      }

      var playBtn = this.querySelector('[data-ms-video-action="play-pause"]');
      if (playBtn) {
        playBtn.setAttribute('aria-label', this.video.paused ? 'Play' : 'Pausa');
      }

      var muteBtn = this.querySelector('[data-ms-video-action="mute-unmute"]');
      if (muteBtn) {
        muteBtn.setAttribute('aria-label', this.video.muted ? 'Attiva audio' : 'Disattiva audio');
      }
    }
  }

  customElements.define('ms-video-bg', MsVideoBg);

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[id^="Deferred-Poster-Modal-"]');
    if (!btn) return;
    var dm = btn.closest('deferred-media');
    if (!dm) return;

    var observer = new MutationObserver(function (mutations, obs) {
      var iframe = dm.querySelector('iframe');
      if (!iframe) return;
      obs.disconnect();
      iframe.addEventListener('load', function () {
        if (iframe.src.indexOf('youtube.com') !== -1) {
          iframe.contentWindow.postMessage(
            '{"event":"command","func":"playVideo","args":""}', '*'
          );
        } else if (iframe.src.indexOf('vimeo.com') !== -1) {
          iframe.contentWindow.postMessage(
            '{"method":"play"}', '*'
          );
        }
      });
    });
    observer.observe(dm, { childList: true, subtree: true });
  });
})();
</script>

{%- liquid
  assign sd_video_name = section.settings.description | strip_html | strip | truncate: 5000
  assign sd_video_thumb = section.settings.cover_image | default: section.settings.video.preview_image
  assign sd_video_has_url = false
  if section.settings.video_url != null
    assign sd_video_has_url = true
  endif
-%}
{%- if sd_video_name != blank and sd_video_has_url -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": {{ sd_video_name | json }},
    "description": {{ sd_video_name | json }},
    {%- if sd_video_thumb -%}
    "thumbnailUrl": "{{ sd_video_thumb | image_url: width: 1200 }}",
    {%- endif -%}
    {%- if section.settings.video_url.type == 'youtube' -%}
    "embedUrl": "https://www.youtube.com/embed/{{ section.settings.video_url.id }}",
    {%- elsif section.settings.video_url.type == 'vimeo' -%}
    "embedUrl": "https://player.vimeo.com/video/{{ section.settings.video_url.id }}",
    {%- endif -%}
    "uploadDate": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  }
  </script>
{%- elsif sd_video_name != blank and section.settings.video != null -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": {{ sd_video_name | json }},
    "description": {{ sd_video_name | json }},
    {%- if sd_video_thumb -%}
    "thumbnailUrl": "{{ sd_video_thumb | image_url: width: 1200 }}",
    {%- endif -%}
    "contentUrl": "{{ section.settings.video.sources[0].url }}",
    "uploadDate": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  }
  </script>
{%- endif -%}

{% schema %}
{
